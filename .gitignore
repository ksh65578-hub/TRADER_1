__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Volatile non-live runtime artifacts generated by local PAPER/SHADOW runs.
# Tracked evidence snapshots remain tracked; these rules only prevent new
# smoke-run outputs from dirtying the workspace.
system/runtime/**/paper_runtime/runner/archive/
system/runtime/**/paper_runtime/runner/runner_events.jsonl
system/runtime/**/paper_runtime/runner/runner_status.json
system/runtime/**/paper_runtime/runner/runner_retention_manifest.json
system/runtime/**/paper_runtime/runner/runner_start_reconciliation.json
system/runtime/**/paper_runtime/runner/STOP_UPBIT_PAPER.signal
system/runtime/**/paper_runtime/current_evidence/archive/
system/runtime/**/paper_runtime/cycles/upbit-paper-runner-*
system/runtime/**/paper_runtime/upbit-paper-runner-*.persistent_loop_report.json
system/runtime/**/paper_runtime/upbit-paper-runner-*-recovery-guard.json
system/runtime/**/paper_runtime/upbit-paper-runner-*-preflight-recovery-guard.json
system/runtime/**/ledger/cycles/upbit-paper-runner-*
system/runtime/**/ledger/dashboard-current-truth-rollup-*
system/runtime/**/ledger/upbit-paper-runner-*
system/runtime/**/market_data/public/raw/upbit-paper-runner-*
system/runtime/**/market_data/public/canonical/upbit-paper-runner-*
system/runtime/**/market_data/public/collection/upbit-paper-runner-*
system/runtime/**/profitability/candidate_scorecards/*.candidate_scorecard.json
system/runtime/**/profitability/overfit_diagnostics/*.overfit_diagnostic_report.json
