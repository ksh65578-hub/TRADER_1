    "quarantine_blockers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "one_line_summary": {
      "type": "string",
      "minLength": 1
    },
    "primary_next_action": {
      "type": "string",
      "minLength": 1
    },
    "operator_no_action_needed_for_next_non_live_patch": {
      "const": true
    },
    "operator_action_required_for_gap_closure": {
      "const": true
    },
    "evidence_file_content_read": {
      "const": false
    },
    "evidence_artifact_hash_recomputed": {
      "const": false
    },
    "secret_pattern_content_scan_performed": {
      "const": false
    },
    "current_evidence_write_allowed": {
      "const": false
    },
    "gap_closure_allowed_by_this_patch": {
      "const": false
    },
    "live_ready_write_allowed": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "credential_values_read": {
      "const": false
    },
    "credential_environment_inspection_performed": {
      "const": false
    },
    "runtime_artifacts_staged_by_this_patch": {
      "const": false
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "validation_status": {
      "const": "PASS"
    },
    "validation_errors": {
      "type": "array",
      "maxItems": 0
    },
    "report_hash": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "source_report_ref": {
      "type": "object",
      "required": ["role", "patch_id", "report_hash"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "enum": [
            "residual_operator_reconciliation_submission_manifest_preflight",
            "residual_operator_reconciliation_submission_template_packet"
          ]
        },
        "patch_id": {
          "type": "string",
          "minLength": 1
        },
        "report_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "security_control": {
      "type": "object",
      "required": ["control_id", "status", "required_behavior"],
      "additionalProperties": false,
      "properties": {
        "control_id": {
          "enum": [
            "SUBMISSION_PATH_PREFIX_ONLY",
            "NO_CONTENT_READ_IN_QUARANTINE",
            "NO_CREDENTIAL_OR_LIVE_CONFIG_PATHS",
            "NO_ACCEPTANCE_OR_GAP_CLOSURE"
          ]
        },
        "status": {
          "const": "PASS"
        },
        "required_behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
