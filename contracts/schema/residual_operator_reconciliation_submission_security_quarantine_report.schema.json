      "const": false
    },
    "operator_submission_accepted": {
      "const": false
    },
    "allowed_submission_prefix": {
      "const": "system/evidence/operator_submissions/residual_operator_reconciliation/"
    },
    "allowed_artifact_extensions": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "enum": [".json", ".jsonl", ".md", ".txt", ".csv"]
      }
    },
    "forbidden_path_tokens": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_manifest_item_count": {
      "const": 32
    },
    "manifest_item_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 32
    },
    "missing_manifest_item_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 32
    },
    "required_control_count": {
      "const": 4
    },
    "manifest_control_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "missing_control_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "template_manifest_item_count": {
      "const": 32
    },
    "template_control_count": {
      "const": 4
    },
    "preflight_unsafe_manifest_flag_count": {
      "type": "integer",
      "minimum": 0
    },
    "preflight_path_policy_violation_count": {
      "type": "integer",
      "minimum": 0
    },
    "preflight_source_hash_mismatch_count": {
      "type": "integer",
      "minimum": 0
    },
    "template_path_placeholder_violation_count": {
      "type": "integer",
      "minimum": 0
    },
    "template_path_placeholder_violations": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string"
      }
    },
    "security_control_count": {
      "const": 4
    },
    "security_controls": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/security_control"
      }
    },
    "quarantine_blocker_count": {
      "type": "integer",
      "minimum": 1
