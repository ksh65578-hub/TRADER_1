{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.shadow_observation_actual_runtime_harness_report.v1",
  "title": "TRADER_1 Shadow Observation Actual Runtime Harness Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "harness_id",
    "exchange",
    "market_type",
    "source_mode",
    "mode",
    "session_id",
    "harness_execution_mode",
    "data_source_role",
    "runtime_artifact_path",
    "source_runtime_id",
    "source_runtime_report_hash",
    "source_runtime_hash_verified",
    "source_runtime_validation_status",
    "source_actual_blocker_report_hash",
    "source_actual_blocker_hash_verified",
    "source_actual_blocker_validation_status",
    "requested_cycle_count",
    "completed_cycle_count",
    "observations_per_cycle",
    "observation_count",
    "heartbeat_count",
    "measured_runtime_seconds",
    "runtime_measurement_source",
    "monotonic_timer_started",
    "monotonic_timer_stopped",
    "measured_runtime_seconds_verified",
    "runtime_measurement_status",
    "minimum_runtime_window_seconds",
    "minimum_actual_cycle_count",
    "minimum_evidence_window_met",
    "minimum_cycle_count_met",
    "actual_non_live_runtime_harness_executed",
    "runtime_evidence_status",
    "runtime_evidence_role",
    "long_run_evidence_present",
    "long_run_evidence_eligible",
    "dashboard_display_truth_only",
    "dashboard_visibility_status",
    "optimizer_input_role",
    "promotion_eligible",
    "credential_access_attempted",
    "exchange_account_call_attempted",
    "live_order_api_attempted",
    "order_adapter_called",
    "optimizer_ranking_input_attempted",
    "scale_up_requested",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "harness_status",
    "primary_blocker_code",
    "blockers",
    "operator_message",
    "next_operator_action",
    "harness_report_hash"
  ],
  "properties": {
    "schema_id": {"const": "trader1.shadow_observation_actual_runtime_harness_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "harness_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "source_mode": {"const": "PAPER"},
    "mode": {"const": "SHADOW"},
    "session_id": {"type": "string", "minLength": 1},
    "harness_execution_mode": {"const": "NON_LIVE_LOCAL_PAPER_SHADOW_HARNESS"},
    "data_source_role": {"enum": ["DETERMINISTIC_PAPER_FIXTURE_NO_CREDENTIALS", "UPBIT_PAPER_RUNTIME_LOOP_NO_CREDENTIALS"]},
    "runtime_artifact_path": {"type": "string", "pattern": "^system/runtime/upbit/krw_spot/shadow/.+actual_runtime_harness_report\\.json$"},
    "source_runtime_id": {"type": "string", "minLength": 1},
    "source_runtime_report_hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "source_runtime_hash_verified": {"const": true},
    "source_runtime_validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
    "source_actual_blocker_report_hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "source_actual_blocker_hash_verified": {"const": true},
    "source_actual_blocker_validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
    "requested_cycle_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "completed_cycle_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "observations_per_cycle": {"type": "integer", "minimum": 1, "maximum": 20},
    "observation_count": {"type": "integer", "minimum": 1, "maximum": 400},
    "heartbeat_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "measured_runtime_seconds": {"type": "integer", "minimum": 0, "maximum": 300},
    "runtime_measurement_source": {
      "enum": [
        "MONOTONIC_LOCAL_TIMER_VERIFIED",
        "PAPER_LOOP_TIMESTAMP_SPAN_VERIFIED",
        "CALLER_SUPPLIED_UNVERIFIED"
      ]
    },
    "monotonic_timer_started": {"type": "boolean"},
    "monotonic_timer_stopped": {"type": "boolean"},
    "measured_runtime_seconds_verified": {"type": "boolean"},
    "runtime_measurement_status": {"enum": ["VERIFIED_SHORT_WINDOW", "BLOCKED_UNVERIFIED_MEASUREMENT"]},
    "minimum_runtime_window_seconds": {"type": "integer", "minimum": 86400},
    "minimum_actual_cycle_count": {"type": "integer", "minimum": 2880},
    "minimum_evidence_window_met": {"const": false},
    "minimum_cycle_count_met": {"const": false},
    "actual_non_live_runtime_harness_executed": {"type": "boolean"},
    "runtime_evidence_status": {"const": "BLOCKED_LONG_RUN_EVIDENCE_MISSING"},
    "runtime_evidence_role": {"const": "EXECUTION_HARNESS_PROOF_ONLY_NOT_LONG_RUN"},
    "long_run_evidence_present": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "dashboard_display_truth_only": {"const": true},
    "dashboard_visibility_status": {"const": "VISIBLE_AS_SHORT_WINDOW_BLOCKED"},
    "optimizer_input_role": {"const": "BLOCKER_ONLY_NOT_RANKING_INPUT"},
    "promotion_eligible": {"const": false},
    "credential_access_attempted": {"const": false},
    "exchange_account_call_attempted": {"const": false},
    "live_order_api_attempted": {"const": false},
    "order_adapter_called": {"const": false},
    "optimizer_ranking_input_attempted": {"const": false},
    "scale_up_requested": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "harness_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"$ref": "common.defs.schema.json#/$defs/live_blocker_code"},
    "blockers": {"type": "array", "minItems": 1, "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "operator_message": {"type": "string", "minLength": 1},
    "next_operator_action": {"type": "string", "minLength": 1},
    "harness_report_hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"}
  }
}
