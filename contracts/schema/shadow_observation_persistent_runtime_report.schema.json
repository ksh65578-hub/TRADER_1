{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.shadow_observation_persistent_runtime_report.v1",
  "title": "shadow_observation_persistent_runtime_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "runtime_id",
    "scheduler_id",
    "stream_id",
    "exchange",
    "market_type",
    "source_mode",
    "mode",
    "runtime_artifact_path",
    "runtime_execution_mode",
    "runtime_evidence_role",
    "actual_persistent_runtime_executed",
    "source_scheduler_guard_hash",
    "source_scheduler_guard_status",
    "source_scheduler_validation_status",
    "requested_cycle_count",
    "completed_cycle_count",
    "max_cycle_count",
    "heartbeat_count",
    "heartbeat_interval_seconds",
    "heartbeat_status",
    "max_runtime_seconds",
    "runtime_duration_evidence_source",
    "estimated_runtime_seconds",
    "observed_runtime_seconds",
    "duration_evidence_role",
    "atomic_commit_count",
    "cycle_commit_ids",
    "distinct_cycle_commit_count",
    "duplicate_cycle_commit_count",
    "cycle_identity_status",
    "partial_temp_artifact_count",
    "graceful_shutdown",
    "recovery_action",
    "runtime_status",
    "run_action",
    "long_run_evidence_eligible",
    "optimizer_input_role",
    "dashboard_display_truth_only",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "runtime_report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.shadow_observation_persistent_runtime_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "runtime_id": {"type": "string", "minLength": 1},
    "scheduler_id": {"type": "string", "minLength": 1},
    "stream_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "source_mode": {"const": "PAPER"},
    "mode": {"const": "SHADOW"},
    "runtime_artifact_path": {
      "type": "string",
      "pattern": "^system/runtime/upbit/krw_spot/shadow/.+shadow_observation_persistent_runtime_report\\.json$"
    },
    "runtime_execution_mode": {"const": "BOUNDED_SHADOW_STUB"},
    "runtime_evidence_role": {"const": "PERSISTENT_RUNTIME_STUB_ONLY"},
    "actual_persistent_runtime_executed": {"const": false},
    "source_scheduler_guard_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "source_scheduler_guard_status": {"enum": ["PASS", "BLOCKED", "FAIL", "UNKNOWN"]},
    "source_scheduler_validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
    "requested_cycle_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "completed_cycle_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "max_cycle_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "heartbeat_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "heartbeat_interval_seconds": {"type": "integer", "minimum": 1, "maximum": 300},
    "heartbeat_status": {"enum": ["PASS", "BLOCKED"]},
    "max_runtime_seconds": {"type": "integer", "minimum": 1, "maximum": 300},
    "runtime_duration_evidence_source": {"const": "STUB_ESTIMATE_ONLY"},
    "estimated_runtime_seconds": {"type": "integer", "minimum": 0, "maximum": 300},
    "observed_runtime_seconds": {"const": 0},
    "duration_evidence_role": {"const": "NOT_LONG_RUN_EVIDENCE"},
    "atomic_commit_count": {"type": "integer", "minimum": 0},
    "cycle_commit_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
    },
    "distinct_cycle_commit_count": {"type": "integer", "minimum": 0},
    "duplicate_cycle_commit_count": {"type": "integer", "minimum": 0},
    "cycle_identity_status": {"enum": ["PASS", "BLOCKED"]},
    "partial_temp_artifact_count": {"type": "integer", "minimum": 0},
    "graceful_shutdown": {"type": "boolean"},
    "recovery_action": {"enum": ["NO_RECOVERY_NEEDED", "RECONCILE_REQUIRED"]},
    "runtime_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "run_action": {"enum": ["COLLECT_SHADOW_OBSERVATION_STUB_ONLY", "BLOCKED"]},
    "long_run_evidence_eligible": {"const": false},
    "optimizer_input_role": {"const": "SHADOW_PERSISTENT_RUNTIME_STUB_ONLY"},
    "dashboard_display_truth_only": {"const": true},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "order_adapter_called": {"const": false},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "runtime_report_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  }
}
