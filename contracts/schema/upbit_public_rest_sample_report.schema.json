{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_public_rest_sample_report.v1",
  "title": "upbit_public_rest_sample_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "sample_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "endpoint_host",
    "endpoint_path",
    "network_call_attempted",
    "sample_status",
    "collection_status",
    "public_market_data",
    "public_collection_report",
    "canonical_event_count",
    "primary_blocker_code",
    "blockers",
    "latency_ms",
    "fetch_error",
    "evidence_role",
    "credential_load_attempted",
    "authorization_header_present",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "sample_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_public_rest_sample_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "sample_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "endpoint_host": {"const": "api.upbit.com"},
    "endpoint_path": {"const": "/v1/candles/minutes/1"},
    "network_call_attempted": {"type": "boolean"},
    "sample_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "collection_status": {"enum": ["PASS", "BLOCKED", "FAIL", "NOT_RUN"]},
    "public_market_data": {"type": ["object", "null"]},
    "public_collection_report": {"type": ["object", "null"]},
    "canonical_event_count": {"type": "integer", "minimum": 0},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "latency_ms": {"type": "number", "minimum": 0},
    "fetch_error": {"type": ["string", "null"]},
    "evidence_role": {"const": "PAPER_INPUT_QUALITY_SAMPLE_ONLY_NOT_LIVE_READY"},
    "credential_load_attempted": {"const": false},
    "authorization_header_present": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "sample_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
