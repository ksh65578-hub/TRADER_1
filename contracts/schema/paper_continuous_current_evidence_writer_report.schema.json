{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_continuous_current_evidence_writer_report.v1",
  "title": "PAPER Continuous Current Evidence Writer Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "continuous_writer_status",
    "truth_freshness_status",
    "writer_summary",
    "next_action",
    "writer_implemented",
    "writer_active_for_paper_current_truth",
    "writer_stale",
    "writer_source_present",
    "writer_source_valid",
    "current_snapshot_valid",
    "portfolio_snapshot_valid",
    "current_truth_refresh_valid",
    "runtime_truth_active",
    "source_hash_bound",
    "source_audited_writer_hash",
    "source_audited_writer_status",
    "source_audited_writer_validator_status",
    "source_current_evidence_snapshot_hash",
    "source_current_evidence_status",
    "source_current_evidence_validator_status",
    "source_portfolio_snapshot_hash",
    "source_portfolio_snapshot_status",
    "source_portfolio_validator_status",
    "source_current_truth_refresh_hash",
    "source_current_truth_refresh_status",
    "source_current_truth_refresh_validator_status",
    "source_runtime_truth_state_hash",
    "source_runtime_truth_status",
    "source_runtime_truth_validator_status",
    "source_paper_ledger_head_hash",
    "source_runtime_cycle_id",
    "configured_capital_krw",
    "last_verified_paper_ledger_equity_krw",
    "current_refreshed_paper_equity_krw",
    "stale_display_only_equity_krw",
    "max_source_age_seconds",
    "delayed_after_seconds",
    "stale_after_seconds",
    "primary_blocker_code",
    "blockers",
    "evidence_role",
    "paper_only",
    "display_only",
    "dashboard_truth_only",
    "current_trading_review_allowed",
    "current_evidence_write_allowed",
    "audited_current_evidence_write_allowed",
    "portfolio_truth_write_allowed",
    "live_ready_write_allowed",
    "live_config_mutation_allowed",
    "credential_load_attempted",
    "authorization_header_present",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "scale_up_allowed",
    "continuous_writer_report_hash"
  ],
  "$defs": {
    "hash_or_null": {
      "type": ["string", "null"],
      "minLength": 64,
      "maxLength": 64
    },
    "string_or_null": {
      "type": ["string", "null"]
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.paper_continuous_current_evidence_writer_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "continuous_writer_status": {
      "enum": [
        "NOT_IMPLEMENTED",
        "IMPLEMENTED_BLOCKED",
        "IMPLEMENTED_WRITING_PAPER_CURRENT_TRUTH",
        "IMPLEMENTED_STALE"
      ]
    },
    "truth_freshness_status": {
      "enum": ["FRESH", "DELAYED", "STALE_DISPLAY_ONLY", "INVALID"]
    },
    "writer_summary": {"type": "string", "minLength": 1},
    "next_action": {"type": "string", "minLength": 1},
    "writer_implemented": {"type": "boolean"},
    "writer_active_for_paper_current_truth": {"type": "boolean"},
    "writer_stale": {"type": "boolean"},
    "writer_source_present": {"type": "boolean"},
    "writer_source_valid": {"type": "boolean"},
    "current_snapshot_valid": {"type": "boolean"},
    "portfolio_snapshot_valid": {"type": "boolean"},
    "current_truth_refresh_valid": {"type": "boolean"},
    "runtime_truth_active": {"type": "boolean"},
    "source_hash_bound": {"type": "boolean"},
    "source_audited_writer_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_audited_writer_status": {"type": "string", "minLength": 1},
    "source_audited_writer_validator_status": {"type": "string", "minLength": 1},
    "source_current_evidence_snapshot_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_current_evidence_status": {"type": "string", "minLength": 1},
    "source_current_evidence_validator_status": {"type": "string", "minLength": 1},
    "source_portfolio_snapshot_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_portfolio_snapshot_status": {"type": "string", "minLength": 1},
    "source_portfolio_validator_status": {"type": "string", "minLength": 1},
    "source_current_truth_refresh_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_current_truth_refresh_status": {"type": "string", "minLength": 1},
    "source_current_truth_refresh_validator_status": {"type": "string", "minLength": 1},
    "source_runtime_truth_state_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_runtime_truth_status": {"type": "string", "minLength": 1},
    "source_runtime_truth_validator_status": {"type": "string", "minLength": 1},
    "source_paper_ledger_head_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_runtime_cycle_id": {"$ref": "#/$defs/string_or_null"},
    "configured_capital_krw": {"$ref": "#/$defs/string_or_null"},
    "last_verified_paper_ledger_equity_krw": {"$ref": "#/$defs/string_or_null"},
    "current_refreshed_paper_equity_krw": {"$ref": "#/$defs/string_or_null"},
    "stale_display_only_equity_krw": {"$ref": "#/$defs/string_or_null"},
    "max_source_age_seconds": {"type": ["integer", "null"], "minimum": 0},
    "delayed_after_seconds": {"type": "integer", "minimum": 0},
    "stale_after_seconds": {"type": "integer", "minimum": 1},
    "primary_blocker_code": {"type": "string", "minLength": 1},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "evidence_role": {"const": "PAPER_CONTINUOUS_CURRENT_EVIDENCE_WRITER_STATUS_NOT_LIVE_READY"},
    "paper_only": {"const": true},
    "display_only": {"const": true},
    "dashboard_truth_only": {"const": true},
    "current_trading_review_allowed": {"const": false},
    "current_evidence_write_allowed": {"const": false},
    "audited_current_evidence_write_allowed": {"const": false},
    "portfolio_truth_write_allowed": {"const": false},
    "live_ready_write_allowed": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "credential_load_attempted": {"const": false},
    "authorization_header_present": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "can_submit_order": {"const": false},
    "scale_up_allowed": {"const": false},
    "continuous_writer_report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
