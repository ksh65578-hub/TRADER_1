{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_operation_gate_report.v1",
  "title": "paper_operation_gate_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "operation_gate_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "strategy_unit",
    "sizing_decision",
    "paper_dry_run_report",
    "restart_recovery_report",
    "replay_consistency_report",
    "paper_shadow_separation_report",
    "paper_shadow_evidence_accumulation_report",
    "dashboard_panels",
    "operation_gate_status",
    "stage_gate_status",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "operation_gate_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.paper_operation_gate_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "operation_gate_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "strategy_unit": {"type": "object"},
    "sizing_decision": {"type": "object"},
    "paper_dry_run_report": {"type": "object"},
    "restart_recovery_report": {"type": "object"},
    "replay_consistency_report": {"type": "object"},
    "paper_shadow_separation_report": {"type": "object"},
    "paper_shadow_evidence_accumulation_report": {"type": "object"},
    "dashboard_panels": {"type": "object"},
    "operation_gate_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "stage_gate_status": {"enum": ["PASS_FOR_MVP3_OPERATIONAL_PAPER_ONLY", "BLOCKED"]},
    "live_order_ready": {"type": "boolean"},
    "live_order_allowed": {"type": "boolean"},
    "can_live_trade": {"type": "boolean"},
    "can_submit_order": {"type": "boolean"},
    "order_adapter_called": {"type": "boolean"},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "operation_gate_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
