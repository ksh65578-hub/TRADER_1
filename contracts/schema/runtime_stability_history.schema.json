{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.runtime_stability_history.v1",
  "title": "runtime_stability_history",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "truth_role",
    "display_only",
    "dashboard_truth_only",
    "history_status",
    "history_window",
    "first_sample_at_utc",
    "latest_sample_at_utc",
    "observed_span_seconds",
    "min_validated_span_seconds",
    "min_validated_sample_count",
    "span_validation_status",
    "max_samples",
    "sample_count",
    "stable_sample_count",
    "attention_sample_count",
    "error_sample_count",
    "stale_metric_sample_count",
    "latest_sample_hash",
    "reset_reason",
    "samples",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "history_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "metric_status_counts": {
      "type": "object",
      "required": [
        "FAIL",
        "PASS",
        "STALE",
        "UNTESTED",
        "WARN"
      ],
      "additionalProperties": false,
      "properties": {
        "FAIL": {
          "type": "integer",
          "minimum": 0
        },
        "PASS": {
          "type": "integer",
          "minimum": 0
        },
        "STALE": {
          "type": "integer",
          "minimum": 0
        },
        "UNTESTED": {
          "type": "integer",
          "minimum": 0
        },
        "WARN": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sample_metric": {
      "type": "object",
      "required": [
        "metric_id",
        "status",
        "value_display"
      ],
      "additionalProperties": false,
      "properties": {
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "PASS",
            "WARN",
            "FAIL",
            "STALE",
            "UNTESTED"
          ]
        },
        "value_display": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stability_sample": {
      "type": "object",
      "required": [
        "schema_id",
        "generated_at_utc",
        "project_id",
        "exchange",
        "market_type",
        "mode",
        "session_id",
        "source_dashboard_hash",
        "status",
        "severity",
        "metric_status_counts",
        "metrics",
        "previous_sample_hash",
        "display_only",
        "dashboard_truth_only",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed",
        "sample_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_id": {
          "const": "trader1.runtime_stability_sample.v1"
        },
        "generated_at_utc": {
          "type": "string"
        },
        "project_id": {
          "const": "TRADER_1"
        },
        "exchange": {
          "$ref": "common.defs.schema.json#/$defs/exchange"
        },
        "market_type": {
          "$ref": "common.defs.schema.json#/$defs/market_type"
        },
        "mode": {
          "$ref": "common.defs.schema.json#/$defs/mode"
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "source_dashboard_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "status": {
          "enum": [
            "STABLE",
            "ATTENTION",
            "ERROR"
          ]
        },
        "severity": {
          "enum": [
            "NORMAL",
            "WARNING",
            "ERROR"
          ]
        },
        "metric_status_counts": {
          "$ref": "#/$defs/metric_status_counts"
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sample_metric"
          }
        },
        "previous_sample_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "display_only": {
          "const": true
        },
        "dashboard_truth_only": {
          "const": true
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        },
        "sample_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "trader1.runtime_stability_history.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "$ref": "common.defs.schema.json#/$defs/mode"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "truth_role": {
      "const": "dashboard_serving_truth"
    },
    "display_only": {
      "const": true
    },
    "dashboard_truth_only": {
      "const": true
    },
    "history_status": {
      "enum": [
        "INSUFFICIENT_HISTORY",
        "VALIDATED_HISTORY",
        "ATTENTION",
        "ERROR"
      ]
    },
    "history_window": {
      "const": "LAST_N_SAMPLES"
    },
    "first_sample_at_utc": {
      "type": "string"
    },
    "latest_sample_at_utc": {
      "type": "string"
    },
    "observed_span_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "min_validated_span_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "min_validated_sample_count": {
      "type": "integer",
      "minimum": 2
    },
    "span_validation_status": {
      "enum": [
        "INSUFFICIENT_SPAN",
        "SPAN_VALIDATED"
      ]
    },
    "max_samples": {
      "type": "integer",
      "minimum": 2
    },
    "sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "stable_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "attention_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "stale_metric_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "latest_sample_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "reset_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stability_sample"
      }
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "history_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    }
  }
}
