    "design_control_pass_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "design_control_blocked_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "design_controls": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/design_control"
      }
    },
    "planned_write_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
