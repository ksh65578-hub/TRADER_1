        "null"
      ]
    },
    "source_audited_writer_precheck_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_audited_writer_precheck_validator_status": {
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "source_audited_writer_candidate_ready_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_audit_gate_pass_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_audit_gate_blocked_count": {
      "type": "integer",
