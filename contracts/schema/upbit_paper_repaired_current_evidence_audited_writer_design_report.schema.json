      "const": false
    },
    "current_ledger_jsonl_write_allowed": {
      "const": false
    },
    "latest_runtime_pointer_write_allowed": {
      "const": false
    },
    "portfolio_truth_write_allowed": {
      "const": false
    },
    "portfolio_snapshot_write_allowed": {
      "const": false
    },
    "persistent_loop_mutation_allowed": {
      "const": false
    },
    "source_delete_allowed": {
      "const": false
    },
    "actual_long_run_evidence_created": {
      "const": false
    },
    "long_run_evidence_eligible": {
      "const": false
    },
    "promotion_eligible": {
      "const": false
    },
    "credential_load_attempted": {
      "const": false
    },
    "private_endpoint_called": {
      "const": false
    },
    "order_endpoint_called": {
      "const": false
    },
    "order_adapter_called": {
      "const": false
    },
    "live_key_loaded": {
      "const": false
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "can_submit_order": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "audited_writer_design_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    }
