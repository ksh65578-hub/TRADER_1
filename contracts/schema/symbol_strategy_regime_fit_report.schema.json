{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.symbol_strategy_regime_fit_report.v1",
  "title": "symbol_strategy_regime_fit_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "fit_report_id",
    "candidate_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "timeframe_scope",
    "regime_scope",
    "regime_family",
    "fit_status",
    "symbol_selection_basis",
    "liquidity_score",
    "volatility_score",
    "spread_bps",
    "depth_score",
    "depth_notional_krw",
    "average_daily_value_krw",
    "min_required_liquidity_score",
    "max_allowed_spread_bps",
    "min_required_depth_score",
    "supported_strategy_families",
    "rejected_strategy_families",
    "symbol_blocker_codes",
    "paper_review_eligible",
    "dashboard_display_truth_only",
    "promotion_eligible",
    "source_evidence_ids",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "blockers",
    "fit_report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.symbol_strategy_regime_fit_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "fit_report_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"enum": ["REPLAY", "PAPER", "SHADOW", "SAFE", "READ_ONLY"]},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "timeframe_scope": {"type": "string", "minLength": 1},
    "regime_scope": {"type": "string", "minLength": 1},
    "regime_family": {"enum": ["TRENDING", "RANGE", "RISK_OFF"]},
    "fit_status": {"enum": ["ELIGIBLE_FOR_PAPER_REVIEW", "FILTERED", "BLOCKED"]},
    "symbol_selection_basis": {"const": "LIQUIDITY_VOLATILITY_SPREAD_DEPTH_REGIME"},
    "liquidity_score": {"type": "number", "minimum": 0},
    "volatility_score": {"type": "number", "minimum": 0},
    "spread_bps": {"type": "number", "minimum": 0},
    "depth_score": {"type": "number", "minimum": 0},
    "depth_notional_krw": {"type": "number", "minimum": 0},
    "average_daily_value_krw": {"type": "number", "minimum": 0},
    "min_required_liquidity_score": {"type": "number", "minimum": 0},
    "max_allowed_spread_bps": {"type": "number", "minimum": 0},
    "min_required_depth_score": {"type": "number", "minimum": 0},
    "supported_strategy_families": {
      "type": "array",
      "items": {"enum": ["VWAP_REVERSION", "TREND_PULLBACK", "BREAKOUT_RETEST"]}
    },
    "rejected_strategy_families": {
      "type": "array",
      "items": {"enum": ["VWAP_REVERSION", "TREND_PULLBACK", "BREAKOUT_RETEST"]}
    },
    "symbol_blocker_codes": {
      "type": "array",
      "items": {"$ref": "common.defs.schema.json#/$defs/no_trade_reason"}
    },
    "paper_review_eligible": {"type": "boolean"},
    "dashboard_display_truth_only": {"const": true},
    "promotion_eligible": {"const": false},
    "source_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "blockers": {
      "type": "array",
      "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}
    },
    "fit_report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
