{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.shadow_observation_report.v1",
  "title": "shadow_observation_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "observation_id",
    "exchange",
    "market_type",
    "source_mode",
    "mode",
    "paper_session_id",
    "shadow_session_id",
    "paper_artifact_path",
    "shadow_artifact_path",
    "paper_operation_gate_id",
    "paper_operation_gate_hash",
    "source_paper_validation_status",
    "source_paper_hash_valid",
    "candidate_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "shadow_artifact_hash",
    "shadow_sample_count",
    "shadow_artifact_age_seconds",
    "max_artifact_age_seconds",
    "entry_reason_count",
    "exit_reason_count",
    "no_trade_reason_count",
    "cost_evidence_count",
    "source_evidence_binding",
    "shadow_observation_status",
    "optimizer_input_role",
    "dashboard_display_truth_only",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "observation_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.shadow_observation_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "observation_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "source_mode": {"const": "PAPER"},
    "mode": {"const": "SHADOW"},
    "paper_session_id": {"type": "string", "minLength": 1},
    "shadow_session_id": {"type": "string", "minLength": 1},
    "paper_artifact_path": {"type": "string", "minLength": 1},
    "shadow_artifact_path": {"type": "string", "minLength": 1},
    "paper_operation_gate_id": {"type": "string", "minLength": 1},
    "paper_operation_gate_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "source_paper_validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
    "source_paper_hash_valid": {"type": "boolean"},
    "candidate_id": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "shadow_artifact_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "shadow_sample_count": {"type": "integer", "minimum": 0},
    "shadow_artifact_age_seconds": {"type": "integer", "minimum": 0},
    "max_artifact_age_seconds": {"type": "integer", "minimum": 1},
    "entry_reason_count": {"type": "integer", "minimum": 0},
    "exit_reason_count": {"type": "integer", "minimum": 0},
    "no_trade_reason_count": {"type": "integer", "minimum": 0},
    "cost_evidence_count": {"type": "integer", "minimum": 0},
    "source_evidence_binding": {
      "type": "object",
      "required": [
        "source_role",
        "exchange",
        "market_type",
        "mode",
        "session_id",
        "artifact_path",
        "artifact_hash",
        "candidate_id",
        "strategy_id",
        "strategy_build_id",
        "parameter_hash",
        "identity_match_status"
      ],
      "additionalProperties": false,
      "properties": {
        "source_role": {"const": "PAPER_OPERATION"},
        "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
        "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
        "mode": {"const": "PAPER"},
        "session_id": {"type": "string", "minLength": 1},
        "artifact_path": {"type": "string", "minLength": 1},
        "artifact_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "candidate_id": {"type": "string", "minLength": 1},
        "strategy_id": {"type": "string", "minLength": 1},
        "strategy_build_id": {"type": "string", "minLength": 1},
        "parameter_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "identity_match_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"}
      }
    },
    "shadow_observation_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "optimizer_input_role": {"const": "SHADOW_OBSERVATION_ONLY"},
    "dashboard_display_truth_only": {"const": true},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "order_adapter_called": {"const": false},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "observation_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "notes": {"type": ["string", "null"]}
  }
}
