{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.residual_operator_evidence_trial_duration_policy_report.v1",
  "type": "object",
  "required": [
    "schema_id",
    "patch_id",
    "generated_at_utc",
    "authority",
    "source_reports",
    "state_last_patch_id_before",
    "state_next_task_before",
    "selected_next_task_class",
    "open_gap_ids",
    "open_gap_count",
    "duration_policy_status",
    "operator_recommended_next_profile_id",
    "operator_recommended_duration_hours",
    "operator_recommended_heartbeat_ticks",
    "operator_recommended_heartbeat_interval_seconds",
    "operator_recommended_minimum_paper_shadow_window_count",
    "operator_recommended_command_shell",
    "operator_recommended_command_text",
    "trial_profile_non_live_only",
    "trial_profile_credential_required",
    "trial_profile_live_order_allowed",
    "trial_profile_mvp5_evidence_eligible",
    "trial_profile_gap_closure_allowed",
    "trial_profile_current_evidence_write_allowed",
    "trial_profile_purpose",
    "formal_mvp5_profile_id",
    "formal_mvp5_duration_hours",
    "formal_mvp5_expected_heartbeat_ticks",
    "formal_mvp5_minimum_paper_shadow_window_count",
    "formal_mvp5_profile_still_required_for_live_readiness",
    "formal_mvp5_profile_replaced_by_trial",
    "operator_submission_manifest_status",
    "intake_review_ready",
    "command_executed_by_this_patch",
    "operator_run_completed_by_this_patch",
    "operator_run_evidence_ready_for_mvp5",
    "mvp5_entry_blocked_until_operator_evidence",
    "current_evidence_write_allowed",
    "gap_closure_allowed_by_this_patch",
    "live_config_mutation_allowed",
    "live_ready_write_allowed",
    "credential_values_read",
    "credential_environment_inspection_performed",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "validation_status",
    "validation_errors",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.residual_operator_evidence_trial_duration_policy_report.v1"},
    "patch_id": {"type": "string", "minLength": 1},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "minLength": 1},
        "agents_sha256": {"type": "string", "minLength": 1}
      }
    },
    "source_reports": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "patch_id", "report_hash"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "enum": [
              "residual_operator_evidence_run_preflight",
              "residual_operator_evidence_intake_audit"
            ]
          },
          "patch_id": {"type": "string", "minLength": 1},
          "report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
        }
      }
    },
    "state_last_patch_id_before": {"type": "string"},
    "state_next_task_before": {"type": "string"},
    "selected_next_task_class": {"type": "string", "minLength": 1},
    "open_gap_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "open_gap_count": {"type": "integer", "minimum": 0},
    "duration_policy_status": {"const": "TRIAL_PROFILE_ALLOWED_FORMAL_MVP5_STILL_BLOCKED"},
    "operator_recommended_next_profile_id": {"const": "UPBIT_PAPER_SAFE_MONITOR_24H_TRIAL"},
    "operator_recommended_duration_hours": {"const": 24},
    "operator_recommended_heartbeat_ticks": {"const": 8640},
    "operator_recommended_heartbeat_interval_seconds": {"const": 10},
    "operator_recommended_minimum_paper_shadow_window_count": {"const": 4},
    "operator_recommended_command_shell": {"const": "powershell"},
    "operator_recommended_command_text": {
      "type": "string",
      "pattern": ".*TRADER1_ROOT_OPERATOR_HEARTBEAT_TICKS='8640'.*UPBIT_PAPER\\.py.*"
    },
    "trial_profile_non_live_only": {"const": true},
    "trial_profile_credential_required": {"const": false},
    "trial_profile_live_order_allowed": {"const": false},
    "trial_profile_mvp5_evidence_eligible": {"const": false},
    "trial_profile_gap_closure_allowed": {"const": false},
    "trial_profile_current_evidence_write_allowed": {"const": false},
    "trial_profile_purpose": {"const": "SHORT_RUNTIME_DEFECT_DISCOVERY_BEFORE_LONG_RUN"},
    "formal_mvp5_profile_id": {
      "enum": [
        "UPBIT_PAPER_ADAPTIVE_EVIDENCE_REVIEW",
        "UPBIT_PAPER_SAFE_MONITOR_48H",
        "UPBIT_PAPER_SAFE_MONITOR_120H"
      ]
    },
    "formal_mvp5_duration_hours": {"type": "integer", "minimum": 0},
    "formal_mvp5_expected_heartbeat_ticks": {"type": "integer", "minimum": 0},
    "formal_mvp5_minimum_paper_shadow_window_count": {"type": "integer", "minimum": 0},
    "formal_mvp5_profile_still_required_for_live_readiness": {"const": true},
    "formal_mvp5_profile_replaced_by_trial": {"const": false},
    "operator_submission_manifest_status": {
      "enum": ["MISSING_OPERATOR_SUBMISSION_MANIFEST", "PRESENT_NOT_VALIDATED"]
    },
    "intake_review_ready": {"const": false},
    "command_executed_by_this_patch": {"const": false},
    "operator_run_completed_by_this_patch": {"const": false},
    "operator_run_evidence_ready_for_mvp5": {"const": false},
    "mvp5_entry_blocked_until_operator_evidence": {"const": true},
    "current_evidence_write_allowed": {"const": false},
    "gap_closure_allowed_by_this_patch": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "live_ready_write_allowed": {"const": false},
    "credential_values_read": {"const": false},
    "credential_environment_inspection_performed": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "validation_status": {"const": "PASS"},
    "validation_errors": {
      "type": "array",
      "maxItems": 0,
      "items": {"type": "string"}
    },
    "report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
