{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_shadow_harness_binding_report.v1",
  "title": "TRADER_1 Paper Shadow Harness Binding Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "binding_report_id",
    "exchange",
    "market_type",
    "paper_mode",
    "shadow_mode",
    "session_id",
    "harness_id",
    "harness_report_hash",
    "harness_hash_verified",
    "harness_validation_status",
    "evidence_report_id",
    "evidence_report_hash",
    "evidence_hash_verified",
    "evidence_validation_status",
    "binding_status",
    "evidence_graph_version",
    "critical_blockers",
    "warnings",
    "informational",
    "critical_blocker_count",
    "warning_count",
    "informational_count",
    "primary_blocker_code",
    "top_level_blocker_codes",
    "paper_cycle_count",
    "shadow_opportunity_count",
    "paper_sample_count",
    "shadow_sample_count",
    "entry_reason_count",
    "no_trade_reason_count",
    "cost_assumption_count",
    "market_regime_tag_count",
    "latency_freshness_status",
    "source_binding_count",
    "source_scope_status",
    "blocks_paper_current_truth_write",
    "blocks_non_live_runtime_collection",
    "blocks_live_ready",
    "blocks_optimizer_or_convergence",
    "optimizer_status",
    "operator_action_required",
    "codex_non_live_action",
    "local_paper_shadow_runtime_action",
    "external_live_evidence_action",
    "next_action",
    "dashboard_display_truth_only",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "credential_access_attempted",
    "exchange_account_call_attempted",
    "live_order_api_attempted",
    "order_adapter_called",
    "live_ready_snapshot_written",
    "binding_report_hash"
  ],
  "properties": {
    "schema_id": {"const": "trader1.paper_shadow_harness_binding_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "binding_report_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "paper_mode": {"const": "PAPER"},
    "shadow_mode": {"const": "SHADOW"},
    "session_id": {"type": "string", "minLength": 1},
    "harness_id": {"type": "string", "minLength": 1},
    "harness_report_hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "harness_hash_verified": {"type": "boolean"},
    "harness_validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
    "evidence_report_id": {"type": ["string", "null"], "minLength": 1},
    "evidence_report_hash": {"type": ["string", "null"], "pattern": "^[A-F0-9]{64}$"},
    "evidence_hash_verified": {"type": ["boolean", "null"]},
    "evidence_validation_status": {
      "enum": ["NOT_LOADED", "PASS", "FAIL", "WARN", "BLOCKED", "UNTESTED", "STALE", "SKIPPED_NOT_APPLICABLE", "TIMEOUT"]
    },
    "binding_status": {
      "enum": [
        "HARNESS_ONLY_WAITING_EVIDENCE",
        "EVIDENCE_PRESENT_WAITING_COLLECTION",
        "BOUND_TO_SCORECARD_INPUT",
        "STALE_DISPLAY_ONLY",
        "BLOCKED_SOURCE_INVALID"
      ]
    },
    "evidence_graph_version": {"const": "paper_shadow_harness_binding_evidence_graph.v1"},
    "critical_blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "warnings": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "informational": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "critical_blocker_count": {"type": "integer", "minimum": 0},
    "warning_count": {"type": "integer", "minimum": 0},
    "informational_count": {"type": "integer", "minimum": 0},
    "primary_blocker_code": {"type": ["string", "null"]},
    "top_level_blocker_codes": {
      "type": "array",
      "maxItems": 5,
      "items": {"type": "string", "minLength": 1}
    },
    "paper_cycle_count": {"type": "integer", "minimum": 0},
    "shadow_opportunity_count": {"type": "integer", "minimum": 0},
    "paper_sample_count": {"type": "integer", "minimum": 0},
    "shadow_sample_count": {"type": "integer", "minimum": 0},
    "entry_reason_count": {"type": "integer", "minimum": 0},
    "no_trade_reason_count": {"type": "integer", "minimum": 0},
    "cost_assumption_count": {"type": "integer", "minimum": 0},
    "market_regime_tag_count": {"type": "integer", "minimum": 0},
    "latency_freshness_status": {"enum": ["FRESH", "DELAYED", "STALE_DISPLAY_ONLY", "INVALID"]},
    "source_binding_count": {"type": "integer", "minimum": 0},
    "source_scope_status": {"enum": ["PASS", "BLOCKED"]},
    "blocks_paper_current_truth_write": {"type": "boolean"},
    "blocks_non_live_runtime_collection": {"type": "boolean"},
    "blocks_live_ready": {"const": true},
    "blocks_optimizer_or_convergence": {"const": true},
    "optimizer_status": {
      "enum": ["WAITING_FOR_RUNTIME_EVIDENCE", "WAITING_FOR_LONG_RUN_EVIDENCE", "BLOCKED_SOURCE_INVALID"]
    },
    "operator_action_required": {
      "enum": ["NONE_FOR_ROUTINE_REFRESH", "LOCAL_PAPER_SHADOW_RUNTIME_COLLECTION", "STOP_AND_INSPECT_SOURCE"]
    },
    "codex_non_live_action": {"type": "string", "minLength": 1},
    "local_paper_shadow_runtime_action": {"type": "string", "minLength": 1},
    "external_live_evidence_action": {"type": "string", "minLength": 1},
    "next_action": {"type": "string", "minLength": 1},
    "dashboard_display_truth_only": {"const": true},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "credential_access_attempted": {"const": false},
    "exchange_account_call_attempted": {"const": false},
    "live_order_api_attempted": {"const": false},
    "order_adapter_called": {"const": false},
    "live_ready_snapshot_written": {"const": false},
    "binding_report_hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"}
  }
}
