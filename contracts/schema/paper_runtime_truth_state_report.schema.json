{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_runtime_truth_state_report.v1",
  "title": "PAPER Runtime Truth State Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "runtime_truth_status",
    "dashboard_truth_status",
    "state_summary",
    "next_action",
    "monitor_alive",
    "runner_status_loaded",
    "runner_status_fresh",
    "runner_status",
    "runner_running",
    "runner_completed_cycle_count",
    "paper_loop_advancing",
    "market_data_advancing",
    "ledger_advancing",
    "current_evidence_refreshing",
    "validated_paper_cycle_count",
    "validated_paper_ledger_event_count",
    "source_heartbeat_hash",
    "source_runner_status_hash",
    "source_persistent_loop_hash",
    "source_market_continuity_history_hash",
    "source_paper_ledger_rollup_hash",
    "source_current_truth_refresh_hash",
    "primary_blocker_code",
    "blockers",
    "evidence_role",
    "paper_only",
    "display_only",
    "dashboard_truth_only",
    "current_trading_review_allowed",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "authorization_header_present",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_ready_write_allowed",
    "live_config_mutation_allowed",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "scale_up_allowed",
    "truth_state_hash"
  ],
  "$defs": {
    "hash_or_null": {
      "type": ["string", "null"],
      "minLength": 64,
      "maxLength": 64
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.paper_runtime_truth_state_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "runtime_truth_status": {
      "enum": [
        "PAPER_RUNTIME_ACTIVE",
        "MONITOR_ALIVE_ENGINE_NOT_PROVEN",
        "PAPER_RUNTIME_BLOCKED",
        "PAPER_RUNTIME_NOT_LOADED",
        "INVALID"
      ]
    },
    "dashboard_truth_status": {
      "enum": [
        "FRESH_CURRENT_TRUTH",
        "STALE_DISPLAY_TRUTH",
        "MONITOR_ONLY",
        "INVALID"
      ]
    },
    "state_summary": {"type": "string", "minLength": 1},
    "next_action": {"type": "string", "minLength": 1},
    "monitor_alive": {"type": "boolean"},
    "runner_status_loaded": {"type": "boolean"},
    "runner_status_fresh": {"type": "boolean"},
    "runner_status": {
      "enum": [
        "RUNNING",
        "STOPPED",
        "BLOCKED",
        "LOCKED",
        "NOT_LOADED"
      ]
    },
    "runner_running": {"type": "boolean"},
    "runner_completed_cycle_count": {"type": "integer", "minimum": 0},
    "paper_loop_advancing": {"type": "boolean"},
    "market_data_advancing": {"type": "boolean"},
    "ledger_advancing": {"type": "boolean"},
    "current_evidence_refreshing": {"type": "boolean"},
    "validated_paper_cycle_count": {"type": "integer", "minimum": 0},
    "validated_paper_ledger_event_count": {"type": "integer", "minimum": 0},
    "source_heartbeat_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_runner_status_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_persistent_loop_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_market_continuity_history_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_paper_ledger_rollup_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_current_truth_refresh_hash": {"$ref": "#/$defs/hash_or_null"},
    "primary_blocker_code": {"type": "string", "minLength": 1},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "evidence_role": {"const": "PAPER_RUNTIME_TRUTH_STATE_ONLY_NOT_LIVE_READY"},
    "paper_only": {"const": true},
    "display_only": {"const": true},
    "dashboard_truth_only": {"const": true},
    "current_trading_review_allowed": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "authorization_header_present": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_ready_write_allowed": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "can_submit_order": {"const": false},
    "scale_up_allowed": {"const": false},
    "truth_state_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
