{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.strategy_mutation_compiler_report.v1",
  "title": "strategy_mutation_compiler_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "compile_status",
    "status",
    "primary_blocker_code",
    "blockers",
    "mutation_budget_state",
    "mutated_paper_candidate_spec",
    "ranking_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.strategy_mutation_compiler_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": ["string", "null"]},
    "strategy_id": {"type": ["string", "null"]},
    "strategy_build_id": {"type": ["string", "null"]},
    "parent_parameter_hash": {"type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{64}$"},
    "source_evidence_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "mutation_budget_state": {"$ref": "#/$defs/mutation_budget_state"},
    "compile_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "mutation_reason_code": {"type": ["string", "null"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "mutated_paper_candidate_spec": {
      "anyOf": [
        {"$ref": "#/$defs/mutated_paper_candidate_spec"},
        {"type": "null"}
      ]
    },
    "next_action": {"type": "string", "minLength": 1},
    "ranking_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "report_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  },
  "$defs": {
    "mutation_budget_state": {
      "type": "object",
      "required": [
        "schema_id",
        "budget_date_utc",
        "session_id",
        "strategy_id",
        "daily_exploration_budget",
        "daily_exploration_used",
        "strategy_family_mutation_budget",
        "strategy_family_mutation_used",
        "max_concurrent_experimental_candidates",
        "concurrent_experimental_candidate_count",
        "replay_cost_budget",
        "replay_cost_used",
        "candidate_retirement_budget",
        "candidate_retirement_used",
        "exploration_budget_id",
        "budget_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_id": {"const": "trader1.mutation_budget_state.v1"},
        "budget_date_utc": {"type": "string", "minLength": 1},
        "session_id": {"type": "string", "minLength": 1},
        "strategy_id": {"type": "string", "minLength": 1},
        "daily_exploration_budget": {"type": "integer", "minimum": 1},
        "daily_exploration_used": {"type": "integer", "minimum": 0},
        "strategy_family_mutation_budget": {"type": "integer", "minimum": 1},
        "strategy_family_mutation_used": {"type": "integer", "minimum": 0},
        "max_concurrent_experimental_candidates": {"type": "integer", "minimum": 1},
        "concurrent_experimental_candidate_count": {"type": "integer", "minimum": 0},
        "replay_cost_budget": {"type": "integer", "minimum": 1},
        "replay_cost_used": {"type": "integer", "minimum": 0},
        "candidate_retirement_budget": {"type": "integer", "minimum": 1},
        "candidate_retirement_used": {"type": "integer", "minimum": 0},
        "exploration_budget_id": {"type": "string", "minLength": 1},
        "budget_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "mutated_paper_candidate_spec": {
      "type": "object",
      "required": [
        "schema_id",
        "generated_at_utc",
        "project_id",
        "spec_id",
        "mutation_id",
        "mutation_status",
        "candidate_id",
        "parent_candidate_id",
        "symbol",
        "strategy_id",
        "strategy_build_id",
        "parent_parameter_hash",
        "parameter_hash",
        "exchange",
        "market_type",
        "mode",
        "allowed_output_modes",
        "mutation_reason_code",
        "bounded_parameter_delta",
        "edge_delta_bps",
        "signal_delta",
        "exploration_budget_id",
        "parent_candidate_lineage",
        "source_evidence_ids",
        "ranking_eligible",
        "replay_input_allowed",
        "paper_input_allowed",
        "live_config_mutation_allowed",
        "writes_live_ready_snapshot",
        "credential_load_attempted",
        "private_endpoint_called",
        "order_endpoint_called",
        "order_adapter_called",
        "live_key_loaded",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed",
        "spec_hash"
      ],
      "additionalProperties": true,
      "properties": {
        "schema_id": {"const": "trader1.mutated_paper_candidate_spec.v1"},
        "generated_at_utc": {"type": "string", "minLength": 1},
        "project_id": {"const": "TRADER_1"},
        "spec_id": {"type": "string", "minLength": 1},
        "mutation_id": {"type": "string", "minLength": 1},
        "mutation_status": {"const": "PASS"},
        "candidate_id": {"type": "string", "minLength": 1},
        "parent_candidate_id": {"type": "string", "minLength": 1},
        "symbol": {"type": "string", "minLength": 1},
        "strategy_id": {"type": "string", "minLength": 1},
        "strategy_build_id": {"type": "string", "minLength": 1},
        "parent_parameter_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "parameter_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "exchange": {"const": "UPBIT"},
        "market_type": {"const": "KRW_SPOT"},
        "mode": {"const": "PAPER"},
        "allowed_output_modes": {
          "type": "array",
          "items": {"enum": ["REPLAY", "PAPER"]}
        },
        "mutation_reason_code": {"type": "string", "minLength": 1},
        "bounded_parameter_delta": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["parameter_id", "baseline_value", "mutated_value", "delta_pct", "rationale"],
            "additionalProperties": false,
            "properties": {
              "parameter_id": {"type": "string", "minLength": 1},
              "baseline_value": {"type": "number"},
              "mutated_value": {"type": "number"},
              "delta_pct": {"type": "number", "minimum": -20, "maximum": 20},
              "rationale": {"type": "string", "minLength": 1}
            }
          }
        },
        "edge_delta_bps": {"type": "number", "minimum": -25, "maximum": 25},
        "signal_delta": {"type": "number", "minimum": -0.15, "maximum": 0.15},
        "exploration_budget_id": {"type": "string", "minLength": 1},
        "parent_candidate_lineage": {"type": "object"},
        "source_evidence_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "ranking_eligible": {"const": false},
        "replay_input_allowed": {"const": true},
        "paper_input_allowed": {"const": true},
        "live_config_mutation_allowed": {"const": false},
        "writes_live_ready_snapshot": {"const": false},
        "credential_load_attempted": {"const": false},
        "private_endpoint_called": {"const": false},
        "order_endpoint_called": {"const": false},
        "order_adapter_called": {"const": false},
        "live_key_loaded": {"const": false},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false},
        "spec_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    }
  }
}
