{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_public_rest_continuity_history.v1",
  "title": "upbit_public_rest_continuity_history",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "history_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "history_window_label",
    "continuity_attempts",
    "attempt_hashes",
    "total_attempt_count",
    "pass_attempt_count",
    "blocked_attempt_count",
    "duplicate_latest_event_block_count",
    "non_advancing_block_count",
    "data_unavailable_block_count",
    "min_required_pass_attempts",
    "latest_attempt_status",
    "latest_primary_blocker_code",
    "continuity_health_status",
    "primary_blocker_code",
    "blockers",
    "evidence_role",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "authorization_header_present",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "history_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_public_rest_continuity_history.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "history_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "history_window_label": {"type": "string", "minLength": 1},
    "continuity_attempts": {"type": "array", "items": {"type": "object"}},
    "attempt_hashes": {"type": "array", "items": {"type": "string", "minLength": 64, "maxLength": 64}},
    "total_attempt_count": {"type": "integer", "minimum": 0, "maximum": 200},
    "pass_attempt_count": {"type": "integer", "minimum": 0, "maximum": 200},
    "blocked_attempt_count": {"type": "integer", "minimum": 0, "maximum": 200},
    "duplicate_latest_event_block_count": {"type": "integer", "minimum": 0, "maximum": 200},
    "non_advancing_block_count": {"type": "integer", "minimum": 0, "maximum": 200},
    "data_unavailable_block_count": {"type": "integer", "minimum": 0, "maximum": 200},
    "min_required_pass_attempts": {"type": "integer", "minimum": 1, "maximum": 200},
    "latest_attempt_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "latest_primary_blocker_code": {"type": ["string", "null"]},
    "continuity_health_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "evidence_role": {"const": "PAPER_DATA_CONTINUITY_HISTORY_ONLY_NOT_LIVE_READY"},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "authorization_header_present": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "history_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
