{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.parameter_narrowing_report.v1",
  "title": "parameter_narrowing_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "narrowing_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "candidate_id",
    "strategy_id",
    "previous_parameter_hash",
    "proposed_parameter_hash",
    "timeframe_scope",
    "regime_scope",
    "narrowing_scope",
    "narrowing_status",
    "recommendation_scope",
    "parameter_write_scope",
    "objective_basis",
    "source_modes",
    "source_evidence_ids",
    "source_evidence_identity_bindings",
    "dependency_summary_status",
    "candidate_scorecard_validator_status",
    "optimizer_run_report_validator_status",
    "optimizer_recommendation_validator_status",
    "exploration_exploitation_policy_validator_status",
    "overfit_diagnostic_validator_status",
    "execution_feedback_loop_validator_status",
    "live_final_guard_validator_status",
    "required_dependency_count",
    "dependency_pass_count",
    "min_required_sample_count",
    "paper_sample_count",
    "shadow_sample_count",
    "parameter_count_before",
    "parameter_count_after",
    "max_narrowing_pct",
    "narrowing_pct",
    "parameter_changes",
    "narrowing_allowed_for_paper_ranking",
    "blocks_promotion",
    "blocks_live_order",
    "live_readiness_status",
    "operator_warning",
    "status",
    "blockers",
    "dashboard_display_truth_only",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "live_permission_created",
    "live_config_mutation_allowed",
    "writes_live_ready_snapshot",
    "active_snapshot_mutation_allowed",
    "active_config_mutation_allowed",
    "optimizer_winner_live_config_allowed",
    "paper_winner_live_config_allowed",
    "order_submission_allowed",
    "exchange_account_call_allowed",
    "scale_up_recommendation_allowed"
  ],
  "additionalProperties": false,
  "$defs": {
    "parameter_change": {
      "type": "object",
      "required": [
        "parameter_name",
        "previous_min",
        "previous_max",
        "proposed_min",
        "proposed_max",
        "direction",
        "reason_code"
      ],
      "additionalProperties": false,
      "properties": {
        "parameter_name": {
          "type": "string",
          "minLength": 1
        },
        "previous_min": {
          "type": "number"
        },
        "previous_max": {
          "type": "number"
        },
        "proposed_min": {
          "type": "number"
        },
        "proposed_max": {
          "type": "number"
        },
        "direction": {
          "enum": [
            "NARROW",
            "UNCHANGED",
            "BLOCKED"
          ]
        },
        "reason_code": {
          "enum": [
            "NET_EV_AFTER_COST_STABLE",
            "OOS_ROBUSTNESS_PASS",
            "EXECUTION_FEEDBACK_STABLE",
            "DEPENDENCY_BLOCKED",
            "SAMPLE_INSUFFICIENT",
            "OVER_NARROWING_BLOCKED"
          ]
        }
      }
    },
    "source_evidence_identity_binding": {
      "type": "object",
      "required": [
        "source_evidence_id",
        "source_role",
        "exchange",
        "market_type",
        "source_modes",
        "session_id",
        "candidate_id",
        "strategy_id",
        "previous_parameter_hash",
        "proposed_parameter_hash",
        "timeframe_scope",
        "regime_scope",
        "identity_match_status"
      ],
      "additionalProperties": false,
      "properties": {
        "source_evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "source_role": {
          "enum": [
            "PAPER_SHADOW_EVIDENCE",
            "CANDIDATE_SCORECARD",
            "OPTIMIZER_RUN",
            "OPTIMIZER_RECOMMENDATION",
            "EXPLORATION_POLICY"
          ]
        },
        "exchange": {
          "$ref": "common.defs.schema.json#/$defs/exchange"
        },
        "market_type": {
          "$ref": "common.defs.schema.json#/$defs/market_type"
        },
        "source_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "REPLAY",
              "PAPER",
              "SHADOW",
              "READ_ONLY"
            ]
          }
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "strategy_id": {
          "type": "string",
          "minLength": 1
        },
        "previous_parameter_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "proposed_parameter_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "timeframe_scope": {
          "type": "string",
          "minLength": 1
        },
        "regime_scope": {
          "type": "string",
          "minLength": 1
        },
        "identity_match_status": {
          "enum": [
            "PASS",
            "FAIL",
            "BLOCKED",
            "UNTESTED",
            "STALE",
            "TIMEOUT"
          ]
        }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "trader1.parameter_narrowing_report.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "authority": {
      "type": "object",
      "required": [
        "trader1_sha256",
        "agents_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "agents_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "narrowing_id": {
      "type": "string",
      "minLength": 1
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "$ref": "common.defs.schema.json#/$defs/mode"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "previous_parameter_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "proposed_parameter_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timeframe_scope": {
      "type": "string",
      "minLength": 1
    },
    "regime_scope": {
      "type": "string",
      "minLength": 1
    },
    "narrowing_scope": {
      "enum": [
        "ANALYSIS_ONLY",
        "PAPER_PARAMETER_REVIEW_ONLY",
        "RISK_REDUCTION_ONLY",
        "BLOCKED"
      ]
    },
    "narrowing_status": {
      "enum": [
        "ACTIVE_ANALYSIS_ONLY",
        "PAPER_PARAMETER_REVIEW_ELIGIBLE",
        "BLOCKED",
        "STALE_SAFE_MODE"
      ]
    },
    "recommendation_scope": {
      "enum": [
        "ANALYSIS_ONLY",
        "PAPER_PARAMETER_REVIEW_ONLY",
        "RISK_REDUCTION_ONLY",
        "BLOCKED"
      ]
    },
    "parameter_write_scope": {
      "enum": [
        "PROPOSAL_ONLY",
        "BLOCKED"
      ]
    },
    "objective_basis": {
      "enum": [
        "NET_EV_AFTER_COST",
        "BLOCKED_NO_VALID_OBJECTIVE"
      ]
    },
    "source_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "REPLAY",
          "PAPER",
          "SHADOW",
          "READ_ONLY"
        ]
      }
    },
    "source_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_evidence_identity_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_evidence_identity_binding"
      }
    },
    "dependency_summary_status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "FAIL",
        "UNTESTED",
        "STALE",
        "TIMEOUT"
      ]
    },
    "candidate_scorecard_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "optimizer_run_report_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "optimizer_recommendation_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "exploration_exploitation_policy_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "overfit_diagnostic_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "execution_feedback_loop_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "live_final_guard_validator_status": {
      "$ref": "common.defs.schema.json#/$defs/validator_status"
    },
    "required_dependency_count": {
      "const": 7
    },
    "dependency_pass_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 7
    },
    "min_required_sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "paper_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "shadow_sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "parameter_count_before": {
      "type": "integer",
      "minimum": 1
    },
    "parameter_count_after": {
      "type": "integer",
      "minimum": 1
    },
    "max_narrowing_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "narrowing_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "parameter_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/parameter_change"
      }
    },
    "narrowing_allowed_for_paper_ranking": {
      "type": "boolean"
    },
    "blocks_promotion": {
      "type": "boolean"
    },
    "blocks_live_order": {
      "const": true
    },
    "live_readiness_status": {
      "const": "NOT_LIVE_READY"
    },
    "operator_warning": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "SAFE_MODE",
        "FAIL"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "common.defs.schema.json#/$defs/blocker_object"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "dashboard_display_truth_only": {
      "const": true
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "live_permission_created": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "writes_live_ready_snapshot": {
      "const": false
    },
    "active_snapshot_mutation_allowed": {
      "const": false
    },
    "active_config_mutation_allowed": {
      "const": false
    },
    "optimizer_winner_live_config_allowed": {
      "const": false
    },
    "paper_winner_live_config_allowed": {
      "const": false
    },
    "order_submission_allowed": {
      "const": false
    },
    "exchange_account_call_allowed": {
      "const": false
    },
    "scale_up_recommendation_allowed": {
      "const": false
    }
  }
}
