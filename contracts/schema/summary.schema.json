{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.summary.v1",
  "title": "summary",
  "type": "object",
  "required": [
    "schema_id",
    "project",
    "generated_at_utc",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "engine",
    "startup",
    "operator_status",
    "resources",
    "portfolio",
    "orders",
    "positions",
    "strategies",
    "action_queue",
    "recent_errors",
    "recent_no_trade_context",
    "live_ready",
    "final_action",
    "blocking_reason",
    "next_action"
  ],
  "additionalProperties": false,
  "$defs": {
    "decimal_string": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
    },
    "freshness_status": {
      "enum": [
        "PASS",
        "WARN",
        "FAIL",
        "STALE",
        "UNTESTED"
      ]
    },
    "status_source_object": {
      "type": "object",
      "required": [
        "status",
        "source",
        "freshness_status"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        },
        "source": {
          "enum": [
            "LEDGER",
            "RECONCILIATION",
            "SUMMARY_BUILDER",
            "READINESS_SURFACE",
            "HEARTBEAT",
            "STARTUP_PROBE",
            "OPERATOR",
            "SYSTEM"
          ]
        },
        "freshness_status": {
          "$ref": "#/$defs/freshness_status"
        },
        "evidence_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "portfolio_object": {
      "type": "object",
      "required": [
        "source",
        "freshness_status",
        "equity",
        "cash_available",
        "locked_balance"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": [
            "LEDGER",
            "RECONCILIATION",
            "SUMMARY_BUILDER"
          ]
        },
        "freshness_status": {
          "$ref": "#/$defs/freshness_status"
        },
        "source_snapshot_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 64,
          "maxLength": 64
        },
        "source_runtime_cycle_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_paper_ledger_head_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 64,
          "maxLength": 64
        },
        "source_snapshot_status": {
          "enum": [
            "PASS",
            "BLOCKED",
            "UNTESTED"
          ]
        },
        "source_snapshot_generated_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_snapshot_age_seconds": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "source_snapshot_stale_after_seconds": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 1
        },
        "source_snapshot_freshness_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_balance_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "SIMULATED_PAPER_LEDGER",
            null
          ]
        },
        "configured_paper_starting_cash": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "configured_paper_starting_cash_currency": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "configured_paper_starting_cash_source": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "MVP_PAPER_DEFAULT_NOT_LIVE_ACCOUNT",
            null
          ]
        },
        "configured_paper_starting_cash_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "CONFIGURED_NOT_VERIFIED",
            "VERIFIED_SOURCE_PRESENT",
            "UNSUPPORTED_SCOPE",
            null
          ]
        },
        "configured_paper_starting_cash_message": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "equity": {
          "type": [
            "number",
            "null"
          ]
        },
        "cash_available": {
          "type": [
            "number",
            "null"
          ]
        },
        "locked_balance": {
          "type": [
            "number",
            "null"
          ]
        },
        "position_market_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "open_position_count": {
          "type": "integer",
          "minimum": 0
        },
        "realized_pnl": {
          "type": [
            "number",
            "null"
          ]
        },
        "unrealized_pnl": {
          "type": [
            "number",
            "null"
          ]
        },
        "total_pnl": {
          "type": [
            "number",
            "null"
          ]
        },
        "mdd": {
          "type": [
            "number",
            "null"
          ]
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "orders_object": {
      "type": "object",
      "required": [
        "source",
        "freshness_status",
        "open_order_count",
        "pending_confirm_count"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": [
            "LEDGER",
            "RECONCILIATION",
            "SUMMARY_BUILDER"
          ]
        },
        "freshness_status": {
          "$ref": "#/$defs/freshness_status"
        },
        "open_order_count": {
          "type": "integer",
          "minimum": 0
        },
        "pending_confirm_count": {
          "type": "integer",
          "minimum": 0
        },
        "reconciliation_age_sec": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "position": {
      "type": "object",
      "required": [
        "symbol",
        "side",
        "quantity",
        "average_entry_price",
        "mark_price",
        "cost_basis",
        "market_value",
        "unrealized_pnl",
        "source",
        "paper_only"
      ],
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "const": "LONG"
        },
        "quantity": {
          "$ref": "#/$defs/decimal_string"
        },
        "average_entry_price": {
          "$ref": "#/$defs/decimal_string"
        },
        "mark_price": {
          "$ref": "#/$defs/decimal_string"
        },
        "cost_basis": {
          "$ref": "#/$defs/decimal_string"
        },
        "market_value": {
          "$ref": "#/$defs/decimal_string"
        },
        "unrealized_pnl": {
          "$ref": "#/$defs/decimal_string"
        },
        "source": {
          "enum": [
            "PAPER_LEDGER_SCAFFOLD",
            "PAPER_LEDGER_ROLLUP"
          ]
        },
        "paper_only": {
          "const": true
        }
      }
    },
    "live_ready_object": {
      "type": "object",
      "required": [
        "source",
        "live_order_ready",
        "live_order_allowed",
        "primary_blocker_code",
        "blocks_live_order"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": [
            "READINESS_SURFACE",
            "SUMMARY_BUILDER"
          ]
        },
        "live_order_ready": {
          "type": "boolean"
        },
        "live_order_allowed": {
          "type": "boolean"
        },
        "primary_blocker_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "primary_blocker_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "blocks_live_order": {
          "type": "boolean"
        },
        "evidence_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "applied_snapshot_object": {
      "type": "object",
      "required": [
        "snapshot_id",
        "source",
        "scope_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "enum": [
            "LIVE_READY_SNAPSHOT",
            "NONE"
          ]
        },
        "scope_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "freshness_status": {
          "$ref": "#/$defs/freshness_status"
        }
      }
    },
    "market_context_object": {
      "type": "object",
      "required": [
        "source",
        "freshness_status"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": [
            "SUMMARY_BUILDER",
            "MARKET_DATA",
            "READINESS_SURFACE"
          ]
        },
        "freshness_status": {
          "$ref": "#/$defs/freshness_status"
        },
        "regime": {
          "type": [
            "string",
            "null"
          ]
        },
        "liquidity_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "volatility_status": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "quantitative_policy_summary_object": {
      "type": "object",
      "required": [
        "source",
        "freshness_status",
        "policy_status",
        "decision_surface",
        "source_policy_report_id",
        "source_policy_report_hash",
        "dashboard_reason_code",
        "dashboard_operator_message",
        "minimum_trade_count",
        "high_return_candidate_trade_count",
        "signal_grade",
        "signal_score",
        "net_expected_edge",
        "total_cost",
        "primary_blocker_code",
        "next_action",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": [
            "SUMMARY_BUILDER",
            "QUANTITATIVE_POLICY_REPORT"
          ]
        },
        "freshness_status": {
          "$ref": "#/$defs/freshness_status"
        },
        "policy_status": {
          "enum": [
            "IMPLEMENTED_LIVE_BLOCKED",
            "BLOCKED",
            "UNTESTED"
          ]
        },
        "decision_surface": {
          "const": "DASHBOARD_ONLY"
        },
        "source_policy_report_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_policy_report_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 64,
          "maxLength": 64
        },
        "dashboard_reason_code": {
          "$ref": "common.defs.schema.json#/$defs/no_trade_reason"
        },
        "dashboard_operator_message": {
          "type": "string",
          "minLength": 1
        },
        "minimum_trade_count": {
          "const": 100
        },
        "high_return_candidate_trade_count": {
          "const": 300
        },
        "signal_grade": {
          "type": [
            "string",
            "null"
          ]
        },
        "signal_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "net_expected_edge": {
          "type": [
            "number",
            "null"
          ]
        },
        "total_cost": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "primary_blocker_code": {
          "$ref": "common.defs.schema.json#/$defs/no_trade_reason"
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "trader1.summary.v1"
    },
    "project": {
      "const": "TRADER_1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "$ref": "common.defs.schema.json#/$defs/mode"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "engine": {
      "$ref": "#/$defs/status_source_object"
    },
    "startup": {
      "$ref": "#/$defs/status_source_object"
    },
    "operator_status": {
      "$ref": "#/$defs/status_source_object"
    },
    "connectivity": {
      "$ref": "#/$defs/status_source_object"
    },
    "caches": {
      "type": "object"
    },
    "queues": {
      "type": "object"
    },
    "rate_limits": {
      "type": "object"
    },
    "resources": {
      "$ref": "#/$defs/status_source_object"
    },
    "portfolio": {
      "$ref": "#/$defs/portfolio_object"
    },
    "orders": {
      "$ref": "#/$defs/orders_object"
    },
    "watch_universe": {
      "type": "array"
    },
    "entry_candidates": {
      "type": "array"
    },
    "positions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/position"
      }
    },
    "strategies": {
      "type": "array"
    },
    "market_context": {
      "$ref": "#/$defs/market_context_object"
    },
    "action_queue": {
      "type": "array"
    },
    "recent_errors": {
      "type": "array"
    },
    "recent_no_trade_context": {
      "type": "array"
    },
    "recent_entry_context": {
      "type": "array"
    },
    "fee_snapshot": {
      "type": [
        "object",
        "null"
      ]
    },
    "quantitative_policy_summary": {
      "$ref": "#/$defs/quantitative_policy_summary_object"
    },
    "live_ready": {
      "$ref": "#/$defs/live_ready_object"
    },
    "applied_snapshot": {
      "oneOf": [
        {
          "$ref": "#/$defs/applied_snapshot_object"
        },
        {
          "type": "null"
        }
      ]
    },
    "final_action": {
      "$ref": "common.defs.schema.json#/$defs/final_decision"
    },
    "blocking_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
