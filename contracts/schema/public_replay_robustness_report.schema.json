{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.public_replay_robustness_report.v1",
  "title": "public_replay_robustness_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "replay_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "candidate_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "value_source",
    "public_market_data_source",
    "public_market_data_hash",
    "window_size",
    "sample_count",
    "min_required_sample_count",
    "max_replay_windows",
    "sample_rows",
    "replay_closed_trade_sample_count",
    "replay_closed_trade_status",
    "min_required_closed_trade_sample_count",
    "replay_closed_trade_deficit",
    "replay_closed_trade_maturity_status",
    "replay_closed_trade_maturity_blocker_code",
    "replay_status",
    "primary_blocker_code",
    "blockers",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.public_replay_robustness_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "replay_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "REPLAY"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "mutation_status": {
      "enum": [
        "NOT_MUTATED",
        "APPLIED_TO_PAPER_CANDIDATE"
      ]
    },
    "mutation_id": {"type": ["string", "null"]},
    "mutation_reason_code": {"type": ["string", "null"]},
    "mutated_paper_candidate_spec_id": {"type": ["string", "null"]},
    "mutation_spec_hash": {"type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{64}$"},
    "parent_parameter_hash": {"type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{64}$"},
    "value_source": {"const": "PUBLIC_REST_REPLAY_DECISION_ADJUSTED_NET_EV_AFTER_COST_BPS"},
    "public_market_data_source": {
      "enum": [
        "STATIC_FIXTURE",
        "PUBLIC_REST_READ_ONLY",
        "PUBLIC_REST_READ_ONLY_FETCH_FAILED"
      ]
    },
    "public_market_data_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "public_market_data_fetch_status": {
      "enum": [
        "PASS",
        "FAILED"
      ]
    },
    "public_market_data_error_type": {"type": ["string", "null"]},
    "public_market_data_error_message": {"type": ["string", "null"]},
    "window_size": {"type": "integer", "minimum": 5},
    "sample_count": {"type": "integer", "minimum": 0},
    "min_required_sample_count": {"type": "integer", "minimum": 1},
    "max_replay_windows": {"type": "integer", "minimum": 1},
    "sample_rows": {
      "type": "array",
      "items": {"$ref": "#/$defs/public_replay_sample_row"}
    },
    "replay_closed_trade_sample_count": {"type": "integer", "minimum": 0},
    "replay_closed_trade_status": {"enum": ["PASS", "FAIL", "UNTESTED", "BLOCKED"]},
    "min_required_closed_trade_sample_count": {"type": "integer", "minimum": 1},
    "replay_closed_trade_deficit": {"type": "integer", "minimum": 0},
    "replay_closed_trade_maturity_status": {"enum": ["PASS", "UNTESTED", "BLOCKED"]},
    "replay_closed_trade_maturity_blocker_code": {
      "type": ["string", "null"],
      "enum": [
        "REPLAY_CLOSED_TRADES_BELOW_MIN",
        "REPLAY_CLOSED_TRADES_MISSING",
        null
      ]
    },
    "replay_strategy_exit_policy_sample_count": {"type": "integer", "minimum": 0},
    "replay_strategy_exit_policy_match_count": {"type": "integer", "minimum": 0},
    "replay_strategy_exit_policy_mismatch_count": {"type": "integer", "minimum": 0},
    "replay_strategy_exit_policy_status": {"enum": ["PASS", "FAIL", "UNTESTED", "BLOCKED"]},
    "replay_strategy_exit_reason_counts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason_code", "count"],
        "additionalProperties": false,
        "properties": {
          "reason_code": {"type": "string", "minLength": 1},
          "count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "replay_profit_factor": {"type": "number", "minimum": 0},
    "replay_profit_factor_status": {"enum": ["PASS", "FAIL", "UNTESTED", "BLOCKED"]},
    "replay_max_drawdown_bps": {"type": "number", "minimum": 0},
    "replay_realized_vs_expected_edge_bps": {"type": "number"},
    "replay_realized_vs_expected_edge_status": {"enum": ["PASS", "FAIL", "UNTESTED", "BLOCKED"]},
    "replay_fill_quality_score": {"type": "number", "minimum": 0, "maximum": 1},
    "replay_execution_cost_delta_bps": {"type": "number"},
    "replay_execution_cost_status": {"enum": ["PASS", "FAIL", "UNTESTED", "BLOCKED"]},
    "replay_performance_scope": {"const": "PUBLIC_REPLAY_ONLY_NOT_PAPER_RANKING"},
    "replay_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "report_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  },
  "$defs": {
    "public_replay_sample_row": {
      "type": "object",
      "required": [
        "sample_id",
        "sample_index",
        "event_time_utc",
        "runtime_cycle_id",
        "runtime_cycle_hash",
        "symbol",
        "strategy_family",
        "strategy_id",
        "candidate_id",
        "decision",
        "executed_trade",
        "replay_return_basis",
        "regime",
        "strategy_policy_reason",
        "no_trade_reason",
        "net_ev_after_cost_bps",
        "gross_expected_edge_bps",
        "total_execution_cost_bps",
        "opportunity_net_ev_after_cost_bps",
        "opportunity_gross_expected_edge_bps",
        "opportunity_total_execution_cost_bps"
      ],
      "additionalProperties": false,
      "properties": {
        "sample_id": {"type": "string", "minLength": 1},
        "sample_index": {"type": "integer", "minimum": 1},
        "event_time_utc": {"type": ["string", "null"]},
        "runtime_cycle_id": {"type": "string", "minLength": 1},
        "runtime_cycle_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "symbol": {"type": "string", "minLength": 1},
        "strategy_family": {
          "enum": [
            "PULLBACK_TREND_LONG",
            "BREAKOUT_RETEST_LONG",
            "VWAP_MEAN_REVERSION"
          ]
        },
        "strategy_id": {"type": "string", "minLength": 1},
        "candidate_id": {"type": "string", "minLength": 1},
        "decision": {"enum": ["PAPER_ENTRY_REVIEW", "NO_TRADE"]},
        "executed_trade": {"type": "boolean"},
        "replay_return_basis": {
          "enum": [
            "EXECUTED_ENTRY_REVIEW_NET_EV_AFTER_COST",
            "FLAT_NO_TRADE_CASH_RETURN"
          ]
        },
        "regime": {"enum": ["UPTREND", "RANGE", "RISK_OFF"]},
        "strategy_policy_reason": {"type": ["string", "null"]},
        "no_trade_reason": {"type": ["string", "null"]},
        "net_ev_after_cost_bps": {"type": "number"},
        "gross_expected_edge_bps": {"type": "number"},
        "total_execution_cost_bps": {"type": "number"},
        "opportunity_net_ev_after_cost_bps": {"type": "number"},
        "opportunity_gross_expected_edge_bps": {"type": "number"},
        "opportunity_total_execution_cost_bps": {"type": "number"},
        "runtime_final_decision": {
          "enum": ["ENTER_LONG", "NO_TRADE", "HOLD_POSITION", "EXIT_POSITION", "REDUCE_POSITION", "BLOCKED"]
        },
        "runtime_no_trade_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "runtime_paper_fill_side": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
        "runtime_paper_broker_state": {"type": ["string", "null"]},
        "paper_fill_belongs_to_candidate": {"type": "boolean"},
        "paper_fill_side": {"type": ["string", "null"], "enum": ["BUY", "SELL", null]},
        "paper_broker_state": {"type": ["string", "null"]},
        "closed_trade": {"type": "boolean"},
        "realized_trade_pnl_bps": {"type": ["number", "null"]},
        "realized_vs_expected_edge_bps": {"type": ["number", "null"]},
        "strategy_exit_policy_observed": {"type": "boolean"},
        "strategy_exit_policy_matched": {"type": "boolean"},
        "strategy_exit_policy_id": {"type": ["string", "null"]},
        "strategy_exit_variation": {"type": ["string", "null"]},
        "expected_strategy_exit_variation": {"type": "string"},
        "strategy_exit_reason_code": {"type": ["string", "null"]},
        "strategy_exit_action": {"type": ["string", "null"]},
        "realized_fee_bps": {"type": "number", "minimum": 0},
        "realized_slippage_bps": {"type": "number", "minimum": 0},
        "realized_impact_bps": {"type": "number", "minimum": 0},
        "expected_total_execution_cost_bps": {"type": "number", "minimum": 0},
        "realized_total_execution_cost_bps": {"type": "number", "minimum": 0},
        "execution_cost_delta_bps": {"type": "number"}
      }
    }
  }
}
