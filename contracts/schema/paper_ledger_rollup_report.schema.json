{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_ledger_rollup_report.v1",
  "title": "paper_ledger_rollup_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "rollup_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "ledger_source_dir",
    "ledger_input_scope",
    "ledger_jsonl_count",
    "ledger_event_count",
    "filled_order_count",
    "duplicate_ledger_path_count",
    "duplicate_event_count",
    "duplicate_order_count",
    "lifecycle_incomplete_order_count",
    "corrupted_ledger_jsonl_quarantined_count",
    "invalid_ledger_jsonl_count",
    "latest_ledger_head_hash",
    "ledger_head_report_path",
    "ledger_head_report_hash",
    "ledger_head_cycle_id",
    "ledger_head_event_count",
    "ledger_head_match_status",
    "ledger_head_mismatch_count",
    "portfolio_snapshot",
    "rollup_status",
    "primary_blocker_code",
    "blockers",
    "artifact_paths",
    "display_only",
    "dashboard_truth_only",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "rollup_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.paper_ledger_rollup_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "rollup_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "ledger_source_dir": {"type": "string", "minLength": 1},
    "ledger_input_scope": {"enum": ["SESSION_CYCLE_GLOB", "EXPLICIT_SCOPED_PATHS"]},
    "ledger_jsonl_count": {"type": "integer", "minimum": 0},
    "ledger_event_count": {"type": "integer", "minimum": 0},
    "filled_order_count": {"type": "integer", "minimum": 0},
    "duplicate_ledger_path_count": {"type": "integer", "minimum": 0},
    "duplicate_event_count": {"type": "integer", "minimum": 0},
    "duplicate_order_count": {"type": "integer", "minimum": 0},
    "lifecycle_incomplete_order_count": {"type": "integer", "minimum": 0},
    "corrupted_ledger_jsonl_quarantined_count": {"type": "integer", "minimum": 0},
    "invalid_ledger_jsonl_count": {"type": "integer", "minimum": 0},
    "latest_ledger_head_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "ledger_head_report_path": {"type": ["string", "null"], "minLength": 1},
    "ledger_head_report_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "ledger_head_cycle_id": {"type": ["string", "null"], "minLength": 1},
    "ledger_head_event_count": {"type": "integer", "minimum": 0},
    "ledger_head_match_status": {"enum": ["PASS", "MISSING", "MISMATCH", "NOT_APPLICABLE"]},
    "ledger_head_mismatch_count": {"type": "integer", "minimum": 0},
    "portfolio_snapshot": {"type": "object"},
    "rollup_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "artifact_paths": {"type": "array", "items": {"type": "string"}},
    "display_only": {"const": true},
    "dashboard_truth_only": {"const": true},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "rollup_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
