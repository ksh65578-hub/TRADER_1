{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.residual_operator_reconciliation_intake_preflight_report.v1",
  "type": "object",
  "required": [
    "schema_id",
    "patch_id",
    "generated_at_utc",
    "authority",
    "source_reports",
    "state_last_patch_id_before",
    "state_next_task_before",
    "selected_next_task_class",
    "open_gap_ids",
    "open_gap_count",
    "preflight_status",
    "review_cards_source_status",
    "review_cards_source_hashes_verified",
    "review_card_count",
    "blocked_review_card_count",
    "review_ready_count",
    "control_card_count",
    "unsatisfied_control_count",
    "satisfied_control_count",
    "operator_resolution_current_evidence_write_allowed_count",
    "operator_resolution_candidate_current_evidence_usable_count",
    "operator_reconciliation_submission_manifest_path",
    "operator_reconciliation_submission_manifest_status",
    "operator_submission_required",
    "operator_submission_validated",
    "required_intake_item_count",
    "missing_intake_item_count",
    "ready_for_review_intake_item_count",
    "accepted_intake_item_count",
    "single_next_intake_item",
    "intake_item_preview",
    "intake_items",
    "control_requirement_count",
    "unsatisfied_control_requirement_count",
    "control_requirements",
    "paper_shadow_operator_evidence_intake_status",
    "paper_shadow_operator_submission_manifest_status",
    "one_line_summary",
    "primary_next_action",
    "operator_no_action_needed_for_next_non_live_patch",
    "operator_action_required_for_gap_closure",
    "current_evidence_write_allowed",
    "gap_closure_allowed_by_this_patch",
    "live_ready_write_allowed",
    "live_config_mutation_allowed",
    "credential_values_read",
    "credential_environment_inspection_performed",
    "runtime_artifacts_staged_by_this_patch",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "validation_status",
    "validation_errors",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.residual_operator_reconciliation_intake_preflight_report.v1"
    },
    "patch_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "minLength": 1
        },
        "agents_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_reports": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "patch_id", "report_hash"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "enum": [
              "residual_operator_reconciliation_review_cards",
              "residual_operator_evidence_intake_audit"
            ]
          },
          "patch_id": {
            "type": "string",
            "minLength": 1
          },
          "report_hash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        }
      }
    },
    "state_last_patch_id_before": {
      "type": "string"
    },
    "state_next_task_before": {
      "type": "string"
    },
    "selected_next_task_class": {
      "type": "string",
      "minLength": 1
    },
    "open_gap_ids": {
      "$ref": "#/$defs/string_array"
    },
    "open_gap_count": {
      "type": "integer",
      "minimum": 0
    },
    "preflight_status": {
      "const": "BLOCKED_RECONCILIATION_INTAKE_PACKAGE_MISSING"
    },
    "review_cards_source_status": {
      "const": "BLOCKED_RECONCILIATION_REVIEW_ONLY"
    },
    "review_cards_source_hashes_verified": {
      "const": true
    },
    "review_card_count": {
      "type": "integer",
      "minimum": 1
    },
    "blocked_review_card_count": {
      "type": "integer",
      "minimum": 1
    },
    "review_ready_count": {
      "const": 0
    },
    "control_card_count": {
      "type": "integer",
      "minimum": 1
    },
    "unsatisfied_control_count": {
      "type": "integer",
      "minimum": 1
    },
    "satisfied_control_count": {
      "const": 0
    },
    "operator_resolution_current_evidence_write_allowed_count": {
      "const": 0
    },
    "operator_resolution_candidate_current_evidence_usable_count": {
      "const": 0
    },
    "operator_reconciliation_submission_manifest_path": {
      "const": "system/evidence/operator_submissions/residual_operator_reconciliation_submission_manifest.json"
    },
    "operator_reconciliation_submission_manifest_status": {
      "enum": [
        "MISSING_OPERATOR_RECONCILIATION_SUBMISSION_MANIFEST",
        "PRESENT_NOT_VALIDATED"
      ]
    },
    "operator_submission_required": {
      "const": true
    },
    "operator_submission_validated": {
      "const": false
    },
    "required_intake_item_count": {
      "type": "integer",
      "minimum": 1
    },
    "missing_intake_item_count": {
      "type": "integer",
      "minimum": 1
    },
    "ready_for_review_intake_item_count": {
      "const": 0
    },
    "accepted_intake_item_count": {
      "const": 0
    },
    "single_next_intake_item": {
      "$ref": "#/$defs/intake_item"
    },
    "intake_item_preview": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/intake_item"
      }
    },
    "intake_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/intake_item"
      }
    },
    "control_requirement_count": {
      "type": "integer",
      "minimum": 1
    },
    "unsatisfied_control_requirement_count": {
      "type": "integer",
      "minimum": 1
    },
    "control_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/control_requirement"
      }
    },
    "paper_shadow_operator_evidence_intake_status": {
      "const": "BLOCKED_AWAITING_OPERATOR_EVIDENCE_PACKAGE"
    },
    "paper_shadow_operator_submission_manifest_status": {
      "type": "string",
      "minLength": 1
    },
    "one_line_summary": {
      "type": "string",
      "minLength": 1
    },
    "primary_next_action": {
      "type": "string",
      "minLength": 1
    },
    "operator_no_action_needed_for_next_non_live_patch": {
      "const": true
    },
    "operator_action_required_for_gap_closure": {
      "const": true
    },
    "current_evidence_write_allowed": {
      "const": false
    },
    "gap_closure_allowed_by_this_patch": {
      "const": false
    },
    "live_ready_write_allowed": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "credential_values_read": {
      "const": false
    },
    "credential_environment_inspection_performed": {
      "const": false
    },
    "runtime_artifacts_staged_by_this_patch": {
      "const": false
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "validation_status": {
      "const": "PASS"
    },
    "validation_errors": {
      "type": "array",
      "maxItems": 0,
      "items": {
        "type": "string"
      }
    },
    "report_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "intake_item": {
      "type": "object",
      "required": [
        "intake_item_id",
        "review_card_id",
        "priority_order",
        "cycle_id",
        "required_resolution_evidence_kind",
        "resolution_reason_code",
        "source_candidate_rollup_artifact_path",
        "source_decision_candidate_rollup_hash",
        "planned_current_ledger_jsonl_path",
        "manifest_path",
        "intake_item_status",
        "operator_submission_required",
        "operator_submission_validated",
        "source_hash_recorded",
        "review_ready",
        "accepted_for_reconciliation",
        "blocks_gap_closure",
        "current_evidence_write_allowed",
        "gap_closure_allowed_by_this_patch",
        "live_ready_write_allowed",
        "live_config_mutation_allowed",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "intake_item_id": {
          "type": "string",
          "minLength": 1
        },
        "review_card_id": {
          "type": "string",
          "minLength": 1
        },
        "priority_order": {
          "type": "integer",
          "minimum": 1
        },
        "cycle_id": {
          "type": "string",
          "minLength": 1
        },
        "required_resolution_evidence_kind": {
          "type": "string",
          "minLength": 1
        },
        "resolution_reason_code": {
          "const": "POST_RERUN_RECONCILIATION_REQUIRED"
        },
        "source_candidate_rollup_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "source_decision_candidate_rollup_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "planned_current_ledger_jsonl_path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_path": {
          "const": "system/evidence/operator_submissions/residual_operator_reconciliation_submission_manifest.json"
        },
        "intake_item_status": {
          "const": "MISSING_OPERATOR_RECONCILIATION_EVIDENCE"
        },
        "operator_submission_required": {
          "const": true
        },
        "operator_submission_validated": {
          "const": false
        },
        "source_hash_recorded": {
          "const": false
        },
        "review_ready": {
          "const": false
        },
        "accepted_for_reconciliation": {
          "const": false
        },
        "blocks_gap_closure": {
          "const": true
        },
        "current_evidence_write_allowed": {
          "const": false
        },
        "gap_closure_allowed_by_this_patch": {
          "const": false
        },
        "live_ready_write_allowed": {
          "const": false
        },
        "live_config_mutation_allowed": {
          "const": false
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    },
    "control_requirement": {
      "type": "object",
      "required": [
        "control_id",
        "control_order",
        "blocker_code",
        "control_status",
        "source_control_status",
        "required",
        "satisfied",
        "operator_submission_required",
        "current_evidence_write_allowed",
        "gap_closure_allowed_by_this_patch",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "control_id": {
          "type": "string",
          "minLength": 1
        },
        "control_order": {
          "type": "integer",
          "minimum": 1
        },
        "blocker_code": {
          "const": "POST_RERUN_RECONCILIATION_REQUIRED"
        },
        "control_status": {
          "const": "UNSATISFIED_RECONCILIATION_INTAKE_CONTROL"
        },
        "source_control_status": {
          "const": "UNSATISFIED_BLOCKING_CONTROL"
        },
        "required": {
          "const": true
        },
        "satisfied": {
          "const": false
        },
        "operator_submission_required": {
          "const": true
        },
        "current_evidence_write_allowed": {
          "const": false
        },
        "gap_closure_allowed_by_this_patch": {
          "const": false
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    }
  }
}
