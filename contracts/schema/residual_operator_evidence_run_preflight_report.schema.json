{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.residual_operator_evidence_run_preflight_report.v1",
  "type": "object",
  "required": [
    "schema_id",
    "patch_id",
    "generated_at_utc",
    "authority",
    "source_reports",
    "state_last_patch_id_before",
    "state_next_task_before",
    "selected_next_task_class",
    "preflight_status",
    "open_gap_ids",
    "open_gap_count",
    "command_id",
    "command_shell",
    "command_text",
    "command_scope",
    "command_entrypoint",
    "command_environment_overrides",
    "minimum_duration_hours",
    "minimum_paper_shadow_window_count",
    "expected_heartbeat_ticks",
    "heartbeat_interval_seconds",
    "expected_runtime_artifacts",
    "required_validator_ids",
    "preflight_checks",
    "preflight_check_count",
    "preflight_pass_count",
    "preflight_blocked_count",
    "non_live_operator_command_preflight_passed",
    "credential_values_read",
    "credential_environment_inspection_performed",
    "command_executed_by_this_patch",
    "operator_run_started_by_this_patch",
    "operator_run_completed_by_this_patch",
    "operator_run_evidence_ready_for_mvp5",
    "mvp5_entry_blocked_until_operator_evidence",
    "current_evidence_write_allowed",
    "gap_closure_allowed_by_this_patch",
    "live_config_mutation_allowed",
    "live_ready_write_allowed",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "validation_status",
    "validation_errors",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.residual_operator_evidence_run_preflight_report.v1"
    },
    "patch_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "minLength": 1
        },
        "agents_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_reports": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "patch_id", "report_hash"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "enum": [
              "residual_operator_execution_guide",
              "residual_operator_evidence_progress"
            ]
          },
          "patch_id": {
            "type": "string",
            "minLength": 1
          },
          "report_hash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        }
      }
    },
    "state_last_patch_id_before": {
      "type": "string"
    },
    "state_next_task_before": {
      "type": "string"
    },
    "selected_next_task_class": {
      "type": "string",
      "minLength": 1
    },
    "preflight_status": {
      "enum": [
        "NON_LIVE_OPERATOR_RUN_PRECHECK_PASS",
        "BLOCKED_PREFLIGHT"
      ]
    },
    "open_gap_ids": {
      "$ref": "#/$defs/string_array"
    },
    "open_gap_count": {
      "type": "integer",
      "minimum": 0
    },
    "command_id": {
      "const": "UPBIT_PAPER_SAFE_MONITOR_120H"
    },
    "command_shell": {
      "const": "powershell"
    },
    "command_text": {
      "type": "string",
      "minLength": 1
    },
    "command_scope": {
      "const": "UPBIT/KRW_SPOT/PAPER"
    },
    "command_entrypoint": {
      "const": "UPBIT_PAPER.py"
    },
    "command_environment_overrides": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "enum": [
              "TRADER1_ROOT_OPERATOR_HEARTBEAT_TICKS",
              "TRADER1_ROOT_OPERATOR_HEARTBEAT_INTERVAL_SECONDS"
            ]
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "minimum_duration_hours": {
      "type": "integer",
      "minimum": 120
    },
    "minimum_paper_shadow_window_count": {
      "type": "integer",
      "minimum": 20
    },
    "expected_heartbeat_ticks": {
      "type": "integer",
      "minimum": 43200
    },
    "heartbeat_interval_seconds": {
      "const": 10
    },
    "expected_runtime_artifacts": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/expected_runtime_artifact"
      }
    },
    "required_validator_ids": {
      "$ref": "#/$defs/string_array"
    },
    "preflight_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/preflight_check"
      }
    },
    "preflight_check_count": {
      "type": "integer",
      "minimum": 1
    },
    "preflight_pass_count": {
      "type": "integer",
      "minimum": 0
    },
    "preflight_blocked_count": {
      "type": "integer",
      "minimum": 0
    },
    "non_live_operator_command_preflight_passed": {
      "type": "boolean"
    },
    "credential_values_read": {
      "const": false
    },
    "credential_environment_inspection_performed": {
      "const": false
    },
    "command_executed_by_this_patch": {
      "const": false
    },
    "operator_run_started_by_this_patch": {
      "const": false
    },
    "operator_run_completed_by_this_patch": {
      "const": false
    },
    "operator_run_evidence_ready_for_mvp5": {
      "const": false
    },
    "mvp5_entry_blocked_until_operator_evidence": {
      "const": true
    },
    "current_evidence_write_allowed": {
      "const": false
    },
    "gap_closure_allowed_by_this_patch": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "live_ready_write_allowed": {
      "const": false
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "validation_status": {
      "const": "PASS"
    },
    "validation_errors": {
      "type": "array",
      "maxItems": 0,
      "items": {
        "type": "string"
      }
    },
    "report_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_runtime_artifact": {
      "type": "object",
      "required": [
        "path",
        "artifact_role",
        "required_before_next_review",
        "current_path_status",
        "evidence_ready_for_closure",
        "current_evidence_write_allowed",
        "gap_closure_allowed_by_this_patch"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "artifact_role": {
          "const": "PAPER_SHADOW_OPERATOR_EVIDENCE_INPUT"
        },
        "required_before_next_review": {
          "const": true
        },
        "current_path_status": {
          "enum": [
            "PRESENT_LOCAL_RUNTIME_OUTPUT_NOT_CLOSURE_READY",
            "MISSING_EXPECTED_RUNTIME_OUTPUT",
            "PLACEHOLDER_PATTERN_PENDING"
          ]
        },
        "evidence_ready_for_closure": {
          "const": false
        },
        "current_evidence_write_allowed": {
          "const": false
        },
        "gap_closure_allowed_by_this_patch": {
          "const": false
        }
      }
    },
    "preflight_check": {
      "type": "object",
      "required": ["check_id", "status", "message"],
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["PASS", "BLOCKED"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
