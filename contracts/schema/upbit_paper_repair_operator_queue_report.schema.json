    "generated_at_utc",
    "project_id",
    "queue_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "truth_role",
    "queue_role",
    "source_blocked_repair_plan_hash",
    "source_blocked_repair_plan_status",
    "source_ledger_rollup_repair_hash",
    "source_ledger_rollup_repair_status",
    "source_post_repair_reconciliation_hash",
    "source_post_repair_reconciliation_status",
    "queue_item_count",
    "ledger_candidate_review_ready_count",
    "runtime_cycle_rerun_required_count",
    "recovery_guard_rerun_required_count",
    "hash_operator_reconciliation_required_count",
    "candidate_current_evidence_usable_count",
    "queue_status",
    "primary_blocker_code",
    "blocker_codes",
    "items",
    "operator_next_action",
    "current_evidence_mutation_allowed",
    "persistent_loop_mutation_allowed",
    "source_delete_allowed",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "queue_hash"
  ],
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_repair_operator_queue_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 20},
    "project_id": {"const": "TRADER_1"},
    "queue_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "truth_role": {"const": "paper_runtime_repair_operator_queue_truth"},
    "queue_role": {"const": "PAPER_RUNTIME_REPAIR_OPERATOR_QUEUE_NOT_EVIDENCE"},
    "source_blocked_repair_plan_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "source_blocked_repair_plan_status": {"const": "BLOCKED"},
    "source_ledger_rollup_repair_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "source_ledger_rollup_repair_status": {"const": "BLOCKED"},
    "source_post_repair_reconciliation_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "source_post_repair_reconciliation_status": {"const": "BLOCKED"},
    "queue_item_count": {"type": "integer", "minimum": 0},
    "ledger_candidate_review_ready_count": {"type": "integer", "minimum": 0},
    "runtime_cycle_rerun_required_count": {"type": "integer", "minimum": 0},
    "recovery_guard_rerun_required_count": {"type": "integer", "minimum": 0},
    "hash_operator_reconciliation_required_count": {"type": "integer", "minimum": 0},
    "candidate_current_evidence_usable_count": {"const": 0},
    "queue_status": {"const": "BLOCKED"},
    "primary_blocker_code": {"const": "REGENERATED_CURRENT_BLOCKED_REPAIRS_REQUIRE_LEDGER_RECOVERY_RECONCILIATION"},
    "blocker_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority_order",
          "replacement_loop_id",
          "replacement_path",
          "safe_repair_lane",
          "operator_action",
          "ready_for_operator_ledger_candidate_review",
          "requires_runtime_cycle_rerun",
          "requires_recovery_guard_rerun",
          "requires_hash_operator_reconciliation",
          "cycle_ledger_jsonl_missing_count",
          "cycle_ledger_jsonl_missing_paths",
          "paper_ledger_rollup_path",
          "paper_ledger_rollup_artifact_exists",
          "candidate_rollup_artifact_path",
          "candidate_rollup_validator_status",
          "candidate_rollup_hash",
          "candidate_current_evidence_usable",
          "post_repair_candidate_classification",
          "post_repair_item_blocker_code",
          "blocking_codes",
          "current_evidence_mutation_allowed",
          "persistent_loop_mutation_allowed",
          "source_delete_allowed",
          "live_permission_created"
        ],
        "properties": {
          "priority_order": {"type": "integer", "minimum": 1},
          "replacement_loop_id": {"type": "string", "minLength": 1},
          "replacement_path": {"type": "string", "minLength": 1},
          "safe_repair_lane": {
            "enum": [
              "LEDGER_ROLLUP_REBUILD_READY",
              "RERUN_RUNTIME_CYCLES_THEN_LEDGER_ROLLUP",
              "RECOVERY_GUARD_THEN_LEDGER_ROLLUP",
              "QUARANTINE_OPERATOR_REVIEW",
              "RERUN_POST_REGENERATION_RECONCILIATION"
            ]
          },
          "operator_action": {"type": "string", "minLength": 1},
          "ready_for_operator_ledger_candidate_review": {"type": "boolean"},
          "requires_runtime_cycle_rerun": {"type": "boolean"},
          "requires_recovery_guard_rerun": {"type": "boolean"},
          "requires_hash_operator_reconciliation": {"type": "boolean"},
          "cycle_ledger_jsonl_missing_count": {"type": "integer", "minimum": 0},
          "cycle_ledger_jsonl_missing_paths": {"type": "array", "items": {"type": "string"}},
          "paper_ledger_rollup_path": {"type": "string", "minLength": 1},
          "paper_ledger_rollup_artifact_exists": {"type": "boolean"},
          "candidate_rollup_artifact_path": {"type": ["string", "null"], "minLength": 1},
          "candidate_rollup_validator_status": {"enum": ["PASS", "BLOCKED", "FAIL", null]},
          "candidate_rollup_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
          "candidate_current_evidence_usable": {"const": false},
          "post_repair_candidate_classification": {
            "enum": [
              "REPAIR_CANDIDATE_BLOCKED_ROLLUP_VALIDATION",
              "REPAIR_CANDIDATE_BLOCKED_HASH_MISMATCH",
              "REPAIR_CANDIDATE_BLOCKED_OPERATOR_RECONCILIATION",
              "REPAIR_CANDIDATE_BLOCKED_CURRENT_EVIDENCE_MUTATION_POLICY",
              null
            ]
          },
          "post_repair_item_blocker_code": {"type": ["string", "null"]},
          "blocking_codes": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
          "current_evidence_mutation_allowed": {"const": false},
          "persistent_loop_mutation_allowed": {"const": false},
          "source_delete_allowed": {"const": false},
          "live_permission_created": {"const": false}
        }
      }
    },
    "operator_next_action": {"type": "string", "minLength": 1},
    "current_evidence_mutation_allowed": {"const": false},
    "persistent_loop_mutation_allowed": {"const": false},
    "source_delete_allowed": {"const": false},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "queue_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
