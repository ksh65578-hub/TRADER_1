{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_repair_operator_queue_report.v1",
  "title": "upbit_paper_repair_operator_queue_report",
  "type": "object",
  "additionalProperties": false,
