{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.strategy_performance_memory.v1",
  "title": "strategy_performance_memory",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "strategy_performance_memory_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "timeframe_scope",
    "regime_scope",
    "performance_scope",
    "performance_status",
    "source_modes",
    "source_artifact_ids",
    "sample_count",
    "min_required_sample_count",
    "trade_count",
    "no_trade_count",
    "entry_reason_counts",
    "exit_reason_counts",
    "no_trade_reason_counts",
    "gross_pnl",
    "fee_cost",
    "spread_cost",
    "slippage_cost",
    "market_impact_cost",
    "net_ev_after_cost",
    "max_drawdown_pct",
    "win_rate",
    "profit_factor",
    "regime_performance",
    "downtrend_avoidance_enforced",
    "risk_off_no_trade_enforced",
    "cost_model_included",
    "slippage_fee_impact_included",
    "paper_shadow_separated",
    "exchange_market_type_scoped",
    "dashboard_display_truth_only",
    "operator_warning",
    "blockers",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "live_permission_created",
    "live_config_mutation_allowed",
    "writes_live_ready_snapshot",
    "active_snapshot_mutation_allowed",
    "optimizer_winner_live_config_allowed",
    "paper_winner_live_config_allowed",
    "order_submission_allowed",
    "exchange_account_call_allowed",
    "scale_up_from_performance_allowed"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.strategy_performance_memory.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "authority": {
      "type": "object",
      "required": [
        "trader1_sha256",
        "agents_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "agents_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "strategy_performance_memory_id": {
      "type": "string",
      "minLength": 1
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "enum": [
        "REPLAY",
        "PAPER",
        "SHADOW",
        "READ_ONLY"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_build_id": {
      "type": "string",
      "minLength": 1
    },
    "parameter_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timeframe_scope": {
      "type": "string",
      "minLength": 1
    },
    "regime_scope": {
      "type": "string",
      "minLength": 1
    },
    "performance_scope": {
      "enum": [
        "PAPER_SHADOW_RESEARCH_ONLY",
        "PAPER_RUNTIME_SCORECARD_ONLY",
        "REPLAY_RESEARCH_ONLY",
        "READ_ONLY_ANALYSIS_ONLY"
      ]
    },
    "performance_status": {
      "enum": [
        "COLLECTING",
        "IMPROVING_AFTER_COST",
        "BLOCKED",
        "STALE_SAFE_MODE"
      ]
    },
    "source_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "REPLAY",
          "PAPER",
          "SHADOW",
          "READ_ONLY"
        ]
      }
    },
    "source_artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sample_count": {
      "type": "integer",
      "minimum": 0
    },
    "min_required_sample_count": {
      "type": "integer",
      "minimum": 1
    },
    "trade_count": {
      "type": "integer",
      "minimum": 0
    },
    "no_trade_count": {
      "type": "integer",
      "minimum": 0
    },
    "entry_reason_counts": {
      "$ref": "#/$defs/reason_counts"
    },
    "exit_reason_counts": {
      "$ref": "#/$defs/reason_counts"
    },
    "no_trade_reason_counts": {
      "$ref": "#/$defs/reason_counts"
    },
    "gross_pnl": {
      "type": "number"
    },
    "fee_cost": {
      "type": "number",
      "minimum": 0
    },
    "spread_cost": {
      "type": "number",
      "minimum": 0
    },
    "slippage_cost": {
      "type": "number",
      "minimum": 0
    },
    "market_impact_cost": {
      "type": "number",
      "minimum": 0
    },
    "net_ev_after_cost": {
      "type": "number"
    },
    "max_drawdown_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "win_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "profit_factor": {
      "type": "number",
      "minimum": 0
    },
    "regime_performance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "regime",
          "sample_count",
          "trade_count",
          "no_trade_count",
          "net_ev_after_cost",
          "max_drawdown_pct",
          "trade_allowed",
          "primary_blocker_code"
        ],
        "additionalProperties": false,
        "properties": {
          "regime": {
            "enum": [
              "UPTREND",
              "RANGE",
              "DOWNTREND",
              "RISK_OFF"
            ]
          },
          "sample_count": {
            "type": "integer",
            "minimum": 0
          },
          "trade_count": {
            "type": "integer",
            "minimum": 0
          },
          "no_trade_count": {
            "type": "integer",
            "minimum": 0
          },
          "net_ev_after_cost": {
            "type": "number"
          },
          "max_drawdown_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "trade_allowed": {
            "type": "boolean"
          },
          "primary_blocker_code": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "downtrend_avoidance_enforced": {
      "const": true
    },
    "risk_off_no_trade_enforced": {
      "const": true
    },
    "cost_model_included": {
      "const": true
    },
    "slippage_fee_impact_included": {
      "const": true
    },
    "paper_shadow_separated": {
      "type": "boolean"
    },
    "exchange_market_type_scoped": {
      "const": true
    },
    "dashboard_display_truth_only": {
      "const": true
    },
    "operator_warning": {
      "type": "string",
      "minLength": 1
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "common.defs.schema.json#/$defs/blocker_object"
      }
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "live_permission_created": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "writes_live_ready_snapshot": {
      "const": false
    },
    "active_snapshot_mutation_allowed": {
      "const": false
    },
    "optimizer_winner_live_config_allowed": {
      "const": false
    },
    "paper_winner_live_config_allowed": {
      "const": false
    },
    "order_submission_allowed": {
      "const": false
    },
    "exchange_account_call_allowed": {
      "const": false
    },
    "scale_up_from_performance_allowed": {
      "const": false
    }
  },
  "$defs": {
    "reason_counts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "reason_code",
          "count"
        ],
        "additionalProperties": false,
        "properties": {
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
