{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_stale_loop_post_regeneration_reconciliation_report.v1",
  "title": "upbit_paper_stale_loop_post_regeneration_reconciliation_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "post_reconciliation_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "truth_role",
    "post_reconciliation_role",
    "evidence_use_policy",
    "source_executor_hash",
    "source_executor_status",
    "source_executor_validator_status",
    "source_executor_validator_blocker_code",
    "planned_regeneration_item_count",
    "post_reconciliation_item_count",
    "source_retained_count",
    "source_hash_mismatch_count",
    "replacement_found_count",
    "replacement_hash_mismatch_count",
    "regenerated_current_accepted_count",
    "regenerated_current_blocked_reconciliation_count",
    "blocked_repair_reason_counts",
    "regenerated_current_invalid_count",
    "current_evidence_usable_count",
    "excluded_from_current_evidence_count",
    "usable_runtime_cycle_hash_duplicate_count",
    "unpaired_regenerated_artifact_count",
    "unpaired_regenerated_artifact_paths",
    "post_reconciliation_status",
    "primary_blocker_code",
    "blocker_codes",
    "items",
    "delete_source_allowed",
    "overwrite_source_allowed",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "operator_next_action",
    "post_reconciliation_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "post_reconciliation_item": {
      "type": "object",
      "required": [
        "source_path",
        "source_hash_expected",
        "source_hash_actual",
        "source_hash_match",
        "source_retained",
        "source_path_scope_status",
        "replacement_path",
        "replacement_path_scope_status",
        "replacement_exists",
        "replacement_loop_id",
        "replacement_loop_hash_expected",
        "replacement_loop_hash_actual",
        "replacement_loop_hash_match",
        "replacement_validation_status",
        "replacement_validation_blocker_code",
        "replacement_validation_message",
        "classification",
        "evidence_usable_current",
        "recommended_action",
        "item_blocker_code",
        "blocked_repair_reason_codes",
        "blocked_repair_reason_summary",
        "recovery_reconciliation_status",
        "ledger_reconciliation_status",
        "cycle_reconciliation_status",
        "operator_repair_action",
        "runtime_cycle_hashes",
        "unsafe_live_or_order_flag_detected",
        "source_excluded_from_current_evidence",
        "delete_source_allowed",
        "overwrite_source_allowed",
        "actual_long_run_evidence_created",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "source_hash_expected": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_hash_actual": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_hash_match": {"type": "boolean"},
        "source_retained": {"type": "boolean"},
        "source_path_scope_status": {"enum": ["MATCH", "MISMATCH"]},
        "replacement_path": {"type": "string", "minLength": 1},
        "replacement_path_scope_status": {"enum": ["MATCH", "MISMATCH"]},
        "replacement_exists": {"type": "boolean"},
        "replacement_loop_id": {"type": ["string", "null"], "minLength": 1},
        "replacement_loop_hash_expected": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "replacement_loop_hash_actual": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "replacement_loop_hash_match": {"type": "boolean"},
        "replacement_validation_status": {"enum": ["PASS", "FAIL", "BLOCKED"]},
        "replacement_validation_blocker_code": {"type": ["string", "null"]},
        "replacement_validation_message": {"type": "string", "minLength": 1},
        "classification": {
          "enum": [
            "REGENERATED_CURRENT_ACCEPTED",
            "REGENERATED_CURRENT_BLOCKED_RECONCILIATION_REQUIRED",
            "REGENERATED_CURRENT_INVALID",
            "REPLACEMENT_MISSING_OR_MISMATCH",
            "SOURCE_RETENTION_MISMATCH_BLOCKED",
            "EXECUTOR_ITEM_BLOCKED",
            "UNSAFE_BLOCKED"
          ]
        },
        "evidence_usable_current": {"type": "boolean"},
        "recommended_action": {
          "enum": [
            "ACCEPT_REGENERATED_CURRENT_SOURCE",
            "RECONCILE_LEDGER_AND_RECOVERY_BEFORE_EVIDENCE_USE",
            "REPLAY_SAFE_REGENERATION_EXECUTOR",
            "QUARANTINE_OPERATOR_REVIEW"
          ]
        },
        "item_blocker_code": {"type": ["string", "null"]},
        "blocked_repair_reason_codes": {
          "type": "array",
          "items": {
            "enum": [
              "LOOP_STATUS_BLOCKED",
              "LOOP_RECONCILIATION_REQUIRED",
              "RECOVERY_GUARD_BLOCKED",
              "PARTIAL_WRITE_RECOVERY_REQUIRED",
              "PAPER_RUNTIME_RESUME_BLOCKED",
              "LEDGER_ROLLUP_BLOCKED",
              "LEDGER_ROLLUP_RECONCILIATION_REQUIRED",
              "RUNTIME_CYCLE_RECONCILIATION_REQUIRED",
              "PERSISTENT_LOOP_REPORT_NOT_LOADED",
              "PERSISTENT_LOOP_VALIDATOR_RECONCILIATION_REQUIRED"
            ]
          },
          "uniqueItems": true
        },
        "blocked_repair_reason_summary": {"type": "string", "minLength": 1},
        "recovery_reconciliation_status": {"enum": ["PASS", "BLOCKED", "UNKNOWN"]},
        "ledger_reconciliation_status": {"enum": ["PASS", "BLOCKED", "UNKNOWN"]},
        "cycle_reconciliation_status": {"enum": ["PASS", "BLOCKED", "UNKNOWN"]},
        "operator_repair_action": {"type": "string", "minLength": 1},
        "runtime_cycle_hashes": {
          "type": "array",
          "items": {"type": "string", "minLength": 64, "maxLength": 64}
        },
        "unsafe_live_or_order_flag_detected": {"type": "boolean"},
        "source_excluded_from_current_evidence": {"const": true},
        "delete_source_allowed": {"const": false},
        "overwrite_source_allowed": {"const": false},
        "actual_long_run_evidence_created": {"const": false},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_stale_loop_post_regeneration_reconciliation_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "post_reconciliation_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "truth_role": {"const": "paper_runtime_post_regeneration_reconciliation_truth"},
    "post_reconciliation_role": {"const": "PAPER_RUNTIME_STALE_LOOP_POST_REGENERATION_RECONCILIATION_NOT_LONG_RUN_EVIDENCE"},
    "evidence_use_policy": {"const": "PASS_REGENERATED_CURRENT_SCHEMA_ONLY_EXCLUDE_SOURCES_AND_BLOCKED_REPAIRS"},
    "source_executor_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "source_executor_status": {"type": ["string", "null"]},
    "source_executor_validator_status": {"enum": ["PASS", "FAIL", "BLOCKED"]},
    "source_executor_validator_blocker_code": {"type": ["string", "null"]},
    "planned_regeneration_item_count": {"type": "integer", "minimum": 0},
    "post_reconciliation_item_count": {"type": "integer", "minimum": 0},
    "source_retained_count": {"type": "integer", "minimum": 0},
    "source_hash_mismatch_count": {"type": "integer", "minimum": 0},
    "replacement_found_count": {"type": "integer", "minimum": 0},
    "replacement_hash_mismatch_count": {"type": "integer", "minimum": 0},
        "regenerated_current_accepted_count": {"type": "integer", "minimum": 0},
    "regenerated_current_blocked_reconciliation_count": {"type": "integer", "minimum": 0},
    "blocked_repair_reason_counts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason_code", "count"],
        "additionalProperties": false,
        "properties": {
          "reason_code": {
            "enum": [
              "LOOP_STATUS_BLOCKED",
              "LOOP_RECONCILIATION_REQUIRED",
              "RECOVERY_GUARD_BLOCKED",
              "PARTIAL_WRITE_RECOVERY_REQUIRED",
              "PAPER_RUNTIME_RESUME_BLOCKED",
              "LEDGER_ROLLUP_BLOCKED",
              "LEDGER_ROLLUP_RECONCILIATION_REQUIRED",
              "RUNTIME_CYCLE_RECONCILIATION_REQUIRED",
              "PERSISTENT_LOOP_REPORT_NOT_LOADED",
              "PERSISTENT_LOOP_VALIDATOR_RECONCILIATION_REQUIRED"
            ]
          },
          "count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "regenerated_current_invalid_count": {"type": "integer", "minimum": 0},
    "current_evidence_usable_count": {"type": "integer", "minimum": 0},
    "excluded_from_current_evidence_count": {"type": "integer", "minimum": 0},
    "usable_runtime_cycle_hash_duplicate_count": {"type": "integer", "minimum": 0},
    "unpaired_regenerated_artifact_count": {"type": "integer", "minimum": 0},
    "unpaired_regenerated_artifact_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "post_reconciliation_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blocker_codes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "items": {"type": "array", "items": {"$ref": "#/$defs/post_reconciliation_item"}},
    "delete_source_allowed": {"const": false},
    "overwrite_source_allowed": {"const": false},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "operator_next_action": {"type": "string", "minLength": 1},
    "post_reconciliation_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
