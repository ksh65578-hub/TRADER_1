{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.residual_operator_evidence_progress_report.v1",
  "type": "object",
  "required": [
    "schema_id",
    "patch_id",
    "generated_at_utc",
    "authority",
    "source_reports",
    "state_last_patch_id_before",
    "state_next_task_before",
    "selected_next_task_class",
    "open_gap_ids",
    "open_gap_count",
    "execution_step_count",
    "evidence_item_count",
    "present_blocked_evidence_item_count",
    "missing_operator_evidence_item_count",
    "placeholder_pending_evidence_item_count",
    "external_evidence_required_item_count",
    "local_runtime_output_item_count",
    "local_runtime_command_count",
    "local_runtime_completed_count",
    "minimum_observation_hours_required",
    "operator_evidence_ready_for_mvp5",
    "any_evidence_item_ready_for_closure",
    "mvp5_entry_blocked_until_operator_evidence",
    "binance_runtime_status",
    "progress_status",
    "evidence_items",
    "local_runtime_commands",
    "current_evidence_write_allowed",
    "gap_closure_allowed_by_this_patch",
    "live_config_mutation_allowed",
    "live_ready_write_allowed",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "validation_status",
    "validation_errors",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.residual_operator_evidence_progress_report.v1"
    },
    "patch_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "minLength": 1
        },
        "agents_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_reports": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "patch_id", "report_hash"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "const": "residual_operator_execution_guide"
          },
          "patch_id": {
            "type": "string",
            "minLength": 1
          },
          "report_hash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        }
      }
    },
    "state_last_patch_id_before": {
      "type": "string"
    },
    "state_next_task_before": {
      "type": "string"
    },
    "selected_next_task_class": {
      "type": "string",
      "minLength": 1
    },
    "open_gap_ids": {
      "$ref": "#/$defs/string_array"
    },
    "open_gap_count": {
      "type": "integer",
      "minimum": 0
    },
    "execution_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "present_blocked_evidence_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "missing_operator_evidence_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "placeholder_pending_evidence_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "external_evidence_required_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "local_runtime_output_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "local_runtime_command_count": {
      "type": "integer",
      "minimum": 0
    },
    "local_runtime_completed_count": {
      "const": 0
    },
    "minimum_observation_hours_required": {
      "type": "integer",
      "minimum": 0
    },
    "operator_evidence_ready_for_mvp5": {
      "const": false
    },
    "any_evidence_item_ready_for_closure": {
      "const": false
    },
    "mvp5_entry_blocked_until_operator_evidence": {
      "const": true
    },
    "binance_runtime_status": {
      "const": "SCAFFOLD_ONLY_NOT_ELIGIBLE_FOR_READINESS"
    },
    "progress_status": {
      "const": "BLOCKED_EVIDENCE_MISSING"
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "local_runtime_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/local_runtime_command"
      }
    },
    "current_evidence_write_allowed": {
      "const": false
    },
    "gap_closure_allowed_by_this_patch": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "live_ready_write_allowed": {
      "const": false
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "validation_status": {
      "const": "PASS"
    },
    "validation_errors": {
      "type": "array",
      "maxItems": 0,
      "items": {
        "type": "string"
      }
    },
    "report_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "action_class": {
      "enum": [
        "OPERATOR_RECONCILIATION_ACTION",
        "PAPER_LEDGER_RERUN_RECONCILIATION_ACTION",
        "PAPER_SHADOW_EVIDENCE_COLLECTION_ACTION",
        "EXTERNAL_LIVE_READINESS_EVIDENCE_ACTION",
        "SEALED_BASELINE_PRESERVATION_ACTION",
        "SCALE_UP_POLICY_EVIDENCE_ACTION"
      ]
    },
    "evidence_path_status": {
      "enum": [
        "PRESENT_BLOCKED",
        "MISSING_OPERATOR_EVIDENCE",
        "PLACEHOLDER_PATTERN_PENDING",
        "EXTERNAL_EVIDENCE_REQUIRED",
        "LOCAL_RUNTIME_OUTPUT_PRESENT_NOT_CLOSURE_READY",
        "LOCAL_RUNTIME_OUTPUT_MISSING"
      ]
    },
    "evidence_item": {
      "type": "object",
      "required": [
        "evidence_item_id",
        "step_id",
        "action_class",
        "evidence_path",
        "path_status",
        "blocks_mvp5_entry",
        "evidence_ready_for_closure",
        "current_evidence_write_allowed",
        "gap_closure_allowed_by_this_patch",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence_item_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "action_class": {
          "$ref": "#/$defs/action_class"
        },
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "path_status": {
          "$ref": "#/$defs/evidence_path_status"
        },
        "blocks_mvp5_entry": {
          "const": true
        },
        "evidence_ready_for_closure": {
          "const": false
        },
        "current_evidence_write_allowed": {
          "const": false
        },
        "gap_closure_allowed_by_this_patch": {
          "const": false
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    },
    "local_runtime_command": {
      "type": "object",
      "required": [
        "command_id",
        "action_class",
        "scope",
        "minimum_duration_hours",
        "command_status",
        "non_live_only",
        "credential_required",
        "live_order_allowed",
        "evidence_ready_for_closure",
        "current_evidence_write_allowed",
        "gap_closure_allowed_by_this_patch",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "command_id": {
          "enum": ["UPBIT_PAPER_SAFE_MONITOR_48H", "UPBIT_PAPER_SAFE_MONITOR_120H"]
        },
        "action_class": {
          "const": "PAPER_SHADOW_EVIDENCE_COLLECTION_ACTION"
        },
        "scope": {
          "const": "UPBIT/KRW_SPOT/PAPER"
        },
        "minimum_duration_hours": {
          "type": "integer",
          "minimum": 48
        },
        "command_status": {
          "const": "NOT_RUN_BY_THIS_PATCH"
        },
        "non_live_only": {
          "const": true
        },
        "credential_required": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "evidence_ready_for_closure": {
          "const": false
        },
        "current_evidence_write_allowed": {
          "const": false
        },
        "gap_closure_allowed_by_this_patch": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    }
  }
}
