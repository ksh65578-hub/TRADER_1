{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_blocked_repair_plan_report.v1",
  "title": "upbit_paper_blocked_repair_plan_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "repair_plan_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "truth_role",
    "repair_plan_role",
    "source_report_path",
    "source_post_reconciliation_hash",
    "source_post_reconciliation_status",
    "source_blocked_reconciliation_count",
    "repair_item_count",
    "repair_lane_counts",
    "ledger_rollup_rebuild_ready_count",
    "runtime_cycle_rerun_required_count",
    "recovery_guard_rerun_required_count",
    "missing_cycle_ledger_jsonl_item_count",
    "missing_cycle_ledger_jsonl_total_count",
    "missing_paper_ledger_rollup_artifact_count",
    "repair_plan_status",
    "primary_blocker_code",
    "blocker_codes",
    "items",
    "operator_next_action",
    "current_evidence_mutation_allowed",
    "generated_artifact_mutation_allowed",
    "source_delete_allowed",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "repair_plan_hash"
  ],
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_blocked_repair_plan_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 20},
    "project_id": {"const": "TRADER_1"},
    "repair_plan_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "truth_role": {"const": "paper_runtime_blocked_repair_plan_truth"},
    "repair_plan_role": {"const": "PAPER_RUNTIME_BLOCKED_REPAIR_PLAN_NOT_EVIDENCE"},
    "source_report_path": {"type": "string", "minLength": 1},
    "source_post_reconciliation_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "source_post_reconciliation_status": {"enum": ["PASS", "BLOCKED"]},
    "source_blocked_reconciliation_count": {"type": "integer", "minimum": 0},
    "repair_item_count": {"type": "integer", "minimum": 0},
    "repair_lane_counts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["safe_repair_lane", "count"],
        "properties": {
          "safe_repair_lane": {
            "enum": [
              "LEDGER_ROLLUP_REBUILD_READY",
              "RERUN_RUNTIME_CYCLES_THEN_LEDGER_ROLLUP",
              "RECOVERY_GUARD_THEN_LEDGER_ROLLUP",
              "QUARANTINE_OPERATOR_REVIEW",
              "RERUN_POST_REGENERATION_RECONCILIATION"
            ]
          },
          "count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "ledger_rollup_rebuild_ready_count": {"type": "integer", "minimum": 0},
    "runtime_cycle_rerun_required_count": {"type": "integer", "minimum": 0},
    "recovery_guard_rerun_required_count": {"type": "integer", "minimum": 0},
    "missing_cycle_ledger_jsonl_item_count": {"type": "integer", "minimum": 0},
    "missing_cycle_ledger_jsonl_total_count": {"type": "integer", "minimum": 0},
    "missing_paper_ledger_rollup_artifact_count": {"type": "integer", "minimum": 0},
    "repair_plan_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blocker_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "replacement_loop_id",
          "replacement_path",
          "replacement_load_status",
          "replacement_path_scope_status",
          "blocked_repair_reason_codes",
          "ledger_reconciliation_status",
          "recovery_reconciliation_status",
          "cycle_reconciliation_status",
          "safe_repair_lane",
          "cycle_count",
          "cycle_ledger_jsonl_present_count",
          "cycle_ledger_jsonl_missing_count",
          "cycle_ledger_jsonl_missing_paths",
          "paper_ledger_rollup_path",
          "paper_ledger_rollup_artifact_exists",
          "can_rebuild_ledger_rollup_without_rerun",
          "requires_recovery_guard_rerun",
          "requires_runtime_cycle_rerun",
          "current_evidence_mutation_allowed",
          "source_delete_allowed",
          "live_permission_created",
          "repair_steps"
        ],
        "properties": {
          "replacement_loop_id": {"type": ["string", "null"]},
          "replacement_path": {"type": "string", "minLength": 1},
          "replacement_load_status": {"type": "string", "minLength": 1},
          "replacement_path_scope_status": {"enum": ["MATCH", "MISMATCH"]},
          "blocked_repair_reason_codes": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
          "ledger_reconciliation_status": {"enum": ["PASS", "BLOCKED", "UNKNOWN"]},
          "recovery_reconciliation_status": {"enum": ["PASS", "BLOCKED", "UNKNOWN"]},
          "cycle_reconciliation_status": {"enum": ["PASS", "BLOCKED", "UNKNOWN"]},
          "safe_repair_lane": {
            "enum": [
              "LEDGER_ROLLUP_REBUILD_READY",
              "RERUN_RUNTIME_CYCLES_THEN_LEDGER_ROLLUP",
              "RECOVERY_GUARD_THEN_LEDGER_ROLLUP",
              "QUARANTINE_OPERATOR_REVIEW",
              "RERUN_POST_REGENERATION_RECONCILIATION"
            ]
          },
          "cycle_count": {"type": "integer", "minimum": 0},
          "cycle_ledger_jsonl_present_count": {"type": "integer", "minimum": 0},
          "cycle_ledger_jsonl_missing_count": {"type": "integer", "minimum": 0},
          "cycle_ledger_jsonl_missing_paths": {"type": "array", "items": {"type": "string"}},
          "paper_ledger_rollup_path": {"type": "string"},
          "paper_ledger_rollup_artifact_exists": {"type": "boolean"},
          "can_rebuild_ledger_rollup_without_rerun": {"type": "boolean"},
          "requires_recovery_guard_rerun": {"type": "boolean"},
          "requires_runtime_cycle_rerun": {"type": "boolean"},
          "current_evidence_mutation_allowed": {"const": false},
          "source_delete_allowed": {"const": false},
          "live_permission_created": {"const": false},
          "repair_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_order",
                "action_code",
                "action_status",
                "evidence_required",
                "mutates_current_evidence",
                "live_permission_created"
              ],
              "properties": {
                "step_order": {"type": "integer", "minimum": 1},
                "action_code": {"type": "string", "minLength": 1},
                "action_status": {"enum": ["READY", "BLOCKED"]},
                "evidence_required": {"type": "string", "minLength": 1},
                "mutates_current_evidence": {"const": false},
                "live_permission_created": {"const": false}
              }
            }
          }
        }
      }
    },
    "operator_next_action": {"type": "string", "minLength": 1},
    "current_evidence_mutation_allowed": {"const": false},
    "generated_artifact_mutation_allowed": {"const": false},
    "source_delete_allowed": {"const": false},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "repair_plan_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
