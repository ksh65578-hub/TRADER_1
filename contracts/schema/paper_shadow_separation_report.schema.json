{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_shadow_separation_report.v1",
  "title": "paper_shadow_separation_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "separation_report_id",
    "exchange",
    "market_type",
    "paper_mode",
    "shadow_mode",
    "paper_session_id",
    "shadow_session_id",
    "paper_artifact_path",
    "shadow_artifact_path",
    "raw_join_attempted",
    "paper_shadow_separated",
    "paper_live_namespace_separated",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "separation_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.paper_shadow_separation_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "separation_report_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "paper_mode": {"const": "PAPER"},
    "shadow_mode": {"const": "SHADOW"},
    "paper_session_id": {"type": "string", "minLength": 1},
    "shadow_session_id": {"type": "string", "minLength": 1},
    "paper_artifact_path": {"type": "string", "minLength": 1},
    "shadow_artifact_path": {"type": "string", "minLength": 1},
    "raw_join_attempted": {"type": "boolean"},
    "paper_shadow_separated": {"type": "boolean"},
    "paper_live_namespace_separated": {"type": "boolean"},
    "live_order_ready": {"type": "boolean"},
    "live_order_allowed": {"type": "boolean"},
    "can_live_trade": {"type": "boolean"},
    "order_adapter_called": {"type": "boolean"},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "separation_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
