{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_runtime_sample_history.v1",
  "title": "upbit_paper_runtime_sample_history",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "history_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "truth_role",
    "runtime_analysis_only",
    "execution_truth",
    "dashboard_truth_only",
    "history_evidence_role",
    "runtime_sample_status",
    "primary_blocker_code",
    "source_loop_report_count",
    "accepted_loop_report_count",
    "accepted_cycle_sample_count",
    "unique_runtime_cycle_hash_count",
    "duplicate_cycle_hash_count",
    "invalid_source_count",
    "invalid_sources",
    "first_sample_at_utc",
    "latest_sample_at_utc",
    "observed_span_seconds",
    "min_actual_long_run_span_seconds",
    "min_actual_long_run_cycle_count",
    "span_floor_met",
    "cycle_floor_met",
    "min_profitability_scope_sample_count",
    "candidate_scope_sample_summary_count",
    "candidate_scope_sample_summaries",
    "active_candidate_scope",
    "active_candidate_scope_status",
    "active_candidate_scope_sample_count",
    "active_candidate_scope_sample_deficit",
    "active_candidate_scope_next_action",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "long_run_blocker_code",
    "long_run_next_action",
    "promotion_eligible",
    "source_loop_report_hashes",
    "source_runtime_cycle_hashes",
    "samples",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "history_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "invalid_source": {
      "type": "object",
      "required": ["path", "reason"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "runtime_sample": {
      "type": "object",
      "required": [
        "schema_id",
        "generated_at_utc",
        "project_id",
        "exchange",
        "market_type",
        "mode",
        "session_id",
        "loop_id",
        "cycle_id",
        "source_loop_report_path",
        "source_loop_report_hash",
        "source_runtime_cycle_path",
        "source_runtime_cycle_hash",
        "runtime_input_role",
        "final_decision",
        "paper_ledger_head_hash",
        "paper_portfolio_snapshot_hash",
        "candidate_count",
        "entry_reason_count",
        "exit_reason_count",
        "no_trade_reason_count",
        "previous_sample_hash",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed",
        "sample_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_id": {"const": "trader1.upbit_paper_runtime_sample.v1"},
        "generated_at_utc": {"type": "string", "minLength": 1},
        "project_id": {"const": "TRADER_1"},
        "exchange": {"const": "UPBIT"},
        "market_type": {"const": "KRW_SPOT"},
        "mode": {"const": "PAPER"},
        "session_id": {"type": "string", "minLength": 1},
        "loop_id": {"type": "string", "minLength": 1},
        "cycle_id": {"type": "string", "minLength": 1},
        "source_loop_report_path": {"type": "string", "minLength": 1},
        "source_loop_report_hash": {"type": "string", "minLength": 64, "maxLength": 64},
        "source_runtime_cycle_path": {"type": "string", "minLength": 1},
        "source_runtime_cycle_hash": {"type": "string", "minLength": 64, "maxLength": 64},
        "runtime_input_role": {
          "enum": [
            "STATIC_FIXTURE",
            "PUBLIC_MARKET_DATA_COLLECTION",
            "MULTI_SYMBOL_PUBLIC_MARKET_DATA_COLLECTION"
          ]
        },
        "final_decision": {
          "enum": [
            "ENTER_LONG",
            "NO_TRADE",
            "BLOCKED",
            "SAFE_MODE",
            "RECONCILE_REQUIRED",
            "HOLD_POSITION",
            "EXIT_POSITION",
            "REDUCE_POSITION"
          ]
        },
        "paper_ledger_head_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "paper_portfolio_snapshot_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "candidate_count": {"type": "integer", "minimum": 0},
        "entry_reason_count": {"type": "integer", "minimum": 0},
        "exit_reason_count": {"type": "integer", "minimum": 0},
        "no_trade_reason_count": {"type": "integer", "minimum": 0},
        "scorecard_candidate_identity_source": {"type": "string", "minLength": 1},
        "scorecard_candidate_identity_binding_status": {"enum": ["BOUND", "MISSING"]},
        "scorecard_candidate_live_flags_clear": {"type": "boolean"},
        "scorecard_symbol": {"type": ["string", "null"], "minLength": 1},
        "scorecard_candidate_id": {"type": ["string", "null"], "minLength": 1},
        "scorecard_strategy_family": {"type": ["string", "null"], "minLength": 1},
        "scorecard_strategy_id": {"type": ["string", "null"], "minLength": 1},
        "scorecard_parameter_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "scorecard_candidate_decision": {"type": ["string", "null"], "minLength": 1},
        "scorecard_candidate_net_ev_after_cost_bps": {"type": ["string", "number", "null"]},
        "scorecard_candidate_selection_score": {"type": ["string", "number", "null"]},
        "scorecard_expected_edge_bps": {"type": ["string", "number", "null"]},
        "scorecard_expected_cost_bps": {"type": ["string", "number", "null"]},
        "paper_entry_review_candidate_count": {"type": "integer", "minimum": 0},
        "paper_entry_review_candidate_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "paper_entry_review_symbols": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "paper_entry_review_symbol_count": {"type": "integer", "minimum": 0},
        "symbol_evidence_scorecard_count": {"type": "integer", "minimum": 0},
        "previous_sample_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false},
        "sample_hash": {"type": "string", "minLength": 64, "maxLength": 64}
      }
    },
    "candidate_scope_summary": {
      "type": "object",
      "required": [
        "candidate_scope_id",
        "exchange",
        "market_type",
        "mode",
        "symbol",
        "candidate_id",
        "strategy_id",
        "parameter_hash",
        "sample_count",
        "entry_reason_count",
        "exit_reason_count",
        "no_trade_reason_count",
        "candidate_count_total",
        "first_sample_at_utc",
        "latest_sample_at_utc",
        "latest_loop_id",
        "latest_cycle_id",
        "latest_final_decision",
        "latest_candidate_decision",
        "latest_sample_hash",
        "latest_runtime_cycle_hash",
        "min_required_sample_count",
        "sample_deficit",
        "scope_progress_status",
        "next_collection_action",
        "next_operator_action",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_scope_id": {"type": "string", "minLength": 1},
        "exchange": {"const": "UPBIT"},
        "market_type": {"const": "KRW_SPOT"},
        "mode": {"const": "PAPER"},
        "symbol": {"type": "string", "minLength": 1},
        "candidate_id": {"type": "string", "minLength": 1},
        "strategy_id": {"type": "string", "minLength": 1},
        "parameter_hash": {"type": "string", "minLength": 64, "maxLength": 64},
        "sample_count": {"type": "integer", "minimum": 0},
        "entry_reason_count": {"type": "integer", "minimum": 0},
        "exit_reason_count": {"type": "integer", "minimum": 0},
        "no_trade_reason_count": {"type": "integer", "minimum": 0},
        "candidate_count_total": {"type": "integer", "minimum": 0},
        "first_sample_at_utc": {"type": ["string", "null"]},
        "latest_sample_at_utc": {"type": ["string", "null"]},
        "latest_loop_id": {"type": ["string", "null"]},
        "latest_cycle_id": {"type": ["string", "null"]},
        "latest_final_decision": {"type": ["string", "null"]},
        "latest_candidate_decision": {"type": ["string", "null"]},
        "latest_sample_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "latest_runtime_cycle_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "min_required_sample_count": {"type": "integer", "minimum": 1},
        "sample_deficit": {"type": "integer", "minimum": 0},
        "scope_progress_status": {
          "enum": ["COLLECT_PAPER_SCOPE_SAMPLES", "PAPER_SCOPE_SAMPLE_FLOOR_MET"]
        },
        "next_collection_action": {
          "enum": ["RUN_MORE_PAPER_SAMPLE_WINDOWS", "KEEP_PAPER_RUNNING_FOR_PAIRED_WINDOWS"]
        },
        "next_operator_action": {"type": "string", "minLength": 1},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_runtime_sample_history.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "history_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "truth_role": {"const": "paper_runtime_analysis_truth"},
    "runtime_analysis_only": {"const": true},
    "execution_truth": {"const": false},
    "dashboard_truth_only": {"const": false},
    "history_evidence_role": {"const": "PAPER_RUNTIME_SAMPLE_HISTORY_NOT_LONG_RUN_EVIDENCE"},
    "runtime_sample_status": {"enum": ["INSUFFICIENT_HISTORY", "COLLECTING", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "source_loop_report_count": {"type": "integer", "minimum": 0},
    "accepted_loop_report_count": {"type": "integer", "minimum": 0},
    "accepted_cycle_sample_count": {"type": "integer", "minimum": 0},
    "unique_runtime_cycle_hash_count": {"type": "integer", "minimum": 0},
    "duplicate_cycle_hash_count": {"type": "integer", "minimum": 0},
    "invalid_source_count": {"type": "integer", "minimum": 0},
    "invalid_sources": {"type": "array", "items": {"$ref": "#/$defs/invalid_source"}},
    "first_sample_at_utc": {"type": ["string", "null"]},
    "latest_sample_at_utc": {"type": ["string", "null"]},
    "observed_span_seconds": {"type": "integer", "minimum": 0},
    "min_actual_long_run_span_seconds": {"type": "integer", "minimum": 1},
    "min_actual_long_run_cycle_count": {"type": "integer", "minimum": 1},
    "span_floor_met": {"type": "boolean"},
    "cycle_floor_met": {"type": "boolean"},
    "min_profitability_scope_sample_count": {"type": "integer", "minimum": 1},
    "candidate_scope_sample_summary_count": {"type": "integer", "minimum": 0},
    "candidate_scope_sample_summaries": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate_scope_summary"}
    },
    "active_candidate_scope": {
      "anyOf": [
        {"$ref": "#/$defs/candidate_scope_summary"},
        {"type": "null"}
      ]
    },
    "active_candidate_scope_status": {
      "enum": ["NO_CANDIDATE_SCOPE", "COLLECT_PAPER_SCOPE_SAMPLES", "PAPER_SCOPE_SAMPLE_FLOOR_MET"]
    },
    "active_candidate_scope_sample_count": {"type": "integer", "minimum": 0},
    "active_candidate_scope_sample_deficit": {"type": "integer", "minimum": 0},
    "active_candidate_scope_next_action": {"type": "string", "minLength": 1},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "long_run_blocker_code": {"const": "LONG_RUN_PAPER_RUNTIME_EVIDENCE_INSUFFICIENT"},
    "long_run_next_action": {"type": "string", "minLength": 1},
    "promotion_eligible": {"const": false},
    "source_loop_report_hashes": {
      "type": "array",
      "items": {"type": "string", "minLength": 64, "maxLength": 64}
    },
    "source_runtime_cycle_hashes": {
      "type": "array",
      "items": {"type": "string", "minLength": 64, "maxLength": 64}
    },
    "samples": {"type": "array", "items": {"$ref": "#/$defs/runtime_sample"}},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "history_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
