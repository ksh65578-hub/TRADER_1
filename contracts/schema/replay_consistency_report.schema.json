{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.replay_consistency_report.v1",
  "title": "replay_consistency_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "replay_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "strategy_unit_id",
    "parameter_hash",
    "input_hash",
    "result_hashes",
    "deterministic_pass",
    "replay_status",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "replay_consistency_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.replay_consistency_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "replay_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"enum": ["REPLAY"]},
    "session_id": {"type": "string", "minLength": 1},
    "strategy_unit_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "input_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "result_hashes": {"type": "array", "items": {"type": "string"}},
    "deterministic_pass": {"type": "boolean"},
    "replay_status": {"enum": ["PASS", "FAIL", "BLOCKED"]},
    "live_order_ready": {"type": "boolean"},
    "live_order_allowed": {"type": "boolean"},
    "can_live_trade": {"type": "boolean"},
    "order_adapter_called": {"type": "boolean"},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "replay_consistency_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
