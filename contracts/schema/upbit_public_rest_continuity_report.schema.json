{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_public_rest_continuity_report.v1",
  "title": "upbit_public_rest_continuity_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "continuity_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "sample_count_requested",
    "sample_count_completed",
    "pass_sample_count",
    "min_required_pass_samples",
    "interval_seconds",
    "sample_reports",
    "sample_hashes",
    "first_event_time_utc",
    "latest_event_time_utc",
    "latest_event_times_utc",
    "observed_span_seconds",
    "duplicate_latest_event_time_detected",
    "non_advancing_sample_detected",
    "continuity_status",
    "primary_blocker_code",
    "blockers",
    "evidence_role",
    "credential_load_attempted",
    "authorization_header_present",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "continuity_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_public_rest_continuity_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "continuity_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "sample_count_requested": {"type": "integer", "minimum": 1, "maximum": 20},
    "sample_count_completed": {"type": "integer", "minimum": 0, "maximum": 20},
    "pass_sample_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "min_required_pass_samples": {"type": "integer", "minimum": 1, "maximum": 20},
    "interval_seconds": {"type": "number", "minimum": 0},
    "sample_reports": {"type": "array", "items": {"type": "object"}},
    "sample_hashes": {"type": "array", "items": {"type": "string", "minLength": 64, "maxLength": 64}},
    "first_event_time_utc": {"type": ["string", "null"]},
    "latest_event_time_utc": {"type": ["string", "null"]},
    "latest_event_times_utc": {"type": "array", "items": {"type": "string"}},
    "observed_span_seconds": {"type": "number", "minimum": 0},
    "duplicate_latest_event_time_detected": {"type": "boolean"},
    "non_advancing_sample_detected": {"type": "boolean"},
    "continuity_status": {"enum": ["PASS", "WARN", "BLOCKED", "FAIL"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "evidence_role": {"const": "PAPER_DATA_CONTINUITY_ONLY_NOT_LIVE_READY"},
    "credential_load_attempted": {"const": false},
    "authorization_header_present": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "continuity_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
