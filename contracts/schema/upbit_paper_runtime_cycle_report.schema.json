{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_runtime_cycle_report.v1",
  "title": "upbit_paper_runtime_cycle_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "cycle_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "runtime_input_role",
    "source_collection_report_hash",
    "source_public_market_data_hash",
    "canonical_event_count",
    "runtime_public_market_data_hash",
    "market_data_source",
    "public_market_data",
    "feature_snapshot",
    "feature_snapshot_hash",
    "regime",
    "strategy_candidates",
    "selected_candidate",
    "strategy_regime_cost_linkage",
    "sizing_decision",
    "paper_fill",
    "paper_ledger_events",
    "paper_ledger_head_hash",
    "paper_portfolio_snapshot",
    "summary",
    "final_decision",
    "no_trade_reasons",
    "entry_reasons",
    "paper_order_adapter",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "scale_up_allowed",
    "primary_blocker_code",
    "blockers",
    "cycle_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_runtime_cycle_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "cycle_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "runtime_input_role": {"enum": ["STATIC_FIXTURE", "PUBLIC_MARKET_DATA_COLLECTION"]},
    "source_collection_report_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "source_public_market_data_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "canonical_event_count": {"type": "integer", "minimum": 0},
    "runtime_public_market_data_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "market_data_source": {"enum": ["STATIC_FIXTURE", "PUBLIC_REST_READ_ONLY", "UNAVAILABLE"]},
    "public_market_data": {"type": "object"},
    "feature_snapshot": {"type": "object"},
    "feature_snapshot_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "regime": {"enum": ["UPTREND", "RANGE", "RISK_OFF"]},
    "strategy_candidates": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/runtime_strategy_candidate"}},
    "selected_candidate": {"$ref": "#/$defs/runtime_strategy_candidate"},
    "strategy_regime_cost_linkage": {"$ref": "#/$defs/strategy_regime_cost_linkage"},
    "sizing_decision": {"type": "object"},
    "paper_fill": {"type": ["object", "null"]},
    "paper_ledger_events": {"type": "array", "items": {"type": "object"}},
    "paper_ledger_head_hash": {"type": ["string", "null"]},
    "paper_portfolio_snapshot": {"type": "object"},
    "summary": {"type": "object"},
    "final_decision": {"$ref": "common.defs.schema.json#/$defs/final_decision"},
    "no_trade_reasons": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/no_trade_reason"}},
    "entry_reasons": {"type": "array", "items": {"type": "object"}},
    "paper_order_adapter": {"const": "SIMULATED_PAPER_BROKER_ONLY"},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "can_submit_order": {"const": false},
    "scale_up_allowed": {"const": false},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "cycle_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  },
  "$defs": {
    "strategy_regime_cost_linkage": {
      "type": "object",
      "required": [
        "source_runtime_cycle_id",
        "runtime_input_role",
        "runtime_public_market_data_hash",
        "feature_snapshot_hash",
        "report_regime",
        "selected_candidate_id",
        "selected_candidate_regime",
        "selected_candidate_cost_model_source",
        "selected_candidate_expected_cost_bps",
        "cost_breakdown_sum_bps",
        "selected_candidate_net_ev_after_cost_bps",
        "decision_basis",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_runtime_cycle_id": {"type": "string", "minLength": 1},
        "runtime_input_role": {"enum": ["STATIC_FIXTURE", "PUBLIC_MARKET_DATA_COLLECTION"]},
        "runtime_public_market_data_hash": {"type": "string", "minLength": 64, "maxLength": 64},
        "feature_snapshot_hash": {"type": "string", "minLength": 64, "maxLength": 64},
        "report_regime": {"enum": ["UPTREND", "RANGE", "RISK_OFF"]},
        "selected_candidate_id": {"type": "string", "minLength": 1},
        "selected_candidate_regime": {"enum": ["UPTREND", "RANGE", "RISK_OFF"]},
        "selected_candidate_cost_model_source": {"const": "PAPER_RUNTIME_STATIC_COST_MODEL"},
        "selected_candidate_expected_cost_bps": {"type": "string"},
        "cost_breakdown_sum_bps": {"type": "string"},
        "selected_candidate_net_ev_after_cost_bps": {"type": "string"},
        "decision_basis": {"const": "NET_EV_AFTER_COST_AND_REGIME"},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    },
    "runtime_strategy_candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "symbol",
        "strategy_family",
        "regime",
        "signal_strength",
        "signal_grade",
        "expected_edge_bps",
        "expected_cost_bps",
        "cost_breakdown_bps",
        "cost_model_source",
        "net_ev_after_cost_bps",
        "decision",
        "no_trade_reason",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": {"type": "string", "minLength": 1},
        "symbol": {"type": "string", "minLength": 1},
        "strategy_family": {"enum": ["PULLBACK_TREND_LONG", "BREAKOUT_RETEST_LONG", "VWAP_MEAN_REVERSION"]},
        "regime": {"enum": ["UPTREND", "RANGE", "RISK_OFF"]},
        "signal_strength": {"type": "string"},
        "signal_grade": {"enum": ["A", "B", "C"]},
        "expected_edge_bps": {"type": "string"},
        "expected_cost_bps": {"type": "string"},
        "cost_breakdown_bps": {
          "type": "object",
          "required": ["fee_bps", "slippage_bps", "spread_bps", "market_impact_bps", "latency_bps"],
          "additionalProperties": false,
          "properties": {
            "fee_bps": {"type": "string"},
            "slippage_bps": {"type": "string"},
            "spread_bps": {"type": "string"},
            "market_impact_bps": {"type": "string"},
            "latency_bps": {"type": "string"}
          }
        },
        "cost_model_source": {"const": "PAPER_RUNTIME_STATIC_COST_MODEL"},
        "net_ev_after_cost_bps": {"type": "string"},
        "decision": {"enum": ["PAPER_ENTRY_REVIEW", "NO_TRADE"]},
        "no_trade_reason": {
          "oneOf": [
            {"$ref": "common.defs.schema.json#/$defs/no_trade_reason"},
            {"type": "null"}
          ]
        },
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  }
}
