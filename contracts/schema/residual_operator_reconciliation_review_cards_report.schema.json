      "$ref": "#/$defs/string_array"
    },
    "operator_reconciliation_gap_count": {
      "type": "integer",
      "minimum": 0
    },
    "operator_reconciliation_required_evidence_kinds": {
      "$ref": "#/$defs/string_array"
    },
