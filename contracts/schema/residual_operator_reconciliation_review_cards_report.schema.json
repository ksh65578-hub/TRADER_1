    "source_hashes_verified": {
      "const": true
    },
    "operator_resolution_unresolved_item_count": {
      "type": "integer",
      "minimum": 1
    },
    "operator_resolution_resolved_item_count": {
      "const": 0
    },
    "operator_resolution_controls_satisfied_count": {
      "const": 0
    },
    "operator_resolution_current_evidence_write_allowed_count": {
      "const": 0
    },
    "operator_resolution_candidate_current_evidence_usable_count": {
      "const": 0
    },
    "review_card_count": {
      "type": "integer",
      "minimum": 1
    },
    "blocked_review_card_count": {
      "type": "integer",
      "minimum": 1
    },
    "review_ready_count": {
      "const": 0
    },
    "control_card_count": {
      "type": "integer",
      "minimum": 1
