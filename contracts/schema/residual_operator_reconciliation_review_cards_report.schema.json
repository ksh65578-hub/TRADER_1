          "type": "string",
          "minLength": 1
        },
        "current_evidence_write_allowed": {
          "const": false
        },
        "gap_closure_allowed_by_this_patch": {
          "const": false
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
