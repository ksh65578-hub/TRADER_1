        "current_evidence_mutation_allowed": {
          "const": false
        },
        "latest_runtime_pointer_write_allowed": {
          "const": false
        },
        "current_ledger_jsonl_write_allowed": {
          "const": false
        },
        "current_evidence_write_authorized": {
          "const": false
        },
        "promotion_eligible": {
          "const": false
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    },
    "control_card": {
      "type": "object",
      "required": [
        "control_id",
        "control_order",
        "blocker_code",
        "message",
        "required",
        "satisfied",
        "control_status",
        "next_safe_action",
        "current_evidence_write_allowed",
        "gap_closure_allowed_by_this_patch",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "control_id": {
          "type": "string",
          "minLength": 1
        },
        "control_order": {
          "type": "integer",
          "minimum": 1
