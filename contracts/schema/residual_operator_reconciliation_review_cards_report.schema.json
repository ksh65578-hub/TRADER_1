    "one_line_summary": {
      "type": "string",
      "minLength": 1
    },
    "primary_next_action": {
      "type": "string",
      "minLength": 1
    },
    "operator_no_action_needed_for_next_non_live_patch": {
      "const": true
    },
    "operator_action_required_for_gap_closure": {
      "const": true
    },
    "gap_closure_allowed_by_this_patch": {
      "const": false
    },
    "current_evidence_write_allowed": {
      "const": false
    },
    "current_evidence_mutation_allowed": {
      "const": false
    },
    "latest_runtime_pointer_write_allowed": {
      "const": false
    },
    "current_ledger_jsonl_write_allowed": {
      "const": false
    },
    "live_ready_write_allowed": {
      "const": false
