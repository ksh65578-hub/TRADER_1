{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.private_stream_health.v1",
  "title": "private_stream_health",
  "type": "object",
  "required": [
    "schema_id",
    "stream_health_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "private_stream_status",
    "private_ws_connected",
    "asset_probe_status",
    "order_probe_status",
    "reconciliation_fallback_available",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "stream_health_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.private_stream_health.v1"
    },
    "stream_health_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "authority": {
      "type": "object",
      "required": [
        "trader1_sha256",
        "agents_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "agents_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "const": "READ_ONLY"
    },
    "session_id": {
      "type": "string"
    },
    "private_stream_status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "UNVERIFIED",
        "FALLBACK_RECONCILIATION_REQUIRED"
      ]
    },
    "private_ws_connected": {
      "type": "boolean"
    },
    "asset_probe_status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "UNVERIFIED"
      ]
    },
    "order_probe_status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "UNVERIFIED"
      ]
    },
    "reconciliation_fallback_available": {
      "type": "boolean"
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "order_adapter_called": {
      "const": false
    },
    "primary_blocker_code": {
      "$ref": "common.defs.schema.json#/$defs/live_blocker_code"
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "common.defs.schema.json#/$defs/blocker_object"
      }
    },
    "stream_health_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
