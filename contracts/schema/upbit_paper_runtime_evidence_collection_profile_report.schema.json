{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_runtime_evidence_collection_profile_report.v1",
  "title": "TRADER_1 Upbit PAPER Runtime Evidence Collection Profile Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "created_at_utc",
    "profile_id",
    "profile_scope",
    "status",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "loop_id",
    "requested_cycle_count",
    "completed_cycle_count",
    "component_count",
    "component_pass_count",
    "component_blocked_count",
    "component_results",
    "loop_status",
    "loop_hash",
    "recovery_guard_status",
    "recovery_guard_hash",
    "runtime_sample_history_validation_status",
    "runtime_sample_status",
    "runtime_sample_history_hash",
    "accepted_cycle_sample_count",
    "unique_runtime_cycle_hash_count",
    "duplicate_cycle_hash_count",
    "invalid_source_count",
    "observed_span_seconds",
    "min_actual_long_run_span_seconds",
    "min_actual_long_run_cycle_count",
    "span_floor_met",
    "cycle_floor_met",
    "ledger_runtime_evidence_status",
    "ledger_idempotency_evidence_hash",
    "idempotency_status",
    "reconciliation_status",
    "mismatch_count",
    "source_ledger_jsonl_count",
    "recomputed_ledger_event_count",
    "recomputed_filled_order_count",
    "duplicate_event_id_count",
    "duplicate_dedup_key_count",
    "duplicate_semantic_event_count",
    "duplicate_filled_order_key_count",
    "primary_blocker_code",
    "blockers",
    "long_run_blocker_code",
    "long_run_collection_depth",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "current_evidence_write_allowed",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "scale_up_allowed",
    "profile_hash"
  ],
  "properties": {
    "schema_id": { "const": "trader1.upbit_paper_runtime_evidence_collection_profile_report.v1" },
    "created_at_utc": { "type": "string", "minLength": 20 },
    "profile_id": { "const": "UPBIT_PAPER_RUNTIME_EVIDENCE_COLLECTION_PROFILE_V1" },
    "profile_scope": { "const": "UPBIT_PAPER_RUNTIME_EVIDENCE_COLLECTION_PROFILE_ONLY_NO_LIVE" },
    "status": { "enum": ["PASS", "BLOCKED"] },
    "exchange": { "const": "UPBIT" },
    "market_type": { "const": "KRW_SPOT" },
    "mode": { "const": "PAPER" },
    "session_id": { "type": "string", "minLength": 1 },
    "loop_id": { "type": "string", "minLength": 1 },
    "requested_cycle_count": { "type": "integer", "minimum": 1, "maximum": 20 },
    "completed_cycle_count": { "type": "integer", "minimum": 0, "maximum": 20 },
    "component_count": { "type": "integer", "minimum": 0 },
    "component_pass_count": { "type": "integer", "minimum": 0 },
    "component_blocked_count": { "type": "integer", "minimum": 0 },
    "component_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/component_result" }
    },
    "loop_status": { "enum": ["PASS", "BLOCKED"] },
    "loop_hash": { "type": ["string", "null"], "minLength": 64, "maxLength": 64 },
    "recovery_guard_status": { "enum": ["PASS", "BLOCKED"] },
    "recovery_guard_hash": { "type": ["string", "null"], "minLength": 64, "maxLength": 64 },
    "runtime_sample_history_validation_status": { "enum": ["PASS", "BLOCKED", "FAIL"] },
    "runtime_sample_status": { "enum": ["INSUFFICIENT_HISTORY", "COLLECTING", "BLOCKED"] },
    "runtime_sample_history_hash": { "type": ["string", "null"], "minLength": 64, "maxLength": 64 },
    "accepted_cycle_sample_count": { "type": "integer", "minimum": 0 },
    "unique_runtime_cycle_hash_count": { "type": "integer", "minimum": 0 },
    "duplicate_cycle_hash_count": { "type": "integer", "minimum": 0 },
    "invalid_source_count": { "type": "integer", "minimum": 0 },
    "observed_span_seconds": { "type": "integer", "minimum": 0 },
    "min_actual_long_run_span_seconds": { "type": "integer", "minimum": 1 },
    "min_actual_long_run_cycle_count": { "type": "integer", "minimum": 1 },
    "span_floor_met": { "type": "boolean" },
    "cycle_floor_met": { "type": "boolean" },
    "ledger_runtime_evidence_status": { "enum": ["PASS", "BLOCKED"] },
    "ledger_idempotency_evidence_hash": { "type": ["string", "null"], "minLength": 64, "maxLength": 64 },
    "idempotency_status": { "enum": ["PASS", "BLOCKED"] },
    "reconciliation_status": { "enum": ["PASS", "BLOCKED"] },
    "mismatch_count": { "type": "integer", "minimum": 0 },
    "source_ledger_jsonl_count": { "type": "integer", "minimum": 0 },
    "recomputed_ledger_event_count": { "type": "integer", "minimum": 0 },
    "recomputed_filled_order_count": { "type": "integer", "minimum": 0 },
    "duplicate_event_id_count": { "type": "integer", "minimum": 0 },
    "duplicate_dedup_key_count": { "type": "integer", "minimum": 0 },
    "duplicate_semantic_event_count": { "type": "integer", "minimum": 0 },
    "duplicate_filled_order_key_count": { "type": "integer", "minimum": 0 },
    "primary_blocker_code": { "type": ["string", "null"] },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "long_run_blocker_code": { "const": "LONG_RUN_PAPER_RUNTIME_EVIDENCE_INSUFFICIENT" },
    "long_run_collection_depth": { "$ref": "#/$defs/long_run_collection_depth" },
    "actual_long_run_evidence_created": { "const": false },
    "long_run_evidence_eligible": { "const": false },
    "promotion_eligible": { "const": false },
    "current_evidence_write_allowed": { "const": false },
    "credential_load_attempted": { "const": false },
    "private_endpoint_called": { "const": false },
    "order_endpoint_called": { "const": false },
    "order_adapter_called": { "const": false },
    "live_key_loaded": { "const": false },
    "live_order_ready": { "const": false },
    "live_order_allowed": { "const": false },
    "can_live_trade": { "const": false },
    "can_submit_order": { "const": false },
    "scale_up_allowed": { "const": false },
    "profile_hash": { "type": "string", "minLength": 64, "maxLength": 64 }
  },
  "$defs": {
    "component_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "status", "blocker_code", "message", "evidence_hash"],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["PASS", "BLOCKED", "FAIL"] },
        "blocker_code": { "type": ["string", "null"] },
        "message": { "type": "string" },
        "evidence_hash": { "type": ["string", "null"], "minLength": 64, "maxLength": 64 }
      }
    },
    "long_run_collection_depth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "depth_role",
        "blocker_code",
        "required_runtime_modes",
        "observed_runtime_modes",
        "missing_runtime_modes",
        "observed_span_seconds",
        "minimum_span_seconds",
        "missing_span_seconds",
        "span_floor_met",
        "observed_cycle_count",
        "minimum_cycle_count",
        "missing_cycle_count",
        "cycle_floor_met",
        "paper_runtime_depth_status",
        "paper_ledger_idempotency_status",
        "shadow_runtime_depth_status",
        "paper_shadow_pairing_status",
        "bounded_profile_counts_as_long_run_evidence",
        "dashboard_display_counts_as_long_run_evidence",
        "actual_long_run_evidence_created",
        "long_run_evidence_eligible",
        "promotion_eligible",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "properties": {
        "status": { "const": "BLOCKED_FOR_LONG_RUN_COLLECTION_DEPTH" },
        "depth_role": { "const": "PAPER_RUNTIME_COLLECTION_DEPTH_BLOCKER_NOT_LONG_RUN_EVIDENCE" },
        "blocker_code": { "const": "LONG_RUN_PAPER_RUNTIME_EVIDENCE_INSUFFICIENT" },
        "required_runtime_modes": {
          "type": "array",
          "prefixItems": [
            { "const": "PAPER" },
            { "const": "SHADOW" }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "observed_runtime_modes": {
          "type": "array",
          "items": { "enum": ["PAPER", "SHADOW"] },
          "uniqueItems": true,
          "maxItems": 2
        },
        "missing_runtime_modes": {
          "type": "array",
          "items": { "enum": ["PAPER", "SHADOW"] },
          "contains": { "const": "SHADOW" },
          "uniqueItems": true,
          "minItems": 1,
          "maxItems": 2
        },
        "observed_span_seconds": { "type": "integer", "minimum": 0 },
        "minimum_span_seconds": { "type": "integer", "minimum": 1 },
        "missing_span_seconds": { "type": "integer", "minimum": 0 },
        "span_floor_met": { "type": "boolean" },
        "observed_cycle_count": { "type": "integer", "minimum": 0 },
        "minimum_cycle_count": { "type": "integer", "minimum": 1 },
        "missing_cycle_count": { "type": "integer", "minimum": 0 },
        "cycle_floor_met": { "type": "boolean" },
        "paper_runtime_depth_status": { "enum": ["PASS", "MISSING", "BLOCKED"] },
        "paper_ledger_idempotency_status": { "enum": ["PASS", "BLOCKED"] },
        "shadow_runtime_depth_status": { "const": "MISSING" },
        "paper_shadow_pairing_status": { "const": "MISSING" },
        "bounded_profile_counts_as_long_run_evidence": { "const": false },
        "dashboard_display_counts_as_long_run_evidence": { "const": false },
        "actual_long_run_evidence_created": { "const": false },
        "long_run_evidence_eligible": { "const": false },
        "promotion_eligible": { "const": false },
        "live_order_ready": { "const": false },
        "live_order_allowed": { "const": false },
        "can_live_trade": { "const": false },
        "scale_up_allowed": { "const": false }
      }
    }
  }
}
