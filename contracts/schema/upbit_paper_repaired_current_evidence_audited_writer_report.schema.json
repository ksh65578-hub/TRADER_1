    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "scale_up_allowed",
    "audited_writer_report_hash"
  ],
  "$defs": {
    "hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 64,
      "maxLength": 64
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "writer_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "control_status",
        "blocker_code",
        "detail",
        "artifact_written",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "properties": {
        "control_id": {
          "enum": [
            "SOURCE_IMPLEMENTATION_PREP_VALID",
            "SOURCE_LEDGER_ROLLUP_VALID",
            "TARGET_PATHS_WITHIN_SESSION",
            "TEMP_PATHS_CLEAR",
            "SINGLE_WRITER_LOCK_ACQUIRED",
            "CURRENT_EVIDENCE_SNAPSHOT_PUBLISHED",
            "IDEMPOTENCY_MANIFEST_PUBLISHED",
            "PORTFOLIO_TRUTH_PUBLISHED",
            "POST_WRITE_HASHES_MATCH",
            "POST_WRITE_SCHEMA_VALIDATED",
            "LIVE_AND_SCALE_BOUNDARY_CONFIRMED"
          ]
        },
        "control_status": {
          "enum": [
            "PASS",
            "BLOCKED"
          ]
        },
        "blocker_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "artifact_written": {
          "type": "boolean"
        },
        "live_order_ready": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "can_live_trade": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    },
    "target_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relative_final_path",
        "relative_temp_path",
        "final_path_resolves_under_session",
        "temp_path_resolves_under_session",
        "final_exists_before",
        "temp_exists_before"
      ],
      "properties": {
        "relative_final_path": {
          "type": "string",
          "minLength": 1
        },
        "relative_temp_path": {
          "type": "string",
          "minLength": 1
        },
        "final_path_resolves_under_session": {
          "type": "boolean"
        },
        "temp_path_resolves_under_session": {
          "type": "boolean"
        },
        "final_exists_before": {
          "type": "boolean"
        },
        "temp_exists_before": {
          "type": "boolean"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "relative_final_path",
        "relative_temp_path",
        "payload_hash",
        "file_hash",
        "file_exists",
        "artifact_written",
        "temp_exists_after_write",
        "live_order_allowed",
        "scale_up_allowed"
      ],
      "properties": {
        "artifact_id": {
          "enum": [
            "AUDITED_CURRENT_EVIDENCE_SNAPSHOT",
            "AUDITED_CURRENT_EVIDENCE_IDEMPOTENCY_MANIFEST",
            "AUDITED_PORTFOLIO_TRUTH_SNAPSHOT"
