        "file_exists": {
          "type": "boolean"
        },
        "artifact_written": {
          "type": "boolean"
        },
        "temp_exists_after_write": {
          "const": false
        },
        "live_order_allowed": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        }
      }
    },
    "archived_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relative_original_path",
        "relative_archive_path",
        "archived_file_hash",
        "archive_write_method",
        "audit_preserved",
        "source_delete_allowed",
        "live_order_allowed",
        "scale_up_allowed"
      ],
      "properties": {
        "relative_original_path": {
          "enum": [
            "paper_runtime/current_evidence/audited_current_evidence_snapshot.json",
            "paper_runtime/current_evidence/audited_current_evidence_idempotency_manifest.json",
            "paper_runtime/portfolio/paper_portfolio_snapshot.json"
          ]
        },
        "relative_archive_path": {
          "type": "string",
          "pattern": "^paper_runtime/current_evidence/archive/"
        },
        "archived_file_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "archive_write_method": {
          "const": "ATOMIC_RENAME"
