{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_current_truth_refresh_report.v1",
  "title": "PAPER Current Truth Refresh Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "refresh_status",
    "refresh_passed",
    "truth_role",
    "source_portfolio_schema_id",
    "source_portfolio_snapshot_hash",
    "source_portfolio_snapshot_generated_at_utc",
    "source_portfolio_snapshot_status",
    "source_paper_ledger_head_hash",
    "source_runtime_cycle_id",
    "verified_currency",
    "verified_starting_cash",
    "source_heartbeat_hash",
    "source_startup_probe_hash",
    "source_balance_kind",
    "portfolio_refresh_key",
    "verified_cash",
    "verified_locked_cash",
    "verified_position_market_value",
    "verified_equity",
    "verified_realized_pnl",
    "verified_unrealized_pnl",
    "verified_total_pnl",
    "verified_return_pct",
    "open_position_count",
    "positions",
    "heartbeat_pass",
    "startup_probe_pass",
    "paper_only",
    "display_only",
    "dashboard_truth_only",
    "audited_current_evidence_writer",
    "continuous_audited_writer",
    "current_evidence_write_allowed",
    "audited_current_evidence_write_allowed",
    "portfolio_truth_write_allowed",
    "live_ready_write_allowed",
    "live_config_mutation_allowed",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "scale_up_allowed",
    "primary_blocker_code",
    "operator_next_action",
    "refresh_report_hash"
  ],
  "$defs": {
    "hash_or_null": {
      "type": ["string", "null"],
      "minLength": 64,
      "maxLength": 64
    },
    "string_or_null": {
      "type": ["string", "null"]
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.paper_current_truth_refresh_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "exchange": {"type": "string", "minLength": 1},
    "market_type": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "refresh_status": {
      "enum": [
        "PASS_PAPER_CURRENT_TRUTH_REFRESHED",
        "BLOCKED_PAPER_CURRENT_TRUTH_UNAVAILABLE",
        "BLOCKED_UNSUPPORTED_MODE"
      ]
    },
    "refresh_passed": {"type": "boolean"},
    "truth_role": {"const": "paper_current_truth_refresh_not_audited_writer"},
    "source_portfolio_schema_id": {"$ref": "#/$defs/string_or_null"},
    "source_portfolio_snapshot_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_portfolio_snapshot_generated_at_utc": {"$ref": "#/$defs/string_or_null"},
    "source_portfolio_snapshot_status": {"type": "string", "minLength": 1},
    "source_paper_ledger_head_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_runtime_cycle_id": {"$ref": "#/$defs/string_or_null"},
    "verified_currency": {"$ref": "#/$defs/string_or_null"},
    "verified_starting_cash": {"$ref": "#/$defs/string_or_null"},
    "source_heartbeat_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_startup_probe_hash": {"$ref": "#/$defs/hash_or_null"},
    "source_balance_kind": {
      "type": ["string", "null"],
      "enum": ["SIMULATED_PAPER_LEDGER", null]
    },
    "portfolio_refresh_key": {"type": "string", "minLength": 64, "maxLength": 64},
    "verified_cash": {"$ref": "#/$defs/string_or_null"},
    "verified_locked_cash": {"$ref": "#/$defs/string_or_null"},
    "verified_position_market_value": {"$ref": "#/$defs/string_or_null"},
    "verified_equity": {"$ref": "#/$defs/string_or_null"},
    "verified_realized_pnl": {"$ref": "#/$defs/string_or_null"},
    "verified_unrealized_pnl": {"$ref": "#/$defs/string_or_null"},
    "verified_total_pnl": {"$ref": "#/$defs/string_or_null"},
    "verified_return_pct": {"$ref": "#/$defs/string_or_null"},
    "open_position_count": {"type": "integer", "minimum": 0},
    "positions": {"type": "array"},
    "heartbeat_pass": {"type": "boolean"},
    "startup_probe_pass": {"type": "boolean"},
    "paper_only": {"const": true},
    "display_only": {"const": true},
    "dashboard_truth_only": {"const": true},
    "audited_current_evidence_writer": {"const": false},
    "continuous_audited_writer": {"const": false},
    "current_evidence_write_allowed": {"const": false},
    "audited_current_evidence_write_allowed": {"const": false},
    "portfolio_truth_write_allowed": {"const": false},
    "live_ready_write_allowed": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "can_submit_order": {"const": false},
    "scale_up_allowed": {"const": false},
    "primary_blocker_code": {"type": "string", "minLength": 1},
    "operator_next_action": {"type": "string", "minLength": 1},
    "refresh_report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
