{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.profit_optimizer_config.v1",
  "title": "profit_optimizer_config",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "optimizer_config_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "optimizer_stage",
    "objective_basis",
    "objective_components",
    "cost_components",
    "allowed_source_modes",
    "ranking_policy",
    "promotion_policy",
    "resource_budget",
    "live_readiness_status",
    "operator_warning",
    "status",
    "blockers",
    "dashboard_display_truth_only",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "live_config_mutation_allowed",
    "writes_live_ready_snapshot",
    "order_submission_allowed",
    "exchange_account_call_allowed"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.profit_optimizer_config.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "authority": {
      "type": "object",
      "required": [
        "trader1_sha256",
        "agents_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "agents_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "optimizer_config_id": {
      "type": "string",
      "minLength": 1
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "enum": [
        "REPLAY",
        "PAPER",
        "SHADOW",
        "READ_ONLY"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "optimizer_stage": {
      "enum": [
        "MVP4_ANALYSIS_ONLY",
        "MVP4_PAPER_RANKING_ONLY",
        "MVP4_RESEARCH_BLOCKED"
      ]
    },
    "objective_basis": {
      "const": "NET_EV_AFTER_COST"
    },
    "objective_components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "component_id",
          "weight",
          "direction",
          "required"
        ],
        "additionalProperties": false,
        "properties": {
          "component_id": {
            "enum": [
              "NET_EV_AFTER_COST",
              "DRAWDOWN_PENALTY",
              "SLIPPAGE_PENALTY",
              "FEE_PENALTY",
              "SPREAD_PENALTY",
              "IMPACT_PENALTY",
              "LATENCY_PENALTY",
              "OVERFIT_PENALTY",
              "LIQUIDITY_DEPTH_SCORE",
              "REGIME_FIT_SCORE"
            ]
          },
          "weight": {
            "type": "number"
          },
          "direction": {
            "enum": [
              "MAXIMIZE",
              "MINIMIZE"
            ]
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "cost_components": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "FEE",
          "SPREAD",
          "SLIPPAGE",
          "IMPACT",
          "LATENCY"
        ]
      }
    },
    "allowed_source_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "REPLAY",
          "PAPER",
          "SHADOW",
          "READ_ONLY"
        ]
      }
    },
    "ranking_policy": {
      "type": "object",
      "required": [
        "candidate_output_type",
        "sort_key",
        "tie_breakers",
        "ranking_stability_required",
        "min_candidate_count"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_output_type": {
          "const": "CANDIDATE_RANKING_INPUT"
        },
        "sort_key": {
          "const": "NET_EV_AFTER_COST"
        },
        "tie_breakers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "MAX_DRAWDOWN",
              "RANKING_STABILITY",
              "SLIPPAGE_P95",
              "LIQUIDITY_DEPTH",
              "REGIME_FIT"
            ]
          }
        },
        "ranking_stability_required": {
          "const": true
        },
        "min_candidate_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "promotion_policy": {
      "type": "object",
      "required": [
        "live_promotion_allowed",
        "live_ready_snapshot_write_allowed",
        "scale_up_allowed",
        "requires_oos_pass",
        "requires_walk_forward_pass",
        "requires_bootstrap_pass",
        "requires_operator_approval"
      ],
      "additionalProperties": false,
      "properties": {
        "live_promotion_allowed": {
          "const": false
        },
        "live_ready_snapshot_write_allowed": {
          "const": false
        },
        "scale_up_allowed": {
          "const": false
        },
        "requires_oos_pass": {
          "const": true
        },
        "requires_walk_forward_pass": {
          "const": true
        },
        "requires_bootstrap_pass": {
          "const": true
        },
        "requires_operator_approval": {
          "const": true
        }
      }
    },
    "resource_budget": {
      "type": "object",
      "required": [
        "max_candidate_count",
        "max_runtime_seconds",
        "partial_write_recovery_required"
      ],
      "additionalProperties": false,
      "properties": {
        "max_candidate_count": {
          "type": "integer",
          "minimum": 1
        },
        "max_runtime_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "partial_write_recovery_required": {
          "const": true
        }
      }
    },
    "live_readiness_status": {
      "const": "NOT_LIVE_READY"
    },
    "operator_warning": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "SAFE_MODE",
        "FAIL"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "common.defs.schema.json#/$defs/blocker_object"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "dashboard_display_truth_only": {
      "const": true
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "writes_live_ready_snapshot": {
      "const": false
    },
    "order_submission_allowed": {
      "const": false
    },
    "exchange_account_call_allowed": {
      "const": false
    }
  }
}
