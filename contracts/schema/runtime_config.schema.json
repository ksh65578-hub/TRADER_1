{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.runtime_config.v1",
  "title": "runtime_config",
  "type": "object",
  "required": [
    "schema_id",
    "project_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "registry_hash",
    "config_hash",
    "market_type_source",
    "market_type_defaulted",
    "live_entry_enabled",
    "allow_live_credentials",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.runtime_config.v1"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "exchange": {
      "enum": [
        "UPBIT",
        "BINANCE"
      ]
    },
    "market_type": {
      "enum": [
        "KRW_SPOT",
        "SPOT",
        "FUTURES_USDT_M"
      ]
    },
    "mode": {
      "enum": [
        "REPLAY",
        "PAPER",
        "SHADOW",
        "LIVE",
        "SAFE",
        "READ_ONLY"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "market_type_source": {
      "enum": [
        "SAFE_CONFIG_SCHEMA",
        "LAUNCHER_INTERNAL_UI",
        "EXPLICIT_COMMAND_OPTION",
        "NOT_APPLICABLE"
      ]
    },
    "market_type_defaulted": {
      "const": false
    },
    "live_entry_enabled": {
      "const": false
    },
    "allow_live_credentials": {
      "const": false
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    }
  }
}
