{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_persistent_loop_report.v1",
  "title": "upbit_paper_persistent_loop_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "loop_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "loop_mode",
    "requested_cycle_count",
    "completed_cycle_count",
    "max_cycle_count",
    "cycle_results",
    "loop_status",
    "primary_blocker_code",
    "blockers",
    "actual_paper_runtime_executed",
    "recovery_guard_status",
    "recovery_guard_hash",
    "recovery_guard_primary_blocker_code",
    "runtime_recovery_guard_path",
    "paper_ledger_rollup_status",
    "paper_ledger_rollup_hash",
    "paper_ledger_rollup_primary_blocker_code",
    "paper_ledger_rollup_path",
    "paper_runtime_resume_allowed",
    "partial_write_recovery_required",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "data_source_policy",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "loop_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_persistent_loop_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "loop_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "loop_mode": {"const": "BOUNDED_PUBLIC_DATA_PAPER_LOOP"},
    "requested_cycle_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "completed_cycle_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "max_cycle_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "cycle_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cycle_index",
          "collector_id",
          "cycle_id",
          "collection_status",
          "collection_hash",
          "collection_writer_status",
          "runtime_status",
          "runtime_cycle_hash",
          "runtime_writer_status",
          "final_decision",
          "artifact_paths",
          "live_order_ready",
          "live_order_allowed",
          "can_live_trade",
          "scale_up_allowed"
        ],
        "additionalProperties": false,
        "properties": {
          "cycle_index": {"type": "integer", "minimum": 1, "maximum": 20},
          "collector_id": {"type": "string", "minLength": 1},
          "cycle_id": {"type": "string", "minLength": 1},
          "collection_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
          "collection_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
          "collection_writer_status": {"enum": ["PASS", "BLOCKED", "FAIL", "NOT_WRITTEN"]},
          "runtime_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
          "runtime_cycle_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
          "runtime_writer_status": {"enum": ["PASS", "BLOCKED", "FAIL", "NOT_WRITTEN"]},
          "final_decision": {"enum": ["ENTER_LONG", "NO_TRADE", "BLOCKED", "SAFE_MODE", "RECONCILE_REQUIRED"]},
          "artifact_paths": {"type": "array", "items": {"type": "string"}},
          "live_order_ready": {"const": false},
          "live_order_allowed": {"const": false},
          "can_live_trade": {"const": false},
          "scale_up_allowed": {"const": false}
        }
      }
    },
    "loop_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "actual_paper_runtime_executed": {"type": "boolean"},
    "recovery_guard_status": {"enum": ["PASS", "BLOCKED"]},
    "recovery_guard_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "recovery_guard_primary_blocker_code": {"type": ["string", "null"]},
    "runtime_recovery_guard_path": {"type": "string", "minLength": 1},
    "paper_ledger_rollup_status": {"enum": ["PASS", "BLOCKED"]},
    "paper_ledger_rollup_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "paper_ledger_rollup_primary_blocker_code": {"type": ["string", "null"]},
    "paper_ledger_rollup_path": {"type": "string", "minLength": 1},
    "paper_runtime_resume_allowed": {"type": "boolean"},
    "partial_write_recovery_required": {"type": "boolean"},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "data_source_policy": {"const": "PUBLIC_OR_STATIC_FIXTURE_ONLY"},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "loop_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
