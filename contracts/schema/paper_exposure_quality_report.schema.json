{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_exposure_quality_report.v1",
  "title": "paper_exposure_quality_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "exposure_report_id",
    "candidate_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "paper_artifact_path",
    "paper_artifact_hash",
    "source_evidence_ids",
    "portfolio_equity_source",
    "paper_sample_count",
    "min_required_sample_count",
    "gross_exposure_pct",
    "max_allowed_gross_exposure_pct",
    "max_symbol_exposure_pct",
    "max_allowed_symbol_exposure_pct",
    "symbol_concentration_pct",
    "max_allowed_symbol_concentration_pct",
    "drawdown_pct",
    "max_allowed_drawdown_pct",
    "exposure_breach_count",
    "drawdown_breach_count",
    "idempotency_conflict_count",
    "partial_write_recovery_status",
    "risk_quality_status",
    "recommendation",
    "dashboard_display_truth_only",
    "operator_warning",
    "next_operator_action",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "order_adapter_called",
    "exchange_account_call_allowed",
    "live_config_mutation_allowed",
    "primary_blocker_code",
    "blockers",
    "report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.paper_exposure_quality_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "exposure_report_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"$ref": "common.defs.schema.json#/$defs/mode"},
    "session_id": {"type": "string", "minLength": 1},
    "paper_artifact_path": {"type": "string", "minLength": 1},
    "paper_artifact_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "source_evidence_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "portfolio_equity_source": {"enum": ["PAPER_LEDGER", "PAPER_PORTFOLIO_SNAPSHOT", "UNVERIFIED"]},
    "paper_sample_count": {"type": "integer", "minimum": 0},
    "min_required_sample_count": {"type": "integer", "minimum": 1},
    "gross_exposure_pct": {"type": "number", "minimum": 0},
    "max_allowed_gross_exposure_pct": {"type": "number", "minimum": 0},
    "max_symbol_exposure_pct": {"type": "number", "minimum": 0},
    "max_allowed_symbol_exposure_pct": {"type": "number", "minimum": 0},
    "symbol_concentration_pct": {"type": "number", "minimum": 0},
    "max_allowed_symbol_concentration_pct": {"type": "number", "minimum": 0},
    "drawdown_pct": {"type": "number", "minimum": 0},
    "max_allowed_drawdown_pct": {"type": "number", "minimum": 0},
    "exposure_breach_count": {"type": "integer", "minimum": 0},
    "drawdown_breach_count": {"type": "integer", "minimum": 0},
    "idempotency_conflict_count": {"type": "integer", "minimum": 0},
    "partial_write_recovery_status": {"enum": ["PASS", "REPAIRED", "BLOCKED", "UNTESTED"]},
    "risk_quality_status": {
      "enum": [
        "PASS_PAPER_ONLY",
        "INSUFFICIENT_EVIDENCE",
        "BLOCKED_EXPOSURE_BREACH",
        "BLOCKED_DRAWDOWN_BREACH",
        "BLOCKED_RECOVERY_REVIEW"
      ]
    },
    "recommendation": {"enum": ["KEEP_PAPER", "NO_SCALE_UP", "SCALE_DOWN_RECOMMENDED"]},
    "dashboard_display_truth_only": {"const": true},
    "operator_warning": {"type": "string", "minLength": 1},
    "next_operator_action": {"type": "string", "minLength": 1},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "order_adapter_called": {"const": false},
    "exchange_account_call_allowed": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "report_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  }
}
