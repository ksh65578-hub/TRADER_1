{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.strategy_unit.v1",
  "title": "strategy_unit",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "strategy_unit_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "timeframe_scope",
    "regime_scope",
    "risk_profile",
    "signal_intent",
    "signal_strength",
    "strategy_confidence",
    "regime_confidence",
    "source_evidence_ids",
    "strategy_level",
    "paper_live_namespace_separated",
    "exchange_market_type_separated",
    "strategy_order_adapter_called",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "blockers",
    "strategy_unit_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.strategy_unit.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "strategy_unit_id": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"$ref": "common.defs.schema.json#/$defs/mode"},
    "session_id": {"type": "string", "minLength": 1},
    "timeframe_scope": {"type": "string", "minLength": 1},
    "regime_scope": {"type": "string", "minLength": 1},
    "risk_profile": {"$ref": "common.defs.schema.json#/$defs/risk_profile"},
    "signal_intent": {"enum": ["ENTER_LONG", "NO_TRADE"]},
    "signal_strength": {"type": "string"},
    "strategy_confidence": {"type": "string"},
    "regime_confidence": {"type": "string"},
    "source_evidence_ids": {"type": "array", "items": {"type": "string"}},
    "strategy_level": {"enum": ["LEVEL_1_PAPER_DRY_RUN", "LEVEL_2_OPERATIONAL_PAPER"]},
    "paper_live_namespace_separated": {"type": "boolean"},
    "exchange_market_type_separated": {"type": "boolean"},
    "strategy_order_adapter_called": {"type": "boolean"},
    "live_order_ready": {"type": "boolean"},
    "live_order_allowed": {"type": "boolean"},
    "can_live_trade": {"type": "boolean"},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "strategy_unit_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
