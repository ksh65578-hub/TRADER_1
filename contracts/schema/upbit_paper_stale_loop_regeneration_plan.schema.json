{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_stale_loop_regeneration_plan.v1",
  "title": "upbit_paper_stale_loop_regeneration_plan",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "plan_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "plan_role",
    "source_reconciliation_status",
    "source_reconciliation_hash",
    "source_loop_report_count",
    "source_current_accepted_count",
    "source_excluded_count",
    "legacy_schema_drift_count",
    "unsafe_blocked_count",
    "invalid_json_count",
    "duplicate_runtime_cycle_hash_count",
    "regeneration_item_count",
    "operator_review_item_count",
    "duplicate_replacement_path_count",
    "overwrite_or_delete_count",
    "plan_status",
    "primary_blocker_code",
    "stale_loop_blocker_code",
    "safe_regeneration_scope",
    "automatic_regeneration_allowed",
    "operator_confirmation_required_before_execution",
    "delete_source_allowed",
    "overwrite_source_allowed",
    "actual_regeneration_performed",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "items",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "plan_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "plan_item": {
      "type": "object",
      "required": [
        "source_path",
        "source_hash",
        "source_classification",
        "source_loop_id",
        "source_generated_at_utc",
        "source_evidence_usable_current",
        "planned_action",
        "planned_replacement_loop_id",
        "planned_replacement_path",
        "overwrite_source_allowed",
        "delete_source_allowed",
        "automatic_live_or_order_allowed",
        "requires_operator_review",
        "blocking_reason",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "source_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_classification": {
          "enum": [
            "LEGACY_SCHEMA_DRIFT",
            "UNSAFE_BLOCKED",
            "SCOPE_MISMATCH_BLOCKED",
            "UNREADABLE_OR_CORRUPT",
            "RECONCILIATION_REQUIRED"
          ]
        },
        "source_loop_id": {"type": ["string", "null"], "minLength": 1},
        "source_generated_at_utc": {"type": ["string", "null"]},
        "source_evidence_usable_current": {"const": false},
        "planned_action": {
          "enum": [
            "REGENERATE_WITH_CURRENT_SCHEMA_AS_NEW_ARTIFACT",
            "OPERATOR_REVIEW_REQUIRED",
            "RETAIN_EXCLUDED_REFERENCE"
          ]
        },
        "planned_replacement_loop_id": {"type": ["string", "null"], "minLength": 1},
        "planned_replacement_path": {"type": ["string", "null"], "minLength": 1},
        "overwrite_source_allowed": {"const": false},
        "delete_source_allowed": {"const": false},
        "automatic_live_or_order_allowed": {"const": false},
        "requires_operator_review": {"type": "boolean"},
        "blocking_reason": {"type": ["string", "null"]},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_stale_loop_regeneration_plan.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "plan_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "plan_role": {"const": "PAPER_RUNTIME_STALE_LOOP_REGENERATION_PLAN_NOT_EXECUTION"},
    "source_reconciliation_status": {"enum": ["PASS", "BLOCKED"]},
    "source_reconciliation_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "source_loop_report_count": {"type": "integer", "minimum": 0},
    "source_current_accepted_count": {"type": "integer", "minimum": 0},
    "source_excluded_count": {"type": "integer", "minimum": 0},
    "legacy_schema_drift_count": {"type": "integer", "minimum": 0},
    "unsafe_blocked_count": {"type": "integer", "minimum": 0},
    "invalid_json_count": {"type": "integer", "minimum": 0},
    "duplicate_runtime_cycle_hash_count": {"type": "integer", "minimum": 0},
    "regeneration_item_count": {"type": "integer", "minimum": 0},
    "operator_review_item_count": {"type": "integer", "minimum": 0},
    "duplicate_replacement_path_count": {"type": "integer", "minimum": 0},
    "overwrite_or_delete_count": {"type": "integer", "minimum": 0},
    "plan_status": {"enum": ["READY_FOR_SAFE_PAPER_REGENERATION", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "stale_loop_blocker_code": {"const": "STALE_PERSISTENT_LOOP_REPORTS_REQUIRE_RECONCILIATION"},
    "safe_regeneration_scope": {"const": "UPBIT_KRW_SPOT_PAPER_PUBLIC_OR_STATIC_DATA_ONLY"},
    "automatic_regeneration_allowed": {"const": false},
    "operator_confirmation_required_before_execution": {"const": false},
    "delete_source_allowed": {"const": false},
    "overwrite_source_allowed": {"const": false},
    "actual_regeneration_performed": {"const": false},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "items": {"type": "array", "items": {"$ref": "#/$defs/plan_item"}},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "plan_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
