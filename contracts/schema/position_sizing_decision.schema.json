{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.position_sizing_decision.v1",
  "title": "position_sizing_decision",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "sizing_decision_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "strategy_unit_id",
    "inputs",
    "caps",
    "selected_notional",
    "sizing_status",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "sizing_decision_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.position_sizing_decision.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "sizing_decision_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"$ref": "common.defs.schema.json#/$defs/mode"},
    "session_id": {"type": "string", "minLength": 1},
    "strategy_unit_id": {"type": "string", "minLength": 1},
    "inputs": {"type": "object"},
    "caps": {"type": "object"},
    "selected_notional": {"type": "string"},
    "sizing_status": {"enum": ["PASS", "BLOCKED"]},
    "live_order_ready": {"type": "boolean"},
    "live_order_allowed": {"type": "boolean"},
    "can_live_trade": {"type": "boolean"},
    "can_submit_order": {"type": "boolean"},
    "order_adapter_called": {"type": "boolean"},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "sizing_decision_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
