        "source_path": {"type": "string", "minLength": 1},
        "replacement_path": {"type": "string", "minLength": 1},
        "closure_lane": {
          "enum": [
            "LEDGER_RECHECK_READY",
            "RECOVERY_GUARD_REQUIRED",
            "RUNTIME_CYCLE_RERUN_REQUIRED",
            "OPERATOR_REVIEW_REQUIRED",
            "UNSAFE_OR_SCOPE_BLOCKED"
