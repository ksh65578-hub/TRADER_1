        "replacement_path_exists": {"type": "boolean"},
        "replacement_validation_status": {"enum": ["PASS", "BLOCKED", "FAIL", "MISSING"]},
        "replacement_validation_blocker_code": {"type": ["string", "null"]},
        "replacement_validation_message": {"type": "string", "minLength": 1},
        "ledger_binding_status": {"enum": ["PASS", "BLOCKED", "NOT_APPLICABLE"]},
        "ledger_head_hash_match": {"type": "boolean"},
        "ledger_rollup_hash_match": {"type": "boolean"},
