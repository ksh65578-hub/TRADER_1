        "current_ledger_rollup_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "preview_item_status": {
          "enum": [
            "PASS_PREVIEW_ONLY",
            "BLOCKED",
            "SKIPPED_RECOVERY_REQUIRED",
            "SKIPPED_OPERATOR_REVIEW"
          ]
        },
        "primary_blocker_code": {"type": ["string", "null"]},
        "blocker_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "operator_action": {"type": "string", "minLength": 1},
