{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_stale_loop_regeneration_execution_guard.v1",
  "title": "upbit_paper_stale_loop_regeneration_execution_guard",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "guard_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "guard_role",
    "source_plan_hash",
    "source_plan_status",
    "planned_regeneration_item_count",
    "operator_review_item_count",
    "duplicate_replacement_path_count",
    "replacement_existing_count",
    "source_hash_mismatch_count",
    "source_missing_count",
    "guard_status",
    "primary_blocker_code",
    "blocker_codes",
    "paper_regeneration_preconditions_passed",
    "separate_safe_executor_required",
    "replacement_write_mode",
    "source_retention_required",
    "items",
    "delete_source_allowed",
    "overwrite_source_allowed",
    "execution_performed",
    "actual_regeneration_performed",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "guard_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "guard_item": {
      "type": "object",
      "required": [
        "source_path",
        "source_hash_expected",
        "source_hash_actual",
        "source_hash_match",
        "source_path_scope_status",
        "source_exists",
        "planned_replacement_loop_id",
        "planned_replacement_path",
        "replacement_path_scope_status",
        "replacement_path_exists",
        "replacement_parent_exists",
        "replacement_write_mode",
        "planned_action",
        "guard_item_status",
        "blocker_code",
        "delete_source_allowed",
        "overwrite_source_allowed",
        "execution_performed",
        "actual_long_run_evidence_created",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "source_hash_expected": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_hash_actual": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_hash_match": {"type": "boolean"},
        "source_path_scope_status": {"enum": ["MATCH", "MISMATCH"]},
        "source_exists": {"type": "boolean"},
        "planned_replacement_loop_id": {"type": ["string", "null"], "minLength": 1},
        "planned_replacement_path": {"type": ["string", "null"], "minLength": 1},
        "replacement_path_scope_status": {"enum": ["MATCH", "MISMATCH"]},
        "replacement_path_exists": {"type": "boolean"},
        "replacement_parent_exists": {"type": "boolean"},
        "replacement_write_mode": {"const": "CREATE_NEW_ONLY"},
        "planned_action": {
          "enum": [
            "REGENERATE_WITH_CURRENT_SCHEMA_AS_NEW_ARTIFACT",
            "OPERATOR_REVIEW_REQUIRED",
            "RETAIN_EXCLUDED_REFERENCE"
          ]
        },
        "guard_item_status": {"enum": ["PASS", "BLOCKED"]},
        "blocker_code": {"type": ["string", "null"]},
        "delete_source_allowed": {"const": false},
        "overwrite_source_allowed": {"const": false},
        "execution_performed": {"const": false},
        "actual_long_run_evidence_created": {"const": false},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_stale_loop_regeneration_execution_guard.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "guard_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "guard_role": {"const": "PAPER_RUNTIME_STALE_LOOP_REGENERATION_EXECUTION_GUARD_NOT_EXECUTION"},
    "source_plan_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "source_plan_status": {"enum": ["READY_FOR_SAFE_PAPER_REGENERATION", "BLOCKED", null]},
    "planned_regeneration_item_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "operator_review_item_count": {"type": "integer", "minimum": 0},
    "duplicate_replacement_path_count": {"type": "integer", "minimum": 0},
    "replacement_existing_count": {"type": "integer", "minimum": 0},
    "source_hash_mismatch_count": {"type": "integer", "minimum": 0},
    "source_missing_count": {"type": "integer", "minimum": 0},
    "guard_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blocker_codes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "paper_regeneration_preconditions_passed": {"type": "boolean"},
    "separate_safe_executor_required": {"const": true},
    "replacement_write_mode": {"const": "CREATE_NEW_ONLY"},
    "source_retention_required": {"const": true},
    "items": {"type": "array", "items": {"$ref": "#/$defs/guard_item"}},
    "delete_source_allowed": {"const": false},
    "overwrite_source_allowed": {"const": false},
    "execution_performed": {"const": false},
    "actual_regeneration_performed": {"const": false},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "guard_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
