{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_public_market_data_collection_report.v1",
  "title": "upbit_public_market_data_collection_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "collector_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "collector_mode",
    "data_source",
    "public_market_data",
    "raw_sample_count",
    "canonical_event_count",
    "canonical_events",
    "collection_status",
    "primary_blocker_code",
    "blockers",
    "private_account_fields_present",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "collection_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_public_market_data_collection_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "collector_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "collector_mode": {"const": "PUBLIC_MARKET_DATA_ONLY"},
    "data_source": {"enum": ["STATIC_FIXTURE", "PUBLIC_REST_READ_ONLY", "UNAVAILABLE"]},
    "public_market_data": {"type": "object"},
    "raw_sample_count": {"type": "integer", "minimum": 0},
    "canonical_event_count": {"type": "integer", "minimum": 0},
    "canonical_events": {"type": "array", "items": {"type": "object"}},
    "collection_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "private_account_fields_present": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "collection_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
