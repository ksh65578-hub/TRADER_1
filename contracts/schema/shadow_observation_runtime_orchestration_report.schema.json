{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.shadow_observation_runtime_orchestration_report.v1",
  "title": "TRADER_1 Shadow Observation Runtime Orchestration Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "orchestration_id",
    "exchange",
    "market_type",
    "source_mode",
    "mode",
    "session_id",
    "orchestration_artifact_path",
    "orchestration_status",
    "orchestration_decision",
    "source_validation_status",
    "source_hashes_verified",
    "source_runtime_hash_pairing_verified",
    "source_scope_match",
    "source_binding_count",
    "source_evidence_bindings",
    "persistent_stub_not_long_run_confirmed",
    "short_window_harness_not_long_run_confirmed",
    "minimum_runtime_window_seconds",
    "observed_actual_runtime_seconds",
    "minimum_actual_cycle_count",
    "observed_actual_cycle_count",
    "minimum_evidence_window_count",
    "observed_evidence_window_count",
    "actual_long_run_runtime_present",
    "long_run_evidence_eligible",
    "scorecard_input_eligible",
    "optimizer_ranking_action",
    "runtime_evidence_role",
    "dashboard_display_truth_only",
    "dashboard_visibility_status",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "operator_message",
    "next_operator_action",
    "orchestration_report_hash"
  ],
  "properties": {
    "schema_id": {"const": "trader1.shadow_observation_runtime_orchestration_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "orchestration_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "source_mode": {"const": "PAPER"},
    "mode": {"const": "SHADOW"},
    "session_id": {"type": "string", "minLength": 1},
    "orchestration_artifact_path": {
      "type": "string",
      "pattern": "^system/runtime/upbit/krw_spot/shadow/.+runtime_orchestration_report\\.json$"
    },
    "orchestration_status": {"const": "BLOCKED"},
    "orchestration_decision": {"const": "BLOCK_LONG_RUN_EVIDENCE"},
    "source_validation_status": {"enum": ["PASS", "BLOCKED"]},
    "source_hashes_verified": {"type": "boolean"},
    "source_runtime_hash_pairing_verified": {"type": "boolean"},
    "source_scope_match": {"type": "boolean"},
    "source_binding_count": {"type": "integer", "minimum": 0},
    "source_evidence_bindings": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": [
          "source_role",
          "source_id",
          "source_hash",
          "hash_verified",
          "validation_status",
          "evidence_role"
        ],
        "additionalProperties": false,
        "properties": {
          "source_role": {"enum": ["PERSISTENT_RUNTIME_STUB", "PERSISTENT_RUNTIME_SHORT_WINDOW", "SHORT_WINDOW_HARNESS"]},
          "source_id": {"type": "string", "minLength": 1},
          "source_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
          "hash_verified": {"type": "boolean"},
          "validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
          "evidence_role": {
            "enum": [
              "PERSISTENT_RUNTIME_STUB_ONLY",
              "PERSISTENT_RUNTIME_SHORT_WINDOW_ONLY",
              "EXECUTION_HARNESS_PROOF_ONLY_NOT_LONG_RUN"
            ]
          }
        }
      }
    },
    "persistent_stub_not_long_run_confirmed": {"type": "boolean"},
    "short_window_harness_not_long_run_confirmed": {"type": "boolean"},
    "minimum_runtime_window_seconds": {"type": "integer", "minimum": 86400},
    "observed_actual_runtime_seconds": {"type": "integer", "minimum": 0},
    "minimum_actual_cycle_count": {"type": "integer", "minimum": 2880},
    "observed_actual_cycle_count": {"type": "integer", "minimum": 0},
    "minimum_evidence_window_count": {"type": "integer", "minimum": 20},
    "observed_evidence_window_count": {"const": 0},
    "actual_long_run_runtime_present": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "scorecard_input_eligible": {"const": false},
    "optimizer_ranking_action": {"const": "BLOCK_RANKING"},
    "runtime_evidence_role": {"const": "ORCHESTRATION_BLOCKER_ONLY_NOT_LONG_RUN"},
    "dashboard_display_truth_only": {"const": true},
    "dashboard_visibility_status": {"const": "VISIBLE_AS_BLOCKED_LONG_RUN_REQUIREMENTS"},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "order_adapter_called": {"const": false},
    "primary_blocker_code": {"$ref": "common.defs.schema.json#/$defs/live_blocker_code"},
    "blockers": {"type": "array", "minItems": 1, "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "operator_message": {"type": "string", "minLength": 1},
    "next_operator_action": {"type": "string", "minLength": 1},
    "orchestration_report_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  }
}
