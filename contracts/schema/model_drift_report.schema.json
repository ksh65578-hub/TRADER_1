{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.model_drift_report.v1",
  "title": "model_drift_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "model_drift_report_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "timeframe_scope",
    "regime_scope",
    "source_modes",
    "source_evidence_ids",
    "baseline_window_id",
    "evaluation_window_id",
    "baseline_sample_count",
    "evaluation_sample_count",
    "min_required_sample_count",
    "baseline_metric_hash",
    "evaluation_metric_hash",
    "drift_status",
    "drift_score",
    "max_allowed_drift_score",
    "feature_drift_score",
    "performance_drift_score",
    "execution_drift_score",
    "oos_status",
    "walk_forward_status",
    "bootstrap_status",
    "data_freshness_status",
    "data_age_seconds",
    "max_data_age_seconds",
    "convergence_claim_before",
    "convergence_claim_after",
    "model_promotion_allowed",
    "scale_up_recommendation_allowed",
    "blocks_promotion",
    "blocks_live_order",
    "dashboard_display_truth_only",
    "operator_warning",
    "next_operator_action",
    "live_permission_created",
    "live_config_mutation_allowed",
    "writes_live_ready_snapshot",
    "active_snapshot_mutation_allowed",
    "optimizer_winner_live_config_allowed",
    "paper_winner_live_config_allowed",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "blockers",
    "model_drift_report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.model_drift_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "model_drift_report_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"enum": ["REPLAY", "PAPER", "SHADOW", "SAFE", "READ_ONLY"]},
    "session_id": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "timeframe_scope": {"type": "string", "minLength": 1},
    "regime_scope": {"type": "string", "minLength": 1},
    "source_modes": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["REPLAY", "PAPER", "SHADOW", "READ_ONLY"]}
    },
    "source_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "baseline_window_id": {"type": "string", "minLength": 1},
    "evaluation_window_id": {"type": "string", "minLength": 1},
    "baseline_sample_count": {"type": "integer", "minimum": 0},
    "evaluation_sample_count": {"type": "integer", "minimum": 0},
    "min_required_sample_count": {"type": "integer", "minimum": 1},
    "baseline_metric_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "evaluation_metric_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "drift_status": {
      "enum": ["NOT_EVALUATED", "NO_DRIFT", "DRIFT_SUSPECTED", "DRIFT_DETECTED", "BLOCKED"]
    },
    "drift_score": {"type": "number", "minimum": 0},
    "max_allowed_drift_score": {"type": "number", "minimum": 0},
    "feature_drift_score": {"type": "number", "minimum": 0},
    "performance_drift_score": {"type": "number", "minimum": 0},
    "execution_drift_score": {"type": "number", "minimum": 0},
    "oos_status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNTESTED", "STALE", "TIMEOUT"]},
    "walk_forward_status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNTESTED", "STALE", "TIMEOUT"]},
    "bootstrap_status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNTESTED", "STALE", "TIMEOUT"]},
    "data_freshness_status": {"enum": ["FRESH", "STALE", "MISSING"]},
    "data_age_seconds": {"type": "number", "minimum": 0},
    "max_data_age_seconds": {"type": "number", "minimum": 0},
    "convergence_claim_before": {
      "enum": ["NO_CLAIM", "LOCALLY_IMPROVING", "ROBUSTLY_IMPROVING", "WRITER_INPUT_ELIGIBLE", "BLOCKED"]
    },
    "convergence_claim_after": {
      "enum": ["NO_CLAIM", "LOCALLY_IMPROVING", "ROBUSTLY_IMPROVING", "WRITER_INPUT_ELIGIBLE", "BLOCKED"]
    },
    "model_promotion_allowed": {"const": false},
    "scale_up_recommendation_allowed": {"const": false},
    "blocks_promotion": {"type": "boolean"},
    "blocks_live_order": {"const": true},
    "dashboard_display_truth_only": {"const": true},
    "operator_warning": {"type": "string", "minLength": 1},
    "next_operator_action": {"type": "string", "minLength": 1},
    "live_permission_created": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "writes_live_ready_snapshot": {"const": false},
    "active_snapshot_mutation_allowed": {"const": false},
    "optimizer_winner_live_config_allowed": {"const": false},
    "paper_winner_live_config_allowed": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "blockers": {
      "type": "array",
      "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}
    },
    "model_drift_report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
