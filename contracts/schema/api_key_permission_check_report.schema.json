{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.api_key_permission_check_report.v1",
  "title": "api_key_permission_check_report",
  "type": "object",
  "required": [
    "schema_id",
    "permission_check_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "exchange",
    "market_type",
    "mode",
    "api_key_id_hash",
    "api_key_present",
    "read_permission_verified",
    "trade_permission_detected",
    "withdrawal_permission_detected",
    "permission_check_status",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "permission_check_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.api_key_permission_check_report.v1"
    },
    "permission_check_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "authority": {
      "type": "object",
      "required": [
        "trader1_sha256",
        "agents_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "agents_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "const": "READ_ONLY"
    },
    "api_key_id_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "api_key_present": {
      "type": "boolean"
    },
    "read_permission_verified": {
      "type": "boolean"
    },
    "trade_permission_detected": {
      "type": "boolean"
    },
    "withdrawal_permission_detected": {
      "type": "boolean"
    },
    "permission_check_status": {
      "enum": [
        "PASS",
        "BLOCKED",
        "UNVERIFIED"
      ]
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "order_adapter_called": {
      "const": false
    },
    "primary_blocker_code": {
      "$ref": "common.defs.schema.json#/$defs/live_blocker_code"
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "common.defs.schema.json#/$defs/blocker_object"
      }
    },
    "permission_check_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
