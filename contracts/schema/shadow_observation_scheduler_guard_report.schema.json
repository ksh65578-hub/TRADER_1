{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.shadow_observation_scheduler_guard_report.v1",
  "title": "shadow_observation_scheduler_guard_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "scheduler_id",
    "stream_id",
    "exchange",
    "market_type",
    "source_mode",
    "mode",
    "scheduler_artifact_path",
    "writer_id",
    "active_writer_id",
    "lock_acquired",
    "lock_owner_match",
    "concurrent_writer_detected",
    "lock_lease_seconds",
    "lock_lease_fresh",
    "lock_lease_status",
    "source_stream_hash",
    "persisted_stream_hash",
    "persisted_stream_hash_match",
    "source_stream_status",
    "source_stream_validation_status",
    "observation_count",
    "last_committed_sequence",
    "expected_next_sequence_number",
    "next_sequence_number",
    "sequence_gap_detected",
    "partial_temp_artifact_count",
    "partial_write_recovery_status",
    "recovery_action",
    "scheduler_status",
    "run_action",
    "optimizer_input_role",
    "dashboard_display_truth_only",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "order_adapter_called",
    "primary_blocker_code",
    "blockers",
    "scheduler_guard_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.shadow_observation_scheduler_guard_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "scheduler_id": {"type": "string", "minLength": 1},
    "stream_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "source_mode": {"const": "PAPER"},
    "mode": {"const": "SHADOW"},
    "scheduler_artifact_path": {"type": "string", "minLength": 1},
    "writer_id": {"type": "string", "minLength": 1},
    "active_writer_id": {"type": "string", "minLength": 1},
    "lock_acquired": {"type": "boolean"},
    "lock_owner_match": {"type": "boolean"},
    "concurrent_writer_detected": {"type": "boolean"},
    "lock_lease_seconds": {"type": "integer", "minimum": 1},
    "lock_lease_fresh": {"type": "boolean"},
    "lock_lease_status": {"enum": ["PASS", "BLOCKED"]},
    "source_stream_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "persisted_stream_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "persisted_stream_hash_match": {"type": "boolean"},
    "source_stream_status": {"enum": ["PASS", "BLOCKED", "FAIL", "UNKNOWN"]},
    "source_stream_validation_status": {"$ref": "common.defs.schema.json#/$defs/validator_status"},
    "observation_count": {"type": "integer", "minimum": 0},
    "last_committed_sequence": {"type": "integer", "minimum": 0},
    "expected_next_sequence_number": {"type": "integer", "minimum": 1},
    "next_sequence_number": {"type": "integer", "minimum": 1},
    "sequence_gap_detected": {"type": "boolean"},
    "partial_temp_artifact_count": {"type": "integer", "minimum": 0},
    "partial_write_recovery_status": {"enum": ["PASS", "BLOCKED"]},
    "recovery_action": {"enum": ["NO_RECOVERY_NEEDED", "RECONCILE_REQUIRED"]},
    "scheduler_status": {"enum": ["PASS", "BLOCKED", "FAIL"]},
    "run_action": {"enum": ["APPEND_SHADOW_OBSERVATION_ONLY", "BLOCKED"]},
    "optimizer_input_role": {"const": "SHADOW_SCHEDULER_GUARD_ONLY"},
    "dashboard_display_truth_only": {"const": true},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "order_adapter_called": {"const": false},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "scheduler_guard_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  }
}
