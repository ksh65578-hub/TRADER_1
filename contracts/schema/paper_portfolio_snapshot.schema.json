{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.paper_portfolio_snapshot.v1",
  "title": "paper_portfolio_snapshot",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "source_runtime_cycle_id",
    "source_paper_ledger_head_hash",
    "snapshot_status",
    "source",
    "starting_cash_source",
    "currency",
    "starting_cash",
    "cash_available",
    "locked_balance",
    "position_market_value",
    "equity",
    "realized_pnl",
    "unrealized_pnl",
    "total_pnl",
    "return_pct",
    "open_position_count",
    "positions",
    "paper_only",
    "display_balance_kind",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "can_submit_order",
    "primary_blocker_code",
    "blockers",
    "snapshot_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "decimal_string": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
    },
    "blocker": {
      "type": "object",
      "required": [
        "code",
        "severity",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "common.defs.schema.json#/$defs/live_blocker_code"
        },
        "severity": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "position": {
      "type": "object",
      "required": [
        "symbol",
        "side",
        "quantity",
        "average_entry_price",
        "mark_price",
        "cost_basis",
        "market_value",
        "unrealized_pnl",
        "source",
        "paper_only"
      ],
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "const": "LONG"
        },
        "quantity": {
          "$ref": "#/$defs/decimal_string"
        },
        "average_entry_price": {
          "$ref": "#/$defs/decimal_string"
        },
        "mark_price": {
          "$ref": "#/$defs/decimal_string"
        },
        "cost_basis": {
          "$ref": "#/$defs/decimal_string"
        },
        "market_value": {
          "$ref": "#/$defs/decimal_string"
        },
        "unrealized_pnl": {
          "$ref": "#/$defs/decimal_string"
        },
        "source": {
          "enum": [
            "PAPER_LEDGER_SCAFFOLD",
            "PAPER_LEDGER_ROLLUP",
            "PAPER_LEDGER_ROLLUP_PUBLIC_MARK"
          ]
        },
        "mark_price_source": {
          "type": "string",
          "minLength": 1
        },
        "source_public_market_event_time_utc": {
          "type": "string",
          "minLength": 1
        },
        "source_public_market_event_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "price_basis_repair_status": {
          "type": "string",
          "minLength": 1
        },
        "price_basis_repair_source": {
          "type": "string",
          "minLength": 1
        },
        "price_basis_original_quantity": {
          "$ref": "#/$defs/decimal_string"
        },
        "price_basis_original_average_entry_price": {
          "$ref": "#/$defs/decimal_string"
        },
        "price_basis_original_gross_entry_cost": {
          "$ref": "#/$defs/decimal_string"
        },
        "price_basis_scale_factor": {
          "$ref": "#/$defs/decimal_string"
        },
        "price_basis_normalized_quantity": {
          "$ref": "#/$defs/decimal_string"
        },
        "price_basis_normalized_average_entry_price": {
          "$ref": "#/$defs/decimal_string"
        },
        "entry_strategy_context_status": {
          "const": "BOUND_TO_ENTRY_CANDIDATE"
        },
        "entry_strategy_context_source": {
          "const": "PAPER_RUNTIME_ENTRY_FILL"
        },
        "entry_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "entry_strategy_family": {
          "enum": [
            "PULLBACK_TREND_LONG",
            "VWAP_MEAN_REVERSION",
            "BREAKOUT_RETEST_LONG"
          ]
        },
        "entry_strategy_exit_policy_id": {
          "const": "UPBIT_KRW_SPOT_STRATEGY_EXIT_ROUTER_V1"
        },
        "entry_strategy_exit_variation": {
          "enum": [
            "trailing_tp",
            "fixed_tp",
            "invalidation_exit"
          ]
        },
        "entry_strategy_source_runtime_cycle_id": {
          "type": "string",
          "minLength": 1
        },
        "entry_strategy_source_candidate_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "entry_strategy_source_exit_plan_hash": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "entry_strategy_context_formula": {
          "type": "string",
          "minLength": 1
        },
        "paper_only": {
          "const": true
        }
      }
    }
  },
  "properties": {
    "schema_id": {
      "const": "trader1.paper_portfolio_snapshot.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "const": "PAPER"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "source_runtime_cycle_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_paper_ledger_head_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 64,
      "maxLength": 64
    },
    "snapshot_status": {
      "enum": [
        "PASS",
        "BLOCKED"
      ]
    },
    "source": {
      "enum": [
        "PAPER_LEDGER_SCAFFOLD",
        "PAPER_LEDGER_ROLLUP",
        "PAPER_LEDGER_ROLLUP_PUBLIC_MARK"
      ]
    },
    "mark_to_market_status": {
      "enum": [
        "PASS_PUBLIC_MARK_TO_MARKET",
        "NOT_REQUIRED_NO_POSITION",
        "BLOCKED_PUBLIC_MARK_UNAVAILABLE"
      ]
    },
    "mark_price_source": {
      "type": "string",
      "minLength": 1
    },
    "source_public_market_data_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 64,
      "maxLength": 64
    },
    "source_public_market_data_generated_at_utc": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_public_market_event_time_utc": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_public_market_event_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 64,
      "maxLength": 64
    },
    "source_public_market_symbol_count": {
      "type": "integer",
      "minimum": 0
    },
    "marked_to_market_position_count": {
      "type": "integer",
      "minimum": 0
    },
    "mark_to_market_blocker_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "price_basis_repair_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "price_basis_repair_count": {
      "type": "integer",
      "minimum": 0
    },
    "price_basis_repair_source": {
      "type": [
        "string",
        "null"
      ]
    },
    "starting_cash_source": {
      "const": "MVP_PAPER_DEFAULT_NOT_LIVE_ACCOUNT"
    },
    "currency": {
      "enum": [
        "KRW",
        "USDT",
        "UNKNOWN"
      ]
    },
    "starting_cash": {
      "$ref": "#/$defs/decimal_string"
    },
    "cash_available": {
      "$ref": "#/$defs/decimal_string"
    },
    "locked_balance": {
      "$ref": "#/$defs/decimal_string"
    },
    "position_market_value": {
      "$ref": "#/$defs/decimal_string"
    },
    "equity": {
      "$ref": "#/$defs/decimal_string"
    },
    "realized_pnl": {
      "$ref": "#/$defs/decimal_string"
    },
    "unrealized_pnl": {
      "$ref": "#/$defs/decimal_string"
    },
    "total_pnl": {
      "$ref": "#/$defs/decimal_string"
    },
    "return_pct": {
      "$ref": "#/$defs/decimal_string"
    },
    "open_position_count": {
      "type": "integer",
      "minimum": 0
    },
    "positions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/position"
      }
    },
    "paper_only": {
      "const": true
    },
    "display_balance_kind": {
      "const": "SIMULATED_PAPER_LEDGER"
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "can_submit_order": {
      "const": false
    },
    "primary_blocker_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "snapshot_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    }
  }
}
