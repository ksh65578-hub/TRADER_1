{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.market_regime_adaptation_report.v1",
  "title": "market_regime_adaptation_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "adaptation_report_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "symbol",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "timeframe_scope",
    "regime_scope",
    "previous_regime_family",
    "current_regime_family",
    "current_trend_direction",
    "adaptation_signal",
    "adaptation_status",
    "recommended_action",
    "entry_allowed",
    "primary_blocker_code",
    "source_modes",
    "source_evidence_ids",
    "source_artifact_roles",
    "data_freshness_status",
    "data_age_seconds",
    "max_data_age_seconds",
    "timeframe_scope_confirmed",
    "regime_scope_confirmed",
    "symbol_strategy_regime_fit_validator_status",
    "strategy_condition_matrix_validator_status",
    "strategy_performance_memory_validator_status",
    "official_api_verification_status",
    "live_observation_used",
    "read_only_live_observation_allowed",
    "recommended_strategy_families",
    "blocked_strategy_families",
    "operator_warning",
    "next_operator_action",
    "dashboard_display_truth_only",
    "execution_truth_created",
    "promotion_eligible",
    "blocks_live_order",
    "live_permission_created",
    "live_config_mutation_allowed",
    "writes_live_ready_snapshot",
    "active_snapshot_mutation_allowed",
    "optimizer_winner_live_config_allowed",
    "paper_winner_live_config_allowed",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "blockers",
    "adaptation_report_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.market_regime_adaptation_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "authority": {
      "type": "object",
      "required": ["trader1_sha256", "agents_sha256"],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
        "agents_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
      }
    },
    "adaptation_report_id": {"type": "string", "minLength": 1},
    "exchange": {"$ref": "common.defs.schema.json#/$defs/exchange"},
    "market_type": {"$ref": "common.defs.schema.json#/$defs/market_type"},
    "mode": {"enum": ["REPLAY", "PAPER", "SHADOW", "SAFE", "READ_ONLY"]},
    "session_id": {"type": "string", "minLength": 1},
    "symbol": {"type": "string", "minLength": 1},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_build_id": {"type": "string", "minLength": 1},
    "parameter_hash": {"type": "string", "minLength": 64, "maxLength": 64},
    "timeframe_scope": {"type": "string", "minLength": 1},
    "regime_scope": {"type": "string", "minLength": 1},
    "previous_regime_family": {"enum": ["TRENDING", "RANGE", "RISK_OFF"]},
    "current_regime_family": {"enum": ["TRENDING", "RANGE", "RISK_OFF"]},
    "current_trend_direction": {"enum": ["UPTREND", "RANGE", "DOWNTREND", "RISK_OFF"]},
    "adaptation_signal": {"enum": ["NO_SIGNAL", "REGIME_SHIFT", "VOLATILITY_SHIFT", "LIQUIDITY_SHIFT", "DATA_STALE"]},
    "adaptation_status": {"enum": ["STABLE", "ADAPTATION_RECOMMENDED", "BLOCKED_SAFE_MODE"]},
    "recommended_action": {"enum": ["KEEP_CURRENT_RESEARCH_SCOPE", "ADAPT_REGIME_SCOPE", "BLOCK_ENTRY", "SAFE_MODE"]},
    "entry_allowed": {"type": "boolean"},
    "primary_blocker_code": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "common.defs.schema.json#/$defs/no_trade_reason"}
      ]
    },
    "source_modes": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["REPLAY", "PAPER", "SHADOW", "READ_ONLY"]}
    },
    "source_evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "source_artifact_roles": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["role", "artifact_id"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "enum": [
              "MARKET_DATA_FRESHNESS",
              "SYMBOL_STRATEGY_REGIME_FIT",
              "STRATEGY_CONDITION_MATRIX",
              "STRATEGY_PERFORMANCE_MEMORY",
              "PAPER_SHADOW_EVIDENCE"
            ]
          },
          "artifact_id": {"type": "string", "minLength": 1}
        }
      }
    },
    "data_freshness_status": {"enum": ["FRESH", "STALE", "MISSING"]},
    "data_age_seconds": {"type": "number", "minimum": 0},
    "max_data_age_seconds": {"type": "number", "minimum": 0},
    "timeframe_scope_confirmed": {"const": true},
    "regime_scope_confirmed": {"const": true},
    "symbol_strategy_regime_fit_validator_status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNTESTED", "STALE", "TIMEOUT"]},
    "strategy_condition_matrix_validator_status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNTESTED", "STALE", "TIMEOUT"]},
    "strategy_performance_memory_validator_status": {"enum": ["PASS", "FAIL", "BLOCKED", "UNTESTED", "STALE", "TIMEOUT"]},
    "official_api_verification_status": {"enum": ["NOT_USED", "PASS", "FAIL", "STALE", "MISSING"]},
    "live_observation_used": {"const": false},
    "read_only_live_observation_allowed": {"const": false},
    "recommended_strategy_families": {
      "type": "array",
      "items": {"enum": ["VWAP_REVERSION", "TREND_PULLBACK", "BREAKOUT_RETEST"]}
    },
    "blocked_strategy_families": {
      "type": "array",
      "items": {"enum": ["VWAP_REVERSION", "TREND_PULLBACK", "BREAKOUT_RETEST"]}
    },
    "operator_warning": {"type": "string", "minLength": 1},
    "next_operator_action": {"type": "string", "minLength": 1},
    "dashboard_display_truth_only": {"const": true},
    "execution_truth_created": {"const": false},
    "promotion_eligible": {"const": false},
    "blocks_live_order": {"const": true},
    "live_permission_created": {"const": false},
    "live_config_mutation_allowed": {"const": false},
    "writes_live_ready_snapshot": {"const": false},
    "active_snapshot_mutation_allowed": {"const": false},
    "optimizer_winner_live_config_allowed": {"const": false},
    "paper_winner_live_config_allowed": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "blockers": {
      "type": "array",
      "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}
    },
    "adaptation_report_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
