{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_stale_loop_reconciliation_report.v1",
  "title": "upbit_paper_stale_loop_reconciliation_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "reconciliation_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "truth_role",
    "reconciliation_role",
    "evidence_use_policy",
    "source_loop_report_count",
    "current_accepted_count",
    "legacy_schema_drift_count",
    "unsafe_blocked_count",
    "invalid_json_count",
    "duplicate_runtime_cycle_hash_count",
    "current_evidence_usable_count",
    "legacy_reference_retained_count",
    "excluded_from_current_evidence_count",
    "reconciliation_status",
    "primary_blocker_code",
    "items",
    "delete_performed",
    "safe_delete_allowed",
    "operator_next_action",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "reconciliation_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "reconciliation_item": {
      "type": "object",
      "required": [
        "source_path",
        "source_hash",
        "loop_id",
        "generated_at_utc",
        "scope_status",
        "current_validator_status",
        "current_validator_blocker_code",
        "current_validator_message",
        "classification",
        "evidence_usable_current",
        "recommended_action",
        "missing_current_required_fields",
        "runtime_cycle_hashes",
        "unsafe_live_or_order_flag_detected",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "source_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "loop_id": {"type": ["string", "null"], "minLength": 1},
        "generated_at_utc": {"type": ["string", "null"]},
        "scope_status": {"enum": ["MATCH", "MISMATCH", "UNKNOWN"]},
        "current_validator_status": {"enum": ["PASS", "FAIL", "BLOCKED"]},
        "current_validator_blocker_code": {"type": ["string", "null"]},
        "current_validator_message": {"type": "string", "minLength": 1},
        "classification": {
          "enum": [
            "CURRENT_ACCEPTED",
            "LEGACY_SCHEMA_DRIFT",
            "UNSAFE_BLOCKED",
            "SCOPE_MISMATCH_BLOCKED",
            "UNREADABLE_OR_CORRUPT",
            "RECONCILIATION_REQUIRED"
          ]
        },
        "evidence_usable_current": {"type": "boolean"},
        "recommended_action": {
          "enum": [
            "ACCEPT_CURRENT_SOURCE",
            "RETAIN_LEGACY_REFERENCE_EXCLUDE_FROM_CURRENT_EVIDENCE",
            "REGENERATE_WITH_CURRENT_SCHEMA",
            "QUARANTINE_OPERATOR_REVIEW"
          ]
        },
        "missing_current_required_fields": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "runtime_cycle_hashes": {
          "type": "array",
          "items": {"type": "string", "minLength": 64, "maxLength": 64}
        },
        "unsafe_live_or_order_flag_detected": {"type": "boolean"},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_stale_loop_reconciliation_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "reconciliation_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "truth_role": {"const": "paper_runtime_reconciliation_truth"},
    "reconciliation_role": {"const": "PAPER_RUNTIME_STALE_LOOP_RECONCILIATION_NOT_LONG_RUN_EVIDENCE"},
    "evidence_use_policy": {"const": "CURRENT_SCHEMA_PASS_ONLY"},
    "source_loop_report_count": {"type": "integer", "minimum": 0},
    "current_accepted_count": {"type": "integer", "minimum": 0},
    "legacy_schema_drift_count": {"type": "integer", "minimum": 0},
    "unsafe_blocked_count": {"type": "integer", "minimum": 0},
    "invalid_json_count": {"type": "integer", "minimum": 0},
    "duplicate_runtime_cycle_hash_count": {"type": "integer", "minimum": 0},
    "current_evidence_usable_count": {"type": "integer", "minimum": 0},
    "legacy_reference_retained_count": {"type": "integer", "minimum": 0},
    "excluded_from_current_evidence_count": {"type": "integer", "minimum": 0},
    "reconciliation_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "items": {"type": "array", "items": {"$ref": "#/$defs/reconciliation_item"}},
    "delete_performed": {"const": false},
    "safe_delete_allowed": {"const": false},
    "operator_next_action": {"type": "string", "minLength": 1},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "reconciliation_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
