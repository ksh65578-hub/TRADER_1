{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_runtime_recovery_guard_report.v1",
  "title": "upbit_paper_runtime_recovery_guard_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "guard_id",
    "loop_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "latest_cycle_path",
    "latest_cycle_status",
    "latest_cycle_hash",
    "latest_cycle_recoverable",
    "latest_cycle_contract_mode",
    "latest_cycle_schema_upgrade_required",
    "latest_cycle_schema_upgrade_reason",
    "canonical_jsonl_checked_count",
    "corrupted_jsonl_quarantined_count",
    "ledger_jsonl_checked_count",
    "corrupted_ledger_jsonl_quarantined_count",
    "ledger_jsonl_invalid_count",
    "orphan_tmp_file_count",
    "artifact_paths",
    "recovery_guard_status",
    "primary_blocker_code",
    "blockers",
    "resume_action",
    "paper_runtime_resume_allowed",
    "runtime_evidence_role",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "long_run_blocker_code",
    "long_run_next_action",
    "promotion_eligible",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "guard_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_runtime_recovery_guard_report.v1"},
    "generated_at_utc": {"type": "string"},
    "project_id": {"const": "TRADER_1"},
    "guard_id": {"type": "string", "minLength": 1},
    "loop_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "latest_cycle_path": {"type": "string", "minLength": 1},
    "latest_cycle_status": {"enum": ["PASS", "BLOCKED", "FAIL", "MISSING"]},
    "latest_cycle_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "latest_cycle_recoverable": {"type": "boolean"},
    "latest_cycle_contract_mode": {
      "enum": [
        "CURRENT",
        "LEGACY_RECHECK_WITHOUT_QUANTITATIVE_POLICY_SUMMARY",
        "LEGACY_RECHECK_WITHOUT_CURRENT_SIZING_EXPOSURE_CAP",
        "LEGACY_RECHECK_WITHOUT_QUANTITATIVE_POLICY_SUMMARY_AND_CURRENT_SIZING_EXPOSURE_CAP"
      ]
    },
    "latest_cycle_schema_upgrade_required": {"type": "boolean"},
    "latest_cycle_schema_upgrade_reason": {"type": ["string", "null"]},
    "canonical_jsonl_checked_count": {"type": "integer", "minimum": 0},
    "corrupted_jsonl_quarantined_count": {"type": "integer", "minimum": 0},
    "ledger_jsonl_checked_count": {"type": "integer", "minimum": 0},
    "corrupted_ledger_jsonl_quarantined_count": {"type": "integer", "minimum": 0},
    "ledger_jsonl_invalid_count": {"type": "integer", "minimum": 0},
    "orphan_tmp_file_count": {"type": "integer", "minimum": 0},
    "artifact_paths": {"type": "array", "items": {"type": "string"}},
    "recovery_guard_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blockers": {"type": "array", "items": {"$ref": "common.defs.schema.json#/$defs/blocker_object"}},
    "resume_action": {"enum": ["RESUME_PAPER_ONLY", "SAFE_MODE_RECONCILE"]},
    "paper_runtime_resume_allowed": {"type": "boolean"},
    "runtime_evidence_role": {"const": "PAPER_RECOVERY_GUARD_ONLY_NOT_LONG_RUN_EVIDENCE"},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "long_run_blocker_code": {"const": "LONG_RUN_PAPER_RUNTIME_EVIDENCE_INSUFFICIENT"},
    "long_run_next_action": {"type": "string", "minLength": 1},
    "promotion_eligible": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "guard_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
