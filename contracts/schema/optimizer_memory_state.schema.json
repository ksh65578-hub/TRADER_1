{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.optimizer_memory_state.v1",
  "title": "optimizer_memory_state",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "authority",
    "optimizer_memory_state_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "strategy_id",
    "strategy_build_id",
    "parameter_hash",
    "timeframe_scope",
    "regime_scope",
    "memory_scope",
    "memory_status",
    "memory_sequence_number",
    "previous_memory_state_hash",
    "memory_state_hash",
    "source_modes",
    "source_artifact_ids",
    "last_write_kind",
    "state_write_policy",
    "candidate_memory_records",
    "failed_candidate_count",
    "blocked_candidate_count",
    "retired_candidate_count",
    "failed_candidates_retained",
    "retired_candidates_retained",
    "blocked_candidates_retained",
    "previous_search_space_retained",
    "previous_objective_profile_retained",
    "root_cause_history_retained",
    "risk_scaling_history_retained",
    "model_drift_history_retained",
    "dashboard_display_truth_only",
    "operator_warning",
    "blockers",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "live_permission_created",
    "live_config_mutation_allowed",
    "writes_live_ready_snapshot",
    "active_snapshot_mutation_allowed",
    "optimizer_winner_live_config_allowed",
    "paper_winner_live_config_allowed",
    "memory_reset_without_audit_allowed",
    "forget_failed_candidate_allowed",
    "cross_scope_memory_reuse_allowed",
    "scale_up_from_memory_allowed",
    "order_submission_allowed",
    "exchange_account_call_allowed"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "const": "trader1.optimizer_memory_state.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "project_id": {
      "const": "TRADER_1"
    },
    "authority": {
      "type": "object",
      "required": [
        "trader1_sha256",
        "agents_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "trader1_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "agents_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "optimizer_memory_state_id": {
      "type": "string",
      "minLength": 1
    },
    "exchange": {
      "$ref": "common.defs.schema.json#/$defs/exchange"
    },
    "market_type": {
      "$ref": "common.defs.schema.json#/$defs/market_type"
    },
    "mode": {
      "enum": [
        "REPLAY",
        "PAPER",
        "SHADOW",
        "READ_ONLY"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_build_id": {
      "type": "string",
      "minLength": 1
    },
    "parameter_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timeframe_scope": {
      "type": "string",
      "minLength": 1
    },
    "regime_scope": {
      "type": "string",
      "minLength": 1
    },
    "memory_scope": {
      "enum": [
        "OPTIMIZER_ANALYSIS_ONLY",
        "PAPER_SHADOW_RESEARCH_ONLY",
        "CONVERGENCE_MEMORY_ONLY"
      ]
    },
    "memory_status": {
      "enum": [
        "ACTIVE_APPEND_ONLY",
        "BLOCKED",
        "STALE_SAFE_MODE"
      ]
    },
    "memory_sequence_number": {
      "type": "integer",
      "minimum": 1
    },
    "previous_memory_state_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "memory_state_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "source_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "REPLAY",
          "PAPER",
          "SHADOW",
          "READ_ONLY"
        ]
      }
    },
    "source_artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "last_write_kind": {
      "enum": [
        "INIT",
        "APPEND",
        "VALIDATION_ONLY"
      ]
    },
    "state_write_policy": {
      "const": "APPEND_AUDIT_ONLY"
    },
    "candidate_memory_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "strategy_id",
          "parameter_hash",
          "source_mode",
          "memory_record_status",
          "last_outcome_status",
          "primary_root_cause_code",
          "failure_count",
          "promotion_blocked",
          "live_order_blocked",
          "audit_event_id"
        ],
        "additionalProperties": false,
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "strategy_id": {
            "type": "string",
            "minLength": 1
          },
          "parameter_hash": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "source_mode": {
            "enum": [
              "REPLAY",
              "PAPER",
              "SHADOW",
              "READ_ONLY"
            ]
          },
          "memory_record_status": {
            "enum": [
              "ACTIVE",
              "FAILED",
              "BLOCKED",
              "RETIRED"
            ]
          },
          "last_outcome_status": {
            "enum": [
              "IMPROVED_AFTER_COST",
              "FAILED_AFTER_COST",
              "BLOCKED_BY_GUARDRAIL",
              "RETIRED_AFTER_FAILURE"
            ]
          },
          "primary_root_cause_code": {
            "type": "string",
            "minLength": 1
          },
          "failure_count": {
            "type": "integer",
            "minimum": 0
          },
          "promotion_blocked": {
            "type": "boolean"
          },
          "live_order_blocked": {
            "type": "boolean"
          },
          "audit_event_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "failed_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "retired_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "failed_candidates_retained": {
      "const": true
    },
    "retired_candidates_retained": {
      "const": true
    },
    "blocked_candidates_retained": {
      "const": true
    },
    "previous_search_space_retained": {
      "const": true
    },
    "previous_objective_profile_retained": {
      "const": true
    },
    "root_cause_history_retained": {
      "const": true
    },
    "risk_scaling_history_retained": {
      "const": true
    },
    "model_drift_history_retained": {
      "const": true
    },
    "dashboard_display_truth_only": {
      "const": true
    },
    "operator_warning": {
      "type": "string",
      "minLength": 1
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "common.defs.schema.json#/$defs/blocker_object"
      }
    },
    "live_order_ready": {
      "const": false
    },
    "live_order_allowed": {
      "const": false
    },
    "can_live_trade": {
      "const": false
    },
    "scale_up_allowed": {
      "const": false
    },
    "live_permission_created": {
      "const": false
    },
    "live_config_mutation_allowed": {
      "const": false
    },
    "writes_live_ready_snapshot": {
      "const": false
    },
    "active_snapshot_mutation_allowed": {
      "const": false
    },
    "optimizer_winner_live_config_allowed": {
      "const": false
    },
    "paper_winner_live_config_allowed": {
      "const": false
    },
    "memory_reset_without_audit_allowed": {
      "const": false
    },
    "forget_failed_candidate_allowed": {
      "const": false
    },
    "cross_scope_memory_reuse_allowed": {
      "const": false
    },
    "scale_up_from_memory_allowed": {
      "const": false
    },
    "order_submission_allowed": {
      "const": false
    },
    "exchange_account_call_allowed": {
      "const": false
    }
  }
}
