{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trader1.upbit_paper_stale_loop_safe_regeneration_executor_report.v1",
  "title": "upbit_paper_stale_loop_safe_regeneration_executor_report",
  "type": "object",
  "required": [
    "schema_id",
    "generated_at_utc",
    "project_id",
    "executor_id",
    "exchange",
    "market_type",
    "mode",
    "session_id",
    "executor_role",
    "source_guard_hash",
    "source_guard_status",
    "planned_regeneration_item_count",
    "regenerated_item_count",
    "skipped_item_count",
    "validation_fail_count",
    "replacement_existing_count",
    "source_hash_mismatch_count",
    "executor_status",
    "primary_blocker_code",
    "blocker_codes",
    "source_retention_required",
    "replacement_write_mode",
    "items",
    "delete_source_allowed",
    "overwrite_source_allowed",
    "actual_regeneration_performed",
    "actual_long_run_evidence_created",
    "long_run_evidence_eligible",
    "promotion_eligible",
    "credential_load_attempted",
    "private_endpoint_called",
    "order_endpoint_called",
    "order_adapter_called",
    "live_key_loaded",
    "live_order_ready",
    "live_order_allowed",
    "can_live_trade",
    "scale_up_allowed",
    "executor_hash"
  ],
  "additionalProperties": false,
  "$defs": {
    "executor_item": {
      "type": "object",
      "required": [
        "source_path",
        "source_hash_expected",
        "source_hash_actual",
        "source_hash_match",
        "source_retained",
        "planned_replacement_loop_id",
        "planned_replacement_path",
        "replacement_write_mode",
        "replacement_existed_before",
        "replacement_exists_after",
        "replacement_written",
        "regenerated_loop_hash",
        "persistent_loop_validation_status",
        "persistent_loop_validation_message",
        "execution_item_status",
        "blocker_code",
        "delete_source_allowed",
        "overwrite_source_allowed",
        "actual_long_run_evidence_created",
        "live_order_ready",
        "live_order_allowed",
        "can_live_trade",
        "scale_up_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "source_hash_expected": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_hash_actual": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "source_hash_match": {"type": "boolean"},
        "source_retained": {"const": true},
        "planned_replacement_loop_id": {"type": ["string", "null"], "minLength": 1},
        "planned_replacement_path": {"type": "string", "minLength": 1},
        "replacement_write_mode": {"const": "CREATE_NEW_ONLY"},
        "replacement_existed_before": {"type": "boolean"},
        "replacement_exists_after": {"type": "boolean"},
        "replacement_written": {"type": "boolean"},
        "regenerated_loop_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
        "persistent_loop_validation_status": {"enum": ["PASS", "BLOCKED", "FAIL", "NOT_RUN"]},
        "persistent_loop_validation_message": {"type": "string"},
        "execution_item_status": {"enum": ["PASS", "BLOCKED"]},
        "blocker_code": {"type": ["string", "null"]},
        "delete_source_allowed": {"const": false},
        "overwrite_source_allowed": {"const": false},
        "actual_long_run_evidence_created": {"const": false},
        "live_order_ready": {"const": false},
        "live_order_allowed": {"const": false},
        "can_live_trade": {"const": false},
        "scale_up_allowed": {"const": false}
      }
    }
  },
  "properties": {
    "schema_id": {"const": "trader1.upbit_paper_stale_loop_safe_regeneration_executor_report.v1"},
    "generated_at_utc": {"type": "string", "minLength": 1},
    "project_id": {"const": "TRADER_1"},
    "executor_id": {"type": "string", "minLength": 1},
    "exchange": {"const": "UPBIT"},
    "market_type": {"const": "KRW_SPOT"},
    "mode": {"const": "PAPER"},
    "session_id": {"type": "string", "minLength": 1},
    "executor_role": {"const": "PAPER_RUNTIME_STALE_LOOP_SAFE_REGENERATION_EXECUTOR_CREATE_NEW_ONLY_NOT_LONG_RUN_EVIDENCE"},
    "source_guard_hash": {"type": ["string", "null"], "minLength": 64, "maxLength": 64},
    "source_guard_status": {"enum": ["PASS", "BLOCKED", null]},
    "planned_regeneration_item_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "regenerated_item_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "skipped_item_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "validation_fail_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "replacement_existing_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "source_hash_mismatch_count": {"type": "integer", "minimum": 0, "maximum": 20},
    "executor_status": {"enum": ["PASS", "BLOCKED"]},
    "primary_blocker_code": {"type": ["string", "null"]},
    "blocker_codes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_retention_required": {"const": true},
    "replacement_write_mode": {"const": "CREATE_NEW_ONLY"},
    "items": {"type": "array", "items": {"$ref": "#/$defs/executor_item"}},
    "delete_source_allowed": {"const": false},
    "overwrite_source_allowed": {"const": false},
    "actual_regeneration_performed": {"type": "boolean"},
    "actual_long_run_evidence_created": {"const": false},
    "long_run_evidence_eligible": {"const": false},
    "promotion_eligible": {"const": false},
    "credential_load_attempted": {"const": false},
    "private_endpoint_called": {"const": false},
    "order_endpoint_called": {"const": false},
    "order_adapter_called": {"const": false},
    "live_key_loaded": {"const": false},
    "live_order_ready": {"const": false},
    "live_order_allowed": {"const": false},
    "can_live_trade": {"const": false},
    "scale_up_allowed": {"const": false},
    "executor_hash": {"type": "string", "minLength": 64, "maxLength": 64}
  }
}
